<script type='text/javascript'>
//<![CDATA[
(function(){
  "use strict";

  /* =========================================================
     HIDE HEADER ON SPECIFIC PAGES (DENYLIST)
     - Exact slugs are safest (ignores query params automatically)
     - Keyword denylist is the safety net for new runner pages
     ---------------------------------------------------------
     ✅ To hide the header on a new page:
        1) Add "/p/your-page.html" into QA_HIDE_EXACT below, OR
        2) Ensure the slug contains one of QA_HIDE_KEYWORDS
  ========================================================= */

  var QA_HIDE_EXACT = [
    "/p/instant-ruuner-for-quiz-builder.html",
    "/p/timed-ruuner-for-quiz-builder.html",
    "/p/offline-pack-renderer.html",
    "/p/welcome-page.html",

    // ✅ TEACHER ASSESS (hide header on TA pages)
    "/p/teacher-classes-manager.html",
    "/p/teacher-quizzes-manager_25.html",
    "/p/teacher-bank.html",
    "/p/teacher-bank-import.html",
    "/p/teacher-library-picker.html",
    "/p/teacher-results.html",
    "/p/my-classes.html"

    // ✅ ADD MORE EXACT PAGES HERE (one per line, keep commas)
    // "/p/another-page-to-hide-header.html"
  ];

  var QA_HIDE_KEYWORDS = [
    "ruuner"
    // ✅ OPTIONAL: add more keywords if you are 100% sure they won't collide:
    // "runner"
  ];

  function _normPath(p){
    p = String(p || "").trim();
    if(!p) return "";
    p = p.toLowerCase();
    // Remove trailing slash safety
    if(p.length > 1 && p.charAt(p.length - 1) === "/") p = p.slice(0, -1);
    return p;
  }

  function _shouldHideHeader(){
    var path = _normPath(location && location.pathname);
    if(!path) return false;

    // Exact match
    for(var i=0;i<QA_HIDE_EXACT.length;i++){
      if(_normPath(QA_HIDE_EXACT[i]) === path) return true;
    }

    // Keyword match (path only; ignores query params like attempt_id)
    for(var k=0;k<QA_HIDE_KEYWORDS.length;k++){
      var kw = String(QA_HIDE_KEYWORDS[k] || "").toLowerCase().trim();
      if(kw && path.indexOf(kw) >= 0) return true;
    }

    return false;
  }

  function _hideHeaderNow(){
    // Hide all header UI parts safely
    var h = document.getElementById("qa-global-header");
    var d = document.getElementById("qaDrawer");
    var o = document.getElementById("qaOverlay");

    if(h) h.style.display = "none";
    if(d) d.style.display = "none";
    if(o) o.style.display = "none";

    // Also remove any open classes if present (defensive)
    if(d) d.classList.remove("is-open");
    if(o) o.classList.remove("is-active");
  }

  // ✅ EARLY EXIT (no listeners, no dropdown hooks, no scroll, no cache calls)
  if(_shouldHideHeader()){
    _hideHeaderNow();
    return;
  }

  var QA_NAV = {
    welcome:   "/p/welcome-page.html", // used for Brand + Login
    dashboard: "/p/dashboard_23.html",       // ✅ UPDATED: Dashboard now routes via Router
    teacher_router: "/p/router.html",  // ✅ NEW: Teacher Assess entry points here

    announce:  "/p/announcement.html",
    history:   "/p/learning-history.html",
    messages:  "/p/messages.html",
    offline:   "/p/my-offline-packs.html",
    pdf:       "/p/pdf-downloader.html",
    fixed:     "/p/fixed-quizzes.html",
    builder:   "/p/quiz-builder.html",

    // NEW/CONFIRMED
    upgrade:   "/p/upgrade-extend-add-on-my-subscription.html",
    profile:   "/p/myprofile.html",
    logout:    "/p/logout.html",

    // Login not provided separately — safest is to use your welcome/login hub
    login:     "/p/welcome-page.html"
  };

  /* =======================
     My Courses cache (fallback)  ✅ DO NOT BREAK
     ======================= */
  var QA_HDR_CACHE_KEY = "qa_access_cache_v1";
  var QA_HDR_CACHE_TTL_MS = 24 * 60 * 60 * 1000; // 24h

  function _safeJsonParse(s){
    try { return JSON.parse(s); } catch(e){ return null; }
  }

  function _getCachedAccess(){
    var raw = null;
    try { raw = localStorage.getItem(QA_HDR_CACHE_KEY); } catch(e){}
    if(!raw) return null;

    var obj = _safeJsonParse(raw);
    if(!obj || !obj.ts || !obj.access) return null;

    if((Date.now() - obj.ts) > QA_HDR_CACHE_TTL_MS) return null;
    return obj.access;
  }

  function _setCachedAccess(access){
    if(!access) return;

    // Keep it small + stable
    var slim = {
      coursesMeta: Array.isArray(access.coursesMeta) ? access.coursesMeta : [],
      // Optional: if your hasCourse relies on a list, store it here too.
      courses: Array.isArray(access.courses) ? access.courses : null,
      entitlements: Array.isArray(access.entitlements) ? access.entitlements : null
    };

    try {
      localStorage.setItem(QA_HDR_CACHE_KEY, JSON.stringify({ ts: Date.now(), access: slim }));
    } catch(e){}
  }

  function normCourseId(id){
    return String(id || '').trim().toUpperCase();
  }

  function _hasCourseFallback(access, courseId){
    var cid = normCourseId(courseId);
    if(!cid) return false;

    var arr = access && (access.entitlements || access.courses);
    if(Array.isArray(arr)){
      return arr.map(normCourseId).indexOf(cid) >= 0;
    }
    // If nothing to check against, assume meta already filtered server-side
    return true;
  }

  function courseHrefFromMeta(c){
    var slug = String((c && c.page_slug) || '').trim();
    if(!slug){
      slug = String((c && c.course_id) || '').trim().toLowerCase();
    }
    return slug ? ("/p/" + slug + ".html") : "#";
  }

  function sortCoursesGpFirst(list){
    var gp = [];
    var rest = [];
    list.forEach(function(c){
      if(normCourseId(c.course_id) === "GP") gp.push(c);
      else rest.push(c);
    });
    rest.sort(function(a,b){
      var ta = String(a.title || a.course_id || "");
      var tb = String(b.title || b.course_id || "");
      return ta.localeCompare(tb);
    });
    return gp.concat(rest);
  }

  function renderMyCoursesFromGuard(){
    var deskList  = document.getElementById("qaGhCoursesList");
    var deskEmpty = document.getElementById("qaGhCoursesEmpty");

    var mobList   = document.getElementById("qaMobCoursesList");
    var mobEmpty  = document.getElementById("qaMobCoursesEmpty");

    // ✅ Prefer live QA_ACCESS only if it contains usable coursesMeta; otherwise fallback to cache
    var access = null;
    var live = window.QA_ACCESS;

    if(live && Array.isArray(live.coursesMeta) && live.coursesMeta.length){
      access = live;
    } else {
      access = _getCachedAccess();
    }

    if(!access){
      if(deskEmpty) deskEmpty.style.display = "block";
      if(mobEmpty)  mobEmpty.style.display  = "block";
      if(deskList) deskList.innerHTML = "";
      if(mobList)  mobList.innerHTML  = "";
      return;
    }

    var meta = Array.isArray(access.coursesMeta) ? access.coursesMeta.slice() : [];

    // Prefer true hasCourse() only when available on this page AND when access is live
    var hasCourseFn =
      (access === live && live && live.hasCourse && typeof live.hasCourse === "function")
        ? live.hasCourse.bind(live)
        : function(cid){ return _hasCourseFallback(access, cid); };

    var active = meta
      .filter(function(c){ return String(c.status || "").toLowerCase() === "active"; })
      .filter(function(c){
        var cid = normCourseId(c.course_id);
        if(!cid) return false;
        return hasCourseFn ? !!hasCourseFn(cid) : true;
      });

    var sorted = sortCoursesGpFirst(active);

    if(deskList) deskList.innerHTML = "";
    if(mobList)  mobList.innerHTML  = "";

    if(!sorted.length){
      if(deskEmpty) deskEmpty.style.display = "block";
      if(mobEmpty)  mobEmpty.style.display  = "block";
      return;
    }

    if(deskEmpty) deskEmpty.style.display = "none";
    if(mobEmpty)  mobEmpty.style.display  = "none";

    sorted.forEach(function(c){
      var title = String(c.title || c.course_id || "Course").trim();
      var href  = courseHrefFromMeta(c);

      if(deskList){
        var a = document.createElement("a");
        a.className = "qa-gh-btn";
        a.href = href;
        a.textContent = title;
        deskList.appendChild(a);
      }

      if(mobList){
        var m = document.createElement("a");
        m.className = "qa-drawer-link";
        m.href = href;
        m.textContent = title;
        mobList.appendChild(m);
      }
    });
  }

  function hookGuardForCourses(){
    if(window.qaGuardReady && typeof window.qaGuardReady.then === "function"){
      window.qaGuardReady
        .then(function(state){
          // ✅ Only refresh cache when coursesMeta exists (avoid wiping good cache)
          try{
            if(state && state.ok && !state.blocked){
              if(window.QA_ACCESS && Array.isArray(window.QA_ACCESS.coursesMeta) && window.QA_ACCESS.coursesMeta.length){
                _setCachedAccess(window.QA_ACCESS);
              }
            }
          }catch(e){}
          renderMyCoursesFromGuard();
        })
        .catch(function(){
          renderMyCoursesFromGuard();
        });
    } else {
      // No guard on this page: render from cache if available
      renderMyCoursesFromGuard();
    }
  }

  function mount(){
    var map = {
      // Brand + Dashboard
      "qaGhBrand": QA_NAV.welcome,
      "qaGhDash": QA_NAV.dashboard,
      "qaMobDash": QA_NAV.dashboard,

      // ✅ NEW: Teacher Assess entry points (Router)
      "qaGhTeacherAssess": QA_NAV.teacher_router,
      "qaMobTeacherAssess": QA_NAV.teacher_router,

      // Communications
      "qaGhAnn": QA_NAV.announce,  "qaMobAnn": QA_NAV.announce,
      "qaGhMsg": QA_NAV.messages,  "qaMobMsg": QA_NAV.messages,

      // My Learning
      "qaGhHistory": QA_NAV.history, "qaMobHistory": QA_NAV.history,
      "qaGhOffline": QA_NAV.offline, "qaMobOffline": QA_NAV.offline,

      // Quiz tools
      "qaGhPdf": QA_NAV.pdf,        "qaMobPdf": QA_NAV.pdf,
      "qaGhFixed": QA_NAV.fixed,    "qaMobFixed": QA_NAV.fixed,
      "qaGhBuild": QA_NAV.builder,  "qaMobBuild": QA_NAV.builder,

      // Account
      "qaGhLogin": QA_NAV.login,      "qaMobLogin": QA_NAV.login,
      "qaGhProfile": QA_NAV.profile,  "qaMobProfile": QA_NAV.profile,
      "qaGhUpgrade": QA_NAV.upgrade,  "qaMobUpgrade": QA_NAV.upgrade,
      "qaGhLogout": QA_NAV.logout,    "qaMobLogout": QA_NAV.logout
    };

    for (var id in map) {
      var el = document.getElementById(id);
      if (el) el.href = map[id];
    }

    // Desktop dropdown toggle
    document.querySelectorAll(".qa-drop-trigger").forEach(function(btn) {
      btn.addEventListener("click", function(e) {
        e.stopPropagation();
        var p = this.parentElement;
        document.querySelectorAll(".qa-gh-dropdown").forEach(function(dd){
          if(dd !== p) dd.classList.remove("is-active");
        });
        p.classList.toggle("is-active");
      });
    });

    // Mobile Drawer open/close
    var drawer = document.getElementById("qaDrawer");
    var overlay = document.getElementById("qaOverlay");
    var openBtn = document.getElementById("qaMobileOpen");
    var closeBtn = document.getElementById("qaMobileClose");

    if(openBtn) openBtn.onclick = function(){
      drawer.classList.add("is-open");
      overlay.classList.add("is-active");
    };

    var closeDrawer = function(){
      drawer.classList.remove("is-open");
      overlay.classList.remove("is-active");
    };

    if(closeBtn) closeBtn.onclick = closeDrawer;
    if(overlay) overlay.onclick = closeDrawer;

    // Mobile accordion behavior (single-open)
    function closeAllAcc(exceptPanel){
      document.querySelectorAll(".qa-acc-item").forEach(function(item){
        var panel = item.querySelector(".qa-acc-panel");
        var key = panel ? panel.getAttribute("data-panel") : "";
        if(exceptPanel && key === exceptPanel) return;
        item.classList.remove("is-open");
      });
    }

    document.querySelectorAll(".qa-acc-trigger").forEach(function(btn){
      btn.addEventListener("click", function(){
        var key = this.getAttribute("data-acc");
        var item = this.closest(".qa-acc-item");
        var isOpen = item.classList.contains("is-open");
        closeAllAcc(key);
        if(!isOpen) item.classList.add("is-open");
        else item.classList.remove("is-open");
      });
    });

    // Close desktop dropdowns on outside click
    document.addEventListener("click", function() {
      document.querySelectorAll(".qa-gh-dropdown").forEach(function(dd) {
        dd.classList.remove("is-active");
      });
    });

    // Smart Scroll
    var lastScroll = 0;
    var header = document.getElementById("qa-global-header");
    window.addEventListener("scroll", function() {
      var currentScroll = window.pageYOffset || document.documentElement.scrollTop;
      if (currentScroll <= 0) {
        header.classList.remove("header-hidden");
        return;
      }
      if (currentScroll > lastScroll && !header.classList.contains("header-hidden")) {
        header.classList.add("header-hidden");
      }
      else if (currentScroll < lastScroll && header.classList.contains("header-hidden")) {
        header.classList.remove("header-hidden");
      }
      lastScroll = currentScroll;
    });

    // ✅ IMPORTANT: call after DOM elements exist
    hookGuardForCourses();
  }

  if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", mount);
  else mount();

})();
//]]>
</script>

