<style>
  :root{
    --qa-brand:#0b7a75;
    --qa-muted:#859998;
    --qa-ink:#0f172a;
    --qa-bg:#ffffff;
    --qa-soft:rgba(15,23,42,.08);
    --qa-soft2:rgba(15,23,42,.12);
    --qa-h:60px;
    --qa-red: #dc2626;
  }

  #qa-global-header {
    position: sticky;
    top: 0;
    z-index: 2147483000;
    font-family: system-ui, -apple-system, sans-serif;
    transition: transform 0.3s ease-in-out;
    will-change: transform;
  }

  #qa-global-header.header-hidden {
    transform: translateY(-110%);
  }

  .qa-gh{ height:var(--qa-h); background:var(--qa-bg); color:var(--qa-ink); border-bottom:1px solid var(--qa-soft); }
  .qa-gh:after{ content:&quot;&quot;; display:block; height:3px; background:var(--qa-muted); opacity:.55; }

  .qa-gh-row{
    height:var(--qa-h); max-width:1180px; margin:0 auto; padding:0 12px;
    display:flex; align-items:center; justify-content: space-between; box-sizing:border-box;
  }

  .qa-gh-brand{ display:flex; align-items:center; gap:10px; text-decoration:none; color:inherit; }
  .qa-gh-mark{
    width:36px; height:36px; border-radius:10px; display:grid; place-items:center;
    background:transparent; border:none;
    color:var(--qa-brand); font-weight:800;
  }
  .qa-gh-mark img{
    width:100%;
    height:100%;
    object-fit:contain;
    display:block;
    border-radius:10px;
  }

  .qa-gh-title b{ font-size:16px; display: block; }
  .qa-gh-title small{ font-size:11px; color:rgba(15,23,42,.64); }

  .qa-gh-actions{ display:flex; align-items:center; gap:8px; }

  .qa-gh-btn, .qa-drop-trigger, .qa-mobile-toggle{
    display:inline-flex; align-items:center; gap:8px;
    height:40px; padding:0 12px; border-radius:10px;
    border:1px solid var(--qa-soft); background:#fff;
    color:var(--qa-ink); text-decoration:none;
    font:700 13px/1.1 inherit; cursor:pointer; white-space:nowrap;
  }
  .qa-gh-btn:hover, .qa-drop-trigger:hover, .qa-gh-dropdown.is-active .qa-drop-trigger{
    border-color:var(--qa-brand); background:#f0f9f8;
  }

  .qa-gh-btn svg, .qa-drop-trigger svg, .qa-mobile-toggle svg{ width:18px; height:18px; color:var(--qa-brand); flex-shrink:0; }

  .qa-gh-dropdown { position: relative; }
  .qa-drop-menu {
    position: absolute; top: 48px; right: 0;
    background: #fff; min-width: 220px;
    max-height: 450px; overflow-y: auto;
    box-shadow: 0 12px 30px rgba(0,0,0,0.15);
    border-radius: 12px; border: 1px solid var(--qa-soft);
    padding: 8px; display: none; z-index: 100;
  }
  .qa-gh-dropdown.is-active .qa-drop-menu { display: block; }
  .qa-drop-menu .qa-gh-btn { display: flex; width: 100%; border: none; justify-content: flex-start; margin-bottom: 2px; }

  /* Account dropdown: make logout visually distinct */
  .qa-drop-menu .qa-gh-btn.qa-logout { color: var(--qa-red); font-weight: 800; }
  .qa-drop-menu .qa-gh-btn.qa-logout:hover { background: rgba(220,38,38,.08); }

  .qa-mobile-toggle { display: none; }

  .qa-mobile-drawer {
    position: fixed; top: 0; right: -100%; width: 290px; height: 100%;
    background: #fff; z-index: 2147484001; box-shadow: -5px 0 20px rgba(0,0,0,0.1);
    transition: right 0.3s ease; padding: 18px; box-sizing: border-box;
    overflow-y: auto;
  }
  .qa-mobile-drawer.is-open { right: 0; }
  .qa-drawer-overlay {
    position: fixed; top:0; left:0; width:100%; height:100%;
    background: rgba(0,0,0,0.4); z-index: 2147484000; display: none;
  }
  .qa-drawer-overlay.is-active { display: block; }

  .qa-drawer-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
  .qa-drawer-link {
    display: flex; align-items: center; gap: 12px; padding: 12px;
    text-decoration: none; color: var(--qa-ink); font-weight: 650; font-size: 14px;
    border-radius: 10px; margin: 2px 6px;
  }
  .qa-drawer-link:hover { background: var(--qa-soft); }

  /* Mobile accordion (inside drawer) */
  .qa-acc-item{
    border: 1px solid var(--qa-soft);
    border-radius: 14px;
    overflow: hidden;
    margin: 10px 0;
    background: #fff;
  }
  .qa-acc-trigger{
    width: 100%;
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 12px;
    background: #fff;
    border: none;
    cursor: pointer;
    color: var(--qa-ink);
    font-weight: 850;
    font-size: 13px;
  }
  .qa-acc-trigger:hover{ background: #f7fbfa; }
  .qa-acc-chevron{
    width: 18px; height: 18px; flex: 0 0 auto;
    color: var(--qa-brand);
    transition: transform .18s ease;
  }
  .qa-acc-item.is-open .qa-acc-chevron{ transform: rotate(180deg); }

  .qa-acc-panel{
    display: none;
    padding: 6px 0 10px;
    border-top: 1px solid var(--qa-soft);
    background: #fff;
  }
  .qa-acc-item.is-open .qa-acc-panel{ display: block; }

  .qa-logout-link { color: var(--qa-red) !important; font-weight: 850; }
  .qa-logout-link:hover { background: rgba(220,38,38,.08) !important; }

  @media (max-width: 900px) {
    .qa-gh-actions { display: none; }
    .qa-mobile-toggle { display: flex; }
  }
</style>

