<style>
  :root{
    --teal:#0b7a75; --teal-dark:#095e5a;
    --ink:#1f2a28; --muted:#5b6a68;
    --line:#e8f0ef; --radius:14px;
    --shadow:0 8px 18px rgba(0,0,0,.05);
  }
  .qa-wrap{
    max-width:780px;margin:0 auto;padding:44px 18px 64px;
    font-family:system-ui, Segoe UI, Roboto, sans-serif;
    color:var(--ink);text-align:center;position:relative;z-index:1;
  }

  /* Ambient background (subtle) */
  .qa-bg{position:fixed;inset:0;background:
    radial-gradient(900px 600px at 12% 18%, rgba(11,122,117,.06), transparent 60%),
    radial-gradient(800px 560px at 88% 8%, rgba(11,122,117,.05), transparent 60%),
    linear-gradient(120deg,#f8fbfb,#fafcfb 30%,#f8fbfb)}
  .qa-bg::before{
    content:"";position:absolute;inset:-25%;
    background:conic-gradient(from 0deg, rgba(11,122,117,.06), transparent 45%, rgba(11,122,117,.05));
    filter:blur(50px);animation:spin 28s linear infinite;
  }
  @keyframes spin{to{transform:rotate(360deg)}}

  .card{
    background:#fff;border:1px solid rgba(0,0,0,.06);
    border-radius:var(--radius);
    padding:22px 18px;margin:0 auto;
    box-shadow:var(--shadow);
    opacity:0;transform:translateY(10px);
    animation:enter .55s ease forwards;
  }
  @keyframes enter{to{opacity:1;transform:translateY(0)}}

  .brand{font-weight:900;letter-spacing:.2px;color:var(--ink);font-size:clamp(19px,2.5vw,21px);margin:6px 0 4px}
  .h1{font-size:clamp(23px,3.3vw,30px);margin:2px 0 8px;color:var(--teal);line-height:1.22}
  .sub{color:var(--muted);font-size:15px;line-height:1.6;margin:0}

  .row{display:flex;flex-wrap:wrap;gap:10px;justify-content:center;margin-top:14px}
  .btn{
    display:inline-block;padding:11px 16px;border-radius:11px;
    font-weight:800;font-size:15px;text-decoration:none;
    border:1px solid transparent;
    transition:transform .1s,box-shadow .2s,background .2s,border-color .2s;
  }
  .btn.primary{
    color:#fff;background:var(--teal);
    box-shadow:0 6px 14px rgba(11,122,117,.22), inset 0 -2px 0 rgba(0,0,0,.06);
  }
  .btn.primary:hover{background:var(--teal-dark)}
  .btn.secondary{
    background:#f0f7f6;color:var(--teal);border-color:#dfe9e7;
  }
  .btn.secondary:hover{background:#e7f2f0;border-color:#d2e5e2}

  .links{margin-top:10px;font-size:14px;color:var(--muted)}
  .links a{color:var(--teal);text-decoration:none}
  .links a:hover{text-decoration:underline}

  .sep{height:1px;background:var(--line);margin:14px auto;max-width:520px;border-radius:999px}

  @media (prefers-reduced-motion:reduce){
    .qa-bg::before,.card{animation:none!important}
  }
  @media (max-width:480px){
    .qa-wrap{padding:36px 16px 56px}
  }
</style>

<div aria-hidden="true" class="qa-bg"></div>

<div class="qa-wrap">
  <div class="card">
    <div class="brand">QAcademy Nurses Hub</div>
    <h1 class="h1">Portal Access</h1>
    <p class="sub">Log in to continue. New here? Create a free account. Already paid? Upgrade or extend your access.</p>

    <div class="row">
      <a id="qa-link-login" class="btn primary" href="/p/login_23.html" aria-label="Log in">Log In</a>
      <a id="qa-link-register" class="btn secondary" href="/p/portal-registration.html" aria-label="Create free account">Create Free Account</a>
    </div>

    <div class="links">
      <a id="qa-link-upgrade" href="/p/upgrade-extend-add-on-my-subscription.html">Upgrade / Extend</a>
      &nbsp;•&nbsp;
      <a id="qa-link-dashboard" href="/p/dashboard.html">Open Dashboard</a>
    </div>

    <div class="sep"></div>

    <div class="links">
      <a id="qa-link-join" href="/p/subscribe-to-nmc-licensure.html">Join 2026 Licensure Prep</a>
      &nbsp;•&nbsp;
      <a id="qa-link-public" href="https://www.qacademynurses.com">Back to Main Site</a>
    </div>
  </div>
</div>
