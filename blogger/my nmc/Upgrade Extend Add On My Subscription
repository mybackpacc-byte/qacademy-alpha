<!-- =================== 2) GUARD v3 (Upgrade variant: NO auto-redirect; user chooses) =================== -->
<script>
(function(){
  'use strict';

  var cfg = (window.QA_CONFIG && typeof window.QA_CONFIG === 'object') ? window.QA_CONFIG : {};

  // ✅ Auth WebApp (PortalAuthv2)
  var AUTH_URL = (cfg.AUTH_URL || '').trim();

  // ✅ Slugs
  var LOGIN_SLUG     = (cfg.LOGIN_SLUG || '').trim();
  var DASHBOARD_SLUG = (cfg.DASHBOARD_SLUG || '').trim();
  var SUBSCRIBE_SLUG = (cfg.SUBSCRIBE_SLUG || '').trim();

  // ✅ Storage keys (standard)
  var TOKEN_KEY = 'qa_token';
  var USERID_KEY = 'qa_user_id';

  // Exposed state/promise (same contract as Dashboard)
  window.QA_GUARD_STATE = 'pending';
  window.QA_GUARD_BLOCK_TYPE = null;

  var guardResolve, guardReject;
  window.qaGuardReady = new Promise(function(resolve, reject){
    guardResolve = resolve;
    guardReject  = reject;
  });

  function persistGuardState(state, blockType){
    window.QA_GUARD_STATE = state;
    window.QA_GUARD_BLOCK_TYPE = blockType || null;
  }

  function pageUrl(slug){
    slug = String(slug || '').trim();
    if(!slug) return '/';
    if(/^https?:\/\//i.test(slug)) return slug;
    if(slug[0] === '/') return slug;
    return '/p/' + slug + '.html';
  }

  function currentReturn(){
    return (location.pathname || '/') + (location.search || '') + (location.hash || '');
  }

  function goToLogin(reason){
    var url = pageUrl(LOGIN_SLUG);
    var params = [];
    if(reason) params.push('reason=' + encodeURIComponent(reason));
    params.push('return_to=' + encodeURIComponent(currentReturn()));
    if(params.length){
      url += (url.indexOf('?') === -1 ? '?' : '&') + params.join('&');
    }
    location.href = url;
  }

  function goToSubscribe(){
    var url = pageUrl(SUBSCRIBE_SLUG);
    var sep = url.indexOf('?') === -1 ? '?' : '&';
    url += sep + 'return_to=' + encodeURIComponent(currentReturn());
    location.href = url;
  }

  function goToDashboard(){
    location.href = pageUrl(DASHBOARD_SLUG);
  }

  function exitBack(){
    if(window.history && history.length > 1){
      history.back();
      return;
    }
    goToDashboard();
  }

  // ✅ Expose safe handlers (avoids fragile function-to-string injection)
  window.qaGoToLogin = goToLogin;
  window.qaGoToSubscribe = goToSubscribe;
  window.qaExitBack = exitBack;
  window.qaGoToDashboard = goToDashboard;

  window.qaLogout = function(){
    try{
      localStorage.removeItem(TOKEN_KEY);
      localStorage.removeItem(USERID_KEY);
    }catch(e){}
    goToLogin('logout');
  };

  // ---- Guard overlay UI ----
  var ov = document.getElementById('qa-guard-overlay');
  var ovTitle = document.getElementById('qa-guard-title');
  var ovBody = document.getElementById('qa-guard-body');
  var ovActions = document.getElementById('qa-guard-actions');

  function showGuardOverlay(title, body, actionsHtml){
    if(ovTitle) ovTitle.textContent = title || 'Checking your access...';
    if(ovBody)  ovBody.textContent  = body  || 'Please wait a moment.';
    if(ovActions) ovActions.innerHTML = actionsHtml || '';
    if(ov) ov.classList.add('on');
  }
  function hideGuardOverlay(){
    if(ov) ov.classList.remove('on');
  }

  function actionsFor(type){
    var btnLogin =
      '<button type="button" class="qa-guard-btn primary" onclick="qaGoToLogin(\'' + String(type||'') + '\')">Log in to continue</button>';
    var btnSubscribe =
      '<button type="button" class="qa-guard-btn ghost" onclick="qaGoToSubscribe()">Subscribe</button>';
    var btnExit =
      '<button type="button" class="qa-guard-btn ghost" onclick="qaExitBack()">Exit</button>';

    if(type === 'admin_required' || type === 'no_course_access' || type === 'account_issue'){
      return '<button type="button" class="qa-guard-btn primary" onclick="qaGoToDashboard()">Go to Dashboard</button>' +
             '<button type="button" class="qa-guard-btn ghost" onclick="qaExitBack()">Exit</button>';
    }

    // Default for upgrade: login / subscribe / exit
    return btnLogin + btnSubscribe + btnExit;
  }

  function block(type, title, body){
    persistGuardState('blocked', type);
    showGuardOverlay(title, body, actionsFor(type));
    guardResolve({ ok:false, blocked:true, type:type });
  }

  function runGuard(){
    if(!AUTH_URL || AUTH_URL.indexOf('PASTE_') !== -1){
      persistGuardState('error', 'missing_auth_url');
      showGuardOverlay(
        'Page not configured',
        'AUTH_URL is missing. Update QA_CONFIG.AUTH_URL in this page.',
        '<button type="button" class="qa-guard-btn primary" onclick="qaExitBack()">Exit</button>'
      );
      guardReject(new Error('missing_auth_url'));
      return;
    }

    showGuardOverlay('Checking your access...', 'Please wait while we verify your session.', '');

    var token = '';
    try{ token = localStorage.getItem(TOKEN_KEY) || ''; }catch(e){ token = ''; }

    if(!token){
      block('session_expired', 'Sign in required', 'To upgrade/extend access, please sign in. If you don’t have an account, tap Subscribe.');
      return;
    }

    fetch(AUTH_URL, {
      method:'POST',
      headers:{ 'Content-Type':'application/x-www-form-urlencoded' },
      body: new URLSearchParams({ action:'verify', token: token })
    })
    .then(function(r){ return r.json(); })
    .then(function(data){
      if(!data || data.ok !== true){
        var errCode = (data && data.error) || 'unknown_error';

        if(errCode === 'missing_token' || errCode === 'not_found' || errCode === 'expired'){
          try{
            localStorage.removeItem(TOKEN_KEY);
            localStorage.removeItem(USERID_KEY);
          }catch(e){}
          block('session_expired', 'Session expired', 'Please sign in again to continue upgrading your account.');
          return;
        }

        if(errCode === 'user_missing' || errCode === 'user_inactive' || errCode === 'user_expired'){
          block('account_issue', 'Account issue', 'There is a problem with your account. Please contact QAcademy support.');
          return;
        }

        persistGuardState('error', errCode);
        showGuardOverlay(
          'Could not verify access',
          'We could not verify your session right now. Please sign in again or try later.',
          actionsFor('session_expired')
        );
        guardReject(new Error('verify_failed:' + errCode));
        return;
      }

      var u = data.user || {};
      var flags = data.flags || {};
      var access = (data.access && typeof data.access === 'object') ? data.access : {};

      window.QA_USER = {
        id: u.user_id || '',
        user_id: u.user_id || '',
        username: u.username || '',
        email: u.email || '',
        name: u.name || '',
        forename: u.forename || '',
        surname: u.surname || '',
        phone_number: u.phone_number || '',
        program_id: u.program_id || '',
        cohort: u.cohort || '',
        avatar_url: u.avatar_url || '',
        role: u.role || '',
        is_admin: !!(flags && flags.is_admin),
        must_change_password: !!u.must_change_password,
        user_expires_utc: u.expires_utc || '',
        signup_source: u.signup_source || ''
      };

      var courseIds = Array.isArray(access.courses) ? access.courses.slice() : [];
      var upperIds = courseIds.map(function(c){ return String(c||'').trim().toUpperCase(); }).filter(Boolean);

      window.QA_ACCESS = {
        courseIds: upperIds,
        access_expires_utc: access.expires_utc || '',
        coursesMeta: Array.isArray(data.courses) ? data.courses : [],
        hasCourse: function(courseId){
          var cid = String(courseId||'').trim().toUpperCase();
          if(!cid) return false;
          return this.courseIds.indexOf(cid) !== -1;
        }
      };

      try{
        if(window.QA_USER && window.QA_USER.user_id){
          localStorage.setItem(USERID_KEY, window.QA_USER.user_id);
        }
      }catch(e){}

      persistGuardState('ready', null);
      hideGuardOverlay();
      guardResolve({ ok:true, blocked:false, kind:'upgrade' });
    })
    .catch(function(err){
      persistGuardState('error', 'network');
      showGuardOverlay(
        'Network problem',
        'We could not verify your access due to a network error. Check your connection and reload.',
        '<button type="button" class="qa-guard-btn primary" onclick="location.reload()">Reload</button>' +
        '<button type="button" class="qa-guard-btn ghost" onclick="qaExitBack()">Exit</button>'
      );
      guardReject(err);
    });
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', runGuard);
  } else {
    runGuard();
  }
})();
</script>

<!-- =================== 3) UPGRADE PAGE LOGIC (runs ONLY after qaGuardReady ok) =================== -->
<script>
(function(){
  // ===================== CONFIG (EDIT THESE) =====================
  // ✅ Payments WebApp (your Paystack payments webapp)
  const PAYMENTS_URL = "https://script.google.com/macros/s/AKfycbyvUw_eEGzHZd0wBsuKDNckQNFXJU-Xhr3T6J8pAuMRlgQbDhVy2nqp9H_QpeUQAI5I/exec"; // TODO: update if changed

  // ✅ FIXED (recommended): make success callback absolute
  const SUCCESS_URL  = location.origin + "/p/payment-confirmation.html"; // TODO: change slug if needed

  // ✅ PortalAuthv2 WebApp URL (used for subscriptions include=subscriptions)
  const AUTH_URL = (window.QA_CONFIG && window.QA_CONFIG.AUTH_URL) ? window.QA_CONFIG.AUTH_URL : "";

  // token key (standard)
  const TOKEN_KEY = "qa_token";

  // ===================== UI HELPERS =====================
  const $ = (id)=>document.getElementById(id);
  const loader = (on)=>{ $("qaLoader").classList.toggle("on", !!on); };

  function showAlert(kind, msg){
    const el = $("qaAlert");
    if(!msg){ el.innerHTML=""; return; }
    el.innerHTML = `<div class="alert ${kind==='ok'?'ok':'err'}">${msg}</div>`;
  }

  function escHtml(s){
    return String(s||"")
      .replace(/&/g,"&amp;")
      .replace(/</g,"&lt;")
      .replace(/>/g,"&gt;")
      .replace(/"/g,"&quot;")
      .replace(/'/g,"&#039;");
  }

  function money(minor, currency){
    const v = Number(minor||0);
    if(!v) return "";
    const major = v / 100;
    try{
      return new Intl.NumberFormat(undefined, { style:"currency", currency: currency || "GHS" }).format(major);
    }catch(_){
      return (currency||"GHS") + " " + major.toFixed(2);
    }
  }

  // IMPORTANT: no custom headers -> avoids CORS preflight
  function postForm(url, data){
    const body = new URLSearchParams();
    Object.keys(data||{}).forEach(k=>{
      if(data[k] !== undefined && data[k] !== null) body.append(k, String(data[k]));
    });
    return fetch(url, { method:"POST", body });
  }

  function fmtDate(iso){
    if(!iso) return "—";
    const d = new Date(iso);
    if(isNaN(d.getTime())) return String(iso);
    return d.toLocaleString(undefined, { year:"numeric", month:"short", day:"2-digit", hour:"2-digit", minute:"2-digit" });
  }

  function daysLeftFromIso(iso){
    if(!iso) return null;
    const d = new Date(iso);
    if(isNaN(d.getTime())) return null;
    const ms = d.getTime() - Date.now();
    return Math.floor(ms / 86400000);
  }

  function statusClassFromDays(days){
    if(days === null) return "warn";
    if(days <= 0) return "bad";
    if(days <= 7) return "warn";
    return "ok";
  }

  // ===================== SUBSCRIPTIONS RENDER =====================
  async function loadAndRenderSubscriptions(token){
    const box = $("qaSubsBox");
    box.style.display = "none";
    box.innerHTML = "";

    const pill = $("qaUserPill");

    if(!AUTH_URL || AUTH_URL.indexOf("PASTE_") !== -1){
      tryRenderPillFromGuardOnly();
      return;
    }

    try{
      const url = `${AUTH_URL}?action=verify&token=${encodeURIComponent(token)}&include=subscriptions`;
      const r = await fetch(url, { method:"GET" });
      const j = await r.json();

      if(!j || !j.ok){
        pill.style.display = "none";
        return;
      }

      const u = j.user || {};
      const subs = Array.isArray(j.subscriptions) ? j.subscriptions : [];

      const fullName =
        (u.forename || u.surname) ? [u.forename||"", u.surname||""].join(" ").trim() :
        (u.name || u.full_name || u.username || u.email || "Signed in");

      const program = (u.program_name || u.program_id || u.program || "").toString().trim();
      const cohort  = (u.cohort || "").toString().trim();
      const role    = (u.role || "").toString().trim();

      const accessExp = (j.access && j.access.expires_utc) ? j.access.expires_utc : "";
      let bestExp = accessExp;

      if(!bestExp && subs.length){
        let maxT = 0;
        subs.forEach(s=>{
          const t = new Date(s.expires_utc||"").getTime();
          if(!isNaN(t) && t > maxT) maxT = t;
        });
        if(maxT) bestExp = new Date(maxT).toISOString();
      }

      const dl = daysLeftFromIso(bestExp);

      pill.style.display = "inline-flex";

      const parts = [];
      parts.push(fullName);
      if(program) parts.push(program);
      if(cohort)  parts.push("Cohort " + cohort);
      if(role && role.toLowerCase() !== "student") parts.push(role);

      const statusPart =
        (dl === null) ? "Status" :
        (dl <= 0) ? "Expired" :
        `Active (${dl}d left)`;

      parts.push(statusPart);

      pill.title = parts.join(" | ");
      pill.innerHTML = `
        <div class="line">
          ${parts.map((txt, i) => `
            <span class="seg ${i===0 ? "name" : ""}">${escHtml(txt)}</span>
            ${i < parts.length - 1 ? `<span class="sep">|</span>` : ``}
          `).join("")}
        </div>
      `;

      if(!subs.length){
        box.style.display = "block";
        box.innerHTML = `
          <h2>Your subscriptions</h2>
          <div class="submeta">
            No active subscriptions found.
            ${bestExp ? `<br><b>Latest access expiry:</b> ${fmtDate(bestExp)}` : ""}
            <br>If you just paid, refresh this page after a few seconds.
          </div>
        `;
        return;
      }

      const itemsHtml = subs.map(s=>{
        const name = (s.product_name || s.product_id || "—");
        const expIso = s.expires_utc || "";
        const exp  = fmtDate(expIso);

        const dlRaw = (s.days_left === "" || s.days_left === null || s.days_left === undefined) ? null : Number(s.days_left);
        const daysLeft = (dlRaw !== null && !isNaN(dlRaw)) ? dlRaw : daysLeftFromIso(expIso);

        const chipClass = statusClassFromDays(daysLeft);
        let chipText = daysLeft === null ? "Expiry unknown" : `${daysLeft} day${daysLeft===1?"":"s"} left`;
        if(daysLeft !== null && daysLeft <= 0) chipText = "Expired";

        const idHint = (s.product_name && s.product_id) ? ` - ${s.product_id}` : "";

        return `
          <div class="subitem">
            <div class="subleft">
              <div class="subname" title="${escHtml(name)}">${escHtml(name)}</div>
              <div class="submeta"><b>Ends:</b> ${escHtml(exp)}${idHint ? `<span style="opacity:.75">${escHtml(idHint)}</span>` : ""}</div>
            </div>
            <div class="chips">
              <span class="chip ${chipClass}">${escHtml(chipText)}</span>
            </div>
          </div>
        `;
      }).join("");

      box.style.display = "block";
      box.innerHTML = `
        <h2>Your subscriptions</h2>
        <div class="sublist">${itemsHtml}</div>
        <div class="submeta" style="margin-top:8px">
          Renewing the same product extends your expiry automatically.
        </div>
      `;
    }catch(err){
      console.error("subs_load_failed", err);
      $("qaUserPill").style.display = "none";
    }
  }

  function tryRenderPillFromGuardOnly(){
    const pill = $("qaUserPill");
    const u = window.QA_USER || {};
    if(!u || (!u.user_id && !u.email && !u.username)){
      pill.style.display = "none";
      return;
    }

    const fullName =
      (u.forename || u.surname) ? [u.forename||"", u.surname||""].join(" ").trim() :
      (u.name || u.username || u.email || "Signed in");

    const program = (u.program_id || "").toString().trim();
    const cohort  = (u.cohort || "").toString().trim();
    const role    = (u.role || "").toString().trim();

    const parts = [];
    parts.push(fullName);
    if(program) parts.push(program);
    if(cohort) parts.push("Cohort " + cohort);
    if(role && role.toLowerCase() !== "student") parts.push(role);
    parts.push("Signed in");

    pill.style.display = "inline-flex";
    pill.title = parts.join(" | ");
    pill.innerHTML = `
      <div class="line">
        ${parts.map((txt, i) => `
          <span class="seg ${i===0 ? "name" : ""}">${escHtml(txt)}</span>
          ${i < parts.length - 1 ? `<span class="sep">|</span>` : ``}
        `).join("")}
      </div>
    `;
  }

  // ===================== STATE =====================
  let meta = { programs:[], products:[] };
  let productsAll = [];

  // ===================== APP INIT (only after guard ok) =====================
  async function initApp(){
    const token = localStorage.getItem(TOKEN_KEY) || "";
    if(!token){
      showAlert("err", "You’re not signed in. Please go to the Login page, then return here.");
      $("product").innerHTML = `<option value="">Sign in required</option>`;
      $("payBtn").disabled = true;
      $("qaUserPill").style.display = "none";
      return;
    }

    loader(true);

    $("qaUserPill").style.display = "inline-flex";
    $("qaUserPill").innerHTML = `
      <div class="line">
        <span class="seg name">Loading…</span>
        <span class="sep">|</span>
        <span class="seg">Preparing upgrade</span>
      </div>
    `;

    loadAndRenderSubscriptions(token);

    try{
      if(!PAYMENTS_URL || PAYMENTS_URL.indexOf("PASTE_") !== -1){
        throw new Error("missing_payments_url");
      }

      const r = await fetch(PAYMENTS_URL + "?action=meta", { method:"GET" });
      const j = await r.json();
      if(!j || !j.ok) throw new Error((j && j.error) || "meta_failed");

      meta = j;
      productsAll = Array.isArray(meta.products) ? meta.products : [];

      const progSel = $("program");
      (meta.programs || []).forEach(p=>{
        const opt = document.createElement("option");
        opt.value = p.program_id || "";
        opt.textContent = p.program_name || p.program_id || "";
        progSel.appendChild(opt);
      });

      renderProducts(productsAll);

      $("program").addEventListener("change", onFilterChanged);
      $("product").addEventListener("change", onProductChanged);
      $("payBtn").addEventListener("click", onPay);

      onProductChanged();
    }catch(err){
      console.error(err);
      showAlert("err", "Could not load products. Please refresh. If it persists, contact support.");
      $("product").innerHTML = `<option value="">Failed to load products</option>`;
      $("payBtn").disabled = true;
    } finally {
      loader(false);
    }
  }

  function renderProducts(list){
    const sel = $("product");
    sel.innerHTML = `<option value="">Select a product</option>`;
    (list || []).forEach(p=>{
      const opt = document.createElement("option");
      opt.value = p.product_id;
      opt.textContent = `${p.name} - ${money(p.price_minor, p.currency)}`;
      opt.dataset.price_minor = p.price_minor;
      opt.dataset.currency = p.currency || "GHS";
      opt.dataset.name = p.name || p.product_id;
      sel.appendChild(opt);
    });
    $("payBtn").disabled = true;
    $("priceLine").textContent = "";
  }

  function onFilterChanged(){
    renderProducts(productsAll);
    showAlert("", "");
  }

  function onProductChanged(){
    const sel = $("product");
    const opt = sel.options[sel.selectedIndex];
    const pid = sel.value || "";

    if(!pid){
      $("payBtn").disabled = true;
      $("priceLine").textContent = "";
      return;
    }
    const priceMinor = opt.dataset.price_minor;
    const currency = opt.dataset.currency || "GHS";
    $("priceLine").textContent = "Price: " + money(priceMinor, currency);
    $("payBtn").disabled = false;
    showAlert("", "");
  }

  async function onPay(){
    const token = localStorage.getItem(TOKEN_KEY) || "";
    const product_id = $("product").value || "";

    if(!token){
      showAlert("err","You’re signed out. Please log in again.");
      if(window.qaGoToLogin) window.qaGoToLogin('session_expired');
      return;
    }
    if(!product_id){
      showAlert("err","Please select a product.");
      return;
    }

    loader(true);
    $("payBtn").disabled = true;

    try{
      const resp = await postForm(PAYMENTS_URL, {
        action: "pay_init_upgrade",
        token,
        product_id,
        callback_url: SUCCESS_URL
      });

      const j = await resp.json();
      if(!j || !j.ok){
        const msg = (j && (j.error || j.detail)) ? String(j.error || j.detail) : "pay_init_upgrade_failed";
        if(msg.toLowerCase().includes("token")) {
          showAlert("err", "Your session has expired. Please log in again, then retry.");
          try{ localStorage.removeItem(TOKEN_KEY); }catch(e){}
          if(window.qaGoToLogin) window.qaGoToLogin('session_expired');
        } else {
          showAlert("err", "Could not start payment. Please try again. If it persists, contact support.");
        }
        throw new Error(msg);
      }

      if(!j.authorization_url){
        throw new Error("missing_authorization_url");
      }

      window.location.href = j.authorization_url;
    }catch(err){
      console.error(err);
      $("payBtn").disabled = false;
    } finally {
      loader(false);
    }
  }

  if(window.qaGuardReady){
    window.qaGuardReady
      .then(function(state){
        if(state && state.ok && !state.blocked){
          initApp();
        }
      })
      .catch(function(err){
        console.error("Upgrade guard error", err);
      });
  } else {
    initApp();
  }
})();
</script>
