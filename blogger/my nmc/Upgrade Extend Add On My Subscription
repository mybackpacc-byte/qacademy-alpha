<!-- =================== QAcademy — Upgrade / Extend Access (Paystack) =================== -->
<meta name="viewport" content="width=device-width, initial-scale=1" />
<style>
  :root{
    --brand:#0b7a75; --muted:#859998; --ink:#1f2a28; --bg:#f6f8f7; --card:#ffffff; --line:#e5e7eb;
    --danger:#b42318; --dangerSoft:#fef2f2;
    --ok:#166534; --okSoft:#ecfdf3;
    --shadow:0 12px 28px rgba(0,0,0,.07);
    --r:16px;
  }
  *{box-sizing:border-box}
  body{margin:0;background:var(--bg);color:var(--ink);font-family:system-ui,-apple-system,Segoe UI,Roboto,sans-serif}
  .wrap{max-width:820px;margin:22px auto;padding:0 14px}
  .card{background:var(--card);border:1px solid rgba(0,0,0,.06);border-radius:var(--r);box-shadow:var(--shadow);padding:16px}
  h1{margin:0 0 8px;font-size:20px}
  .sub{margin:0 0 14px;color:#5b6b69;font-size:13px;line-height:1.45}
  .row{display:flex;gap:12px;flex-wrap:wrap}
  .col{flex:1;min-width:240px}
  label{display:block;font-size:12px;color:#51615f;margin:10px 0 6px}
  select,input{width:100%;padding:11px 12px;border-radius:12px;border:1px solid var(--line);background:#fff;font-size:14px;outline:none}
  select:focus,input:focus{border-color:rgba(11,122,117,.5);box-shadow:0 0 0 4px rgba(11,122,117,.12)}
  .btn{
    width:100%; margin-top:12px; padding:12px 14px; border:0; border-radius:14px;
    background:var(--brand); color:#fff; font-weight:700; font-size:14px; cursor:pointer;
  }
  .btn:disabled{opacity:.55; cursor:not-allowed}
  .note{margin-top:10px;font-size:12px;color:#60706e}

  /* ===== User pill (single line on desktop; | separators) ===== */
  .pill{
    display:inline-flex;
    align-items:center;
    justify-content:flex-end;
    padding:8px 12px;
    border-radius:999px;
    font-size:12px;
    background:#eef6f5;
    color:#0a5f5a;
    border:1px solid rgba(11,122,117,.18);
    max-width:100%;
  }
  .pill .line{
    display:inline-flex;
    align-items:center;
    gap:8px;
    white-space:nowrap;         /* desktop: one line */
    overflow:hidden;
    text-overflow:ellipsis;
    max-width:520px;
  }
  .pill .seg{font-weight:800}
  .pill .seg.name{font-weight:900}
  .pill .sep{opacity:.45; font-weight:800}

  .alert{
    margin-top:12px; padding:10px 12px; border-radius:14px; border:1px solid var(--line);
    font-size:13px; line-height:1.45;
  }
  .alert.err{background:var(--dangerSoft); border-color:#fbd5d5; color:var(--danger)}
  .alert.ok{background:var(--okSoft); border-color:#bbf7d0; color:var(--ok)}
  .hr{height:1px;background:var(--line);margin:14px 0}
  .small{font-size:12px;color:#5b6b69}

  /* ====== Subscriptions box ====== */
  .subbox{
    margin-top:12px;
    border:1px solid rgba(11,122,117,.18);
    background:#f2fbfa;
    border-radius:14px;
    padding:12px;
  }
  .subbox h2{
    margin:0 0 8px;
    font-size:13px;
    letter-spacing:.01em;
  }

  .sublist{display:flex;flex-direction:column;gap:8px}
  .subitem{
    display:flex;
    align-items:flex-start;
    justify-content:space-between;
    gap:10px;
    padding:10px 10px;
    border-radius:12px;
    background:#fff;
    border:1px solid rgba(0,0,0,.06);
  }
  .subleft{min-width:0; flex:1}
  .subname{
    font-weight:800;
    font-size:13px;
    line-height:1.25;
    white-space:nowrap;
    overflow:hidden;
    text-overflow:ellipsis;
    max-width:100%;
  }
  .submeta{margin-top:2px;font-size:12px;color:#5b6b69;line-height:1.35}
  .chips{display:flex;flex-wrap:wrap;gap:6px;justify-content:flex-end;flex-shrink:0}
  .chip{
    display:inline-flex;align-items:center;gap:6px;
    padding:5px 9px;border-radius:999px;font-size:12px;font-weight:800;
    border:1px solid rgba(0,0,0,.10);
    background:#f7f8f8;color:#2b3a38;
    white-space:nowrap;
  }
  .chip.ok{background:#ecfdf3;border-color:#bbf7d0;color:#166534}
  .chip.warn{background:#fff7ed;border-color:#fed7aa;color:#9a3412}
  .chip.bad{background:#fef2f2;border-color:#fecaca;color:#b42318}

  /* Loader overlay */
  .qa-loader{
    position:fixed; inset:0; background:rgba(246,248,247,.78);
    display:none; align-items:center; justify-content:center; z-index:9999;
    backdrop-filter: blur(4px);
  }
  .qa-loader.on{display:flex}
  .spinner{
    width:42px; height:42px; border-radius:50%;
    border:4px solid rgba(11,122,117,.18);
    border-top-color: var(--brand);
    animation:spin .85s linear infinite;
  }
  @keyframes spin{to{transform:rotate(360deg)}}

  /* ===== Guard overlay (matches Dashboard guard style) ===== */
  #qa-guard-overlay{
    position:fixed; inset:0; z-index:99999;
    background:rgba(15,23,42,0.86);
    display:none;
    align-items:center;
    justify-content:center;
    padding:16px;
    font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
  }
  #qa-guard-overlay.on{display:flex}
  #qa-guard-overlay .inner{
    max-width:420px;width:100%;
    background:#ffffff;
    border-radius:16px;
    padding:18px 20px;
    box-shadow:0 18px 45px rgba(15,23,42,0.45);
    text-align:center;
  }
  #qa-guard-overlay .title{
    font-size:18px;font-weight:650;margin-bottom:6px;color:#0b7a75;
  }
  #qa-guard-overlay .body{
    font-size:14px;color:#475569;margin-bottom:14px;line-height:1.45;
  }
  #qa-guard-overlay .actions{
    display:flex;flex-wrap:wrap;gap:8px;justify-content:center;
  }
  .qa-guard-btn{
    display:inline-flex;align-items:center;justify-content:center;
    padding:9px 14px;border-radius:999px;border:none;
    font-size:14px;font-weight:750;cursor:pointer;text-decoration:none;
  }
  .qa-guard-btn.primary{background:#0b7a75;color:#ffffff}
  .qa-guard-btn.ghost{background:#eef6f5;color:#0b7a75;border:1px solid rgba(11,122,117,.22)}
  .qa-guard-btn.danger{background:#b42318;color:#ffffff}

  /* phone: allow wrapping so we don't clip */
  @media (max-width:520px){
    .pill .line{white-space:normal; max-width:260px}
    #qa-guard-overlay .inner{border-radius:14px}
  }
</style>

