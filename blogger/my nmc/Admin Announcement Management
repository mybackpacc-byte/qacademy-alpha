  // ✅ Escape HTML for safe table rendering (prevents XSS)
  function escapeHtml(s){
    s = String(s || '');
    return s.replace(/[&<>"']/g, function(ch){
      return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]);
    });
  }

  /* ==========================
     ✅ SAFE HTML AUTHORING HELPERS (UPGRADED)
     ========================== */

  function qaDecodeHtmlEntities(str){
    str = String(str || '');
    if(str.indexOf('&lt;') === -1 && str.indexOf('&gt;') === -1 && str.indexOf('&amp;') === -1) return str;
    var ta = document.createElement('textarea');
    ta.innerHTML = str;
    return ta.value;
  }

  function qaIsSafeHref(href){
    if(!href) return false;
    href = String(href).trim();

    // ✅ allow hash placeholder for fixed-quiz buttons
    if(href === '#') return true;

    // allow relative links
    if(href[0] === '/' || href[0] === '?' || href[0] === '#') return true;

    // block javascript:, data:, vbscript:
    var lower = href.replace(/\s+/g,'').toLowerCase();
    if(lower.startsWith('javascript:') || lower.startsWith('data:') || lower.startsWith('vbscript:')) return false;

    try{
      var u = new URL(href, window.location.origin);
      return (u.protocol === 'http:' || u.protocol === 'https:' || u.protocol === 'mailto:' || u.protocol === 'tel:');
    }catch(e){
      return false;
    }
  }

  function qaIsSafeSrc(src){
    if(!src) return false;
    src = String(src).trim();

    // allow relative
    if(src[0] === '/' || src[0] === '?') return true;

    var lower = src.replace(/\s+/g,'').toLowerCase();
    if(lower.startsWith('javascript:') || lower.startsWith('data:') || lower.startsWith('vbscript:')) return false;

    try{
      var u = new URL(src, window.location.origin);
      return (u.protocol === 'http:' || u.protocol === 'https:');
    }catch(e){
      return false;
    }
  }

  // ✅ Convert single-enter newlines to <p> blocks (and keep explicit <br>)
  function qaNormalizeNewlinesToParagraphs(raw){
    raw = qaDecodeHtmlEntities(raw);
    raw = String(raw || '').replace(/\r\n/g, '\n').replace(/\r/g, '\n');
    if(!raw.trim()) return '';

    var lines = raw.split('\n');
    var out = [];
    var blockStartRe = /^\s*<(p\b|\/p\b|ul\b|\/ul\b|ol\b|\/ol\b|pre\b|\/pre\b)\s*/i;

    for(var i=0;i<lines.length;i++){
      var line = lines[i];
      var trimmed = (line || '').trim();
      if(!trimmed) continue;

      if(blockStartRe.test(trimmed)){
        out.push(trimmed);
      }else{
        out.push('<p>' + trimmed + '</p>');
      }
    }
    return out.join('\n');
  }

  // ✅ Sanitizer: supports fixed-quiz launch attributes
  function qaSanitizeToFragment(html){
    html = qaDecodeHtmlEntities(html);
    html = String(html || '');
    var tpl = document.createElement('template');
    tpl.innerHTML = html;

    var ALLOWED = { A:1, P:1, BR:1, STRONG:1, EM:1, B:1, I:1, UL:1, OL:1, LI:1, CODE:1, PRE:1, SPAN:1, DIV:1, IMG:1 };

    var walker = document.createTreeWalker(tpl.content, NodeFilter.SHOW_ELEMENT, null, false);
    var nodes = [];
    while(walker.nextNode()) nodes.push(walker.currentNode);

    nodes.forEach(function(node){
      var tag = node.tagName;

      if(!ALLOWED[tag]){
        var parent = node.parentNode;
        if(parent){
          while(node.firstChild) parent.insertBefore(node.firstChild, node);
          parent.removeChild(node);
        }
        return;
      }

      var attrs = Array.prototype.slice.call(node.attributes || []);
      attrs.forEach(function(attr){
        var name = String(attr.name || '').toLowerCase();

        if(name.startsWith('on') || name === 'style'){
          node.removeAttribute(attr.name);
          return;
        }

        if(tag === 'A'){
          // ✅ allow quiz launcher attributes
          if(
            name !== 'href' &&
            name !== 'title' &&
            name !== 'class' &&
            name !== 'data-qa' &&
            name !== 'data-qa-fixed-quiz' &&
            name !== 'data-qa-mode'
          ){
            node.removeAttribute(attr.name);
            return;
          }

          if(name === 'href'){
            var href = node.getAttribute('href') || '';
            if(!qaIsSafeHref(href)){
              node.removeAttribute('href');
            }else{
              // Only set target/rel for real links (not '#')
              if(href !== '#'){
                node.setAttribute('target','_blank');
                node.setAttribute('rel','noopener noreferrer nofollow');
              }
            }
          }

          if(name === 'data-qa'){
            var v = (node.getAttribute('data-qa') || '').toLowerCase();
            if(v !== 'btn') node.removeAttribute('data-qa');
          }

          if(name === 'data-qa-fixed-quiz'){
            var qid = (node.getAttribute('data-qa-fixed-quiz') || '').trim();
            if(!/^[A-Za-z0-9_-]+$/.test(qid)) node.removeAttribute('data-qa-fixed-quiz');
            else node.setAttribute('data-qa-fixed-quiz', qid.toUpperCase());
          }

          if(name === 'data-qa-mode'){
            var m = (node.getAttribute('data-qa-mode') || '').toLowerCase();
            if(m !== 'instant' && m !== 'timed') node.removeAttribute('data-qa-mode');
            else node.setAttribute('data-qa-mode', m);
          }
        }
        else if(tag === 'IMG'){
          if(name !== 'src' && name !== 'alt' && name !== 'title'){
            node.removeAttribute(attr.name);
            return;
          }
          if(name === 'src'){
            var src = node.getAttribute('src') || '';
            if(!qaIsSafeSrc(src)) node.removeAttribute('src');
          }
        }
        else{
          // non-A, non-IMG tags: remove all attributes
          node.removeAttribute(attr.name);
        }
      });
    });

    return tpl.content;
  }

  function qaSanitizeToHtml(html){
    var frag = qaSanitizeToFragment(html);
    var div = document.createElement('div');
    div.appendChild(frag.cloneNode(true));
    return div.innerHTML;
  }

  function qaExtractTextFromHtml(html){
    var frag = qaSanitizeToFragment(html);
    var div = document.createElement('div');
    div.appendChild(frag);
    return (div.textContent || '').replace(/\s+/g,' ').trim();
  }

  function wrapSelection(textarea, before, after){
    var el = textarea;
    var start = el.selectionStart || 0;
    var end = el.selectionEnd || 0;
    var val = el.value || '';
    var sel = val.slice(start, end);
    var out = val.slice(0,start) + before + sel + after + val.slice(end);
    el.value = out;
    var caret = start + before.length + sel.length + after.length;
    el.focus();
    el.setSelectionRange(caret, caret);
  }

  function selectionToList(textarea, kind){
    var el = textarea;
    var start = el.selectionStart || 0;
    var end = el.selectionEnd || 0;
    var val = el.value || '';
    var sel = val.slice(start, end) || '';
    var lines = sel.split('\n').map(function(s){ return s.trim(); }).filter(Boolean);
    if(!lines.length) lines = ['Item 1','Item 2'];

    var tag = (kind === 'ol') ? 'ol' : 'ul';
    var html = '<' + tag + '>' + lines.map(function(x){ return '<li>' + escapeHtml(x) + '</li>'; }).join('') + '</' + tag + '>';
    var out = val.slice(0,start) + html + val.slice(end);
    el.value = out;
    el.focus();
  }

  /* ==========================
     ✅ META + CHIPS
     ========================== */

  function renderChipGroup(containerEl, items, scopeKey){
    if(!containerEl) return;
    containerEl.innerHTML = '';

    if(!items || !items.length){
      containerEl.innerHTML = '<span class="qa-chip-hint">No options from meta.</span>';
      return;
    }

    items.forEach(function(item){
      var val, label;
      if(typeof item === 'string'){
        val = item; label = item;
      }else{
        val = item.id || item.value || '';
        label = item.label || item.id || item.value || '';
      }
      if(!val) return;

      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'qa-chip-toggle';
      btn.dataset.scope = scopeKey;
      btn.dataset.value = val;
      btn.innerHTML = '<span>'+ label +'</span>';

      btn.addEventListener('click', function(){
        toggleScopeChip(scopeKey, val);
      });

      containerEl.appendChild(btn);
    });

    updateScopeChipVisuals(scopeKey);
  }

  function toggleScopeChip(scopeKey, value){
    var arr = scopeSelected[scopeKey];
    if(!arr) return;
    var idx = arr.indexOf(value);
    if(idx === -1) arr.push(value);
    else arr.splice(idx, 1);
    updateScopeChipVisuals(scopeKey);
  }

  function updateScopeChipVisuals(scopeKey){
    var arr = scopeSelected[scopeKey] || [];
    var set = new Set(arr);
    var container;

    if(scopeKey === 'programs') container = els.scopePrograms;
    else if(scopeKey === 'courses') container = els.scopeCourses;
    else if(scopeKey === 'levels') container = els.scopeLevels;
    else if(scopeKey === 'cohorts') container = els.scopeCohorts;
    else if(scopeKey === 'subscriptionKinds') container = els.scopeSubKinds;
    else if(scopeKey === 'productIds') container = els.scopeProducts;
    else if(scopeKey === 'audience') container = els.scopeAudience;
    else return;

    if(!container) return;
    Array.from(container.querySelectorAll('.qa-chip-toggle')).forEach(function(chip){
      var val = chip.dataset.value;
      chip.classList.toggle('qa-chip-active', set.has(val));
    });
  }

  function updateAllScopeVisuals(){
    updateScopeChipVisuals('programs');
    updateScopeChipVisuals('courses');
    updateScopeChipVisuals('levels');
    updateScopeChipVisuals('cohorts');
    updateScopeChipVisuals('subscriptionKinds');
    updateScopeChipVisuals('productIds');
    updateScopeChipVisuals('audience');
  }

  function loadMeta(){
    setMetaStatus('Loading filter options…', false);

    return apiGet({ action:'announcements.meta' })
      .then(function(data){
        if(!data || data.ok === false) throw new Error((data && data.error) || 'Meta error');
        meta = data;

        var statusItems = (data.status_options || []).map(function(s){ return { id:s, label:s }; });
        populateSelect(els.status, statusItems, { keepFirst:true });

        populateSelect(els.program, data.programs || [], { keepFirst:true });
        populateSelect(els.course, data.courses || [], { keepFirst:true });

        var cohortItems = (data.cohorts || []).map(function(c){ return { id:c, label:c }; });
        populateSelect(els.cohort, cohortItems, { keepFirst:true });

        var kinds = (data.subscription_kinds || []).map(function(k){ return { id:k, label:k }; });
        populateSelect(els.subkind, kinds, { keepFirst:true });

        var prods = (data.product_ids || []).map(function(p){ return { id:p, label:p }; });
        populateSelect(els.product, prods, { keepFirst:true });

        var auds = (data.audiences || []).map(function(a){ return { id:a, label:a }; });
        populateSelect(els.audience, auds, { keepFirst:true });

        renderChipGroup(els.scopePrograms,  data.programs || [], 'programs');
        renderChipGroup(els.scopeCourses,   data.courses  || [], 'courses');
        renderChipGroup(els.scopeLevels,    data.levels   || [], 'levels');
        renderChipGroup(els.scopeCohorts,   data.cohorts  || [], 'cohorts');
        renderChipGroup(els.scopeSubKinds,  data.subscription_kinds || [], 'subscriptionKinds');
        renderChipGroup(els.scopeProducts,  data.product_ids || [], 'productIds');
        renderChipGroup(els.scopeAudience,  data.audiences || [], 'audience');

        setMetaStatus('Filter options loaded.', false);
      })
      .catch(function(err){
        console.error(err);
        setMetaStatus('Failed to load filter options.', true);
      });
  }

  /* ==========================
     ✅ USER SCOPE HELPERS
     ========================== */

  function renderSelectedUsers(){
    if(!els.uSelected) return;
    var ids = scopeSelected.userIds || [];
    if(!ids.length){ els.uSelected.innerHTML = ''; return; }

    var html = '';
    ids.forEach(function(id){
      var label = selectedUserLabels[id] || id;
      html += '<span class="qa-user-chip" data-id="'+id+'">'
           +  '<span>'+ escapeHtml(label) +'</span>'
           +  '<button type="button" data-id="'+id+'" aria-label="Remove">×</button>'
           + '</span>';
    });
    els.uSelected.innerHTML = html;

    Array.from(els.uSelected.querySelectorAll('button[data-id]')).forEach(function(btn){
      btn.addEventListener('click', function(ev){
        ev.preventDefault();
        ev.stopPropagation();
        var id = btn.getAttribute('data-id');
        removeUserFromScope(id);
      });
    });
  }

  function addUserToScope(user){
    if(!user || !user.user_id) return;
    var id = String(user.user_id);
    if(scopeSelected.userIds.indexOf(id) === -1) scopeSelected.userIds.push(id);

    var labelParts = [];
    if(user.name) labelParts.push(user.name);
    if(user.program_id) labelParts.push('('+user.program_id+')');
    if(!labelParts.length && user.email) labelParts.push(user.email);
    var label = labelParts.join(' ');
    selectedUserLabels[id] = label || id;
    renderSelectedUsers();
  }

  function removeUserFromScope(id){
    if(!id) return;
    var idx = scopeSelected.userIds.indexOf(id);
    if(idx !== -1) scopeSelected.userIds.splice(idx,1);
    renderSelectedUsers();
  }

  function performUserSearch(){
    if(!els.uSearch || !els.uResults) return;
    var q = (els.uSearch.value || '').trim();
    if(!q){ els.uResults.textContent = 'Type a name, email or user ID to search.'; return; }
    els.uResults.textContent = 'Searching…';

    apiGet({ action: 'users.search', q: q, limit: 10 })
      .then(function(data){
        if(!data || data.ok === false) throw new Error((data && data.error) || 'Search error');

        var items = data.items || [];
        if(!items.length){
          els.uResults.textContent = 'No users found for "'+q+'".';
          return;
        }

        var html = '';
        items.forEach(function(u){
          var labelName = u.name || '(no name)';
          var program = u.program_id || '';
          var email = u.email || '';
          var id = u.user_id || '';

          html += '<div class="qa-user-result-item" data-user-id="'+escapeHtml(id)+'">'
               +   '<div class="qa-user-result-main">'
               +     '<div class="qa-user-result-name">'+ escapeHtml(labelName) +'</div>'
               +     '<div class="qa-user-result-meta">'
               +        (program ? escapeHtml(program)+' · ' : '')
               +        (email ? escapeHtml(email)+' · ' : '')
               +        'ID: '+ escapeHtml(shortId(id))
               +     '</div>'
               +   '</div>'
               +   '<button type="button" class="qa-btn qa-btn-subtle qa-btn-add-user" data-user-id="'+escapeHtml(id)+'">Add</button>'
               + '</div>';
        });

        els.uResults.innerHTML = html;

        Array.from(els.uResults.querySelectorAll('.qa-btn-add-user')).forEach(function(btn){
          btn.addEventListener('click', function(){
            var id = btn.getAttribute('data-user-id');
            var user = (items || []).find(function(u){ return String(u.user_id) === String(id); });
            if(user) addUserToScope(user);
          });
        });
      })
      .catch(function(err){
        console.error(err);
        els.uResults.textContent = 'Search failed: ' + err.message;
      });
  }

  /* ==========================
     ✅ LIST SIDE
     ========================== */

  function loadAnnouncements(){
    var token = getToken();
    if(!token){
      els.resultsMeta.textContent = 'Missing token.';
      els.tableWrap.innerHTML = '<div class="qa-empty">Cannot load — missing token.</div>';
      return;
    }

    els.resultsLabel.textContent = 'Announcements (loading…)';
    els.resultsMeta.textContent  = '';

    var params = { action: 'announcements.list', mode: 'admin', limit: 100 };

    if(els.status.value)   params.status            = els.status.value;
    if(els.program.value)  params.program_id        = els.program.value;
    if(els.course.value)   params.course_id         = els.course.value;
    if(els.cohort.value)   params.cohort            = els.cohort.value;
    if(els.subkind.value)  params.subscription_kind = els.subkind.value;
    if(els.product.value)  params.product_id        = els.product.value;
    if(els.audience.value) params.audience          = els.audience.value;
    if(els.search.value)   params.search            = els.search.value.trim();

    apiGet(params)
      .then(function(data){
        if(!data || data.ok === false) throw new Error((data && data.error) || 'List error');

        var items = data.items || [];
        var total = data.total || items.length;
        announcements = items;

        els.resultsLabel.textContent = 'Announcements';
        els.resultsMeta.textContent  = total + ' total · showing ' + items.length;

        if(!items.length){
          els.tableWrap.innerHTML = '<div class="qa-empty">No announcements matched your filters.</div>';
          return;
        }

        var html = '<table class="qa-table"><thead><tr>'
          + '<th>ID</th>'
          + '<th>Title &amp; body</th>'
          + '<th>Status</th>'
          + '<th>Window</th>'
          + '<th>Scope</th>'
          + '<th>Flags</th>'
          + '</tr></thead><tbody>';

        items.forEach(function(a, idx){
          var eff = a.status_effective || a.status || '';

          var winParts = [];
          if(a.start_at) winParts.push('From '  + formatDateISO(a.start_at));
          if(a.end_at)   winParts.push('Until ' + formatDateISO(a.end_at));
          var win = winParts.join('<br/>');

          var scopeHtml =
            scopeBadges('Prog',   a.scope_programs) +
            scopeBadges('Course', a.scope_courses) +
            scopeBadges('Cohort', a.scope_cohort) +
            scopeBadges('Level',  a.scope_level) +
            scopeBadges('Kind',   a.scope_subscription_kind) +
            scopeBadges('Prod',   a.scope_product_ids) +
            scopeBadges('Aud',    a.scope_audience) +
            scopeBadges('User',   a.scope_user_ids);

          var flags = [];
          if(a.pinned) flags.push('<span class="qa-pill qa-pill-pinned">Pinned</span>');
          if(a.priority !== undefined && a.priority !== null && a.priority !== ''){
            flags.push('<span class="qa-badge-small">Priority '+ escapeHtml(a.priority) +'</span>');
          }
          if(!flags.length) flags.push('<span class="qa-badge-small">None</span>');

          var bodyId = 'body-'+idx;
          var bodyRaw = a.body_html || '';
          var bodyPreview = '';
          if(bodyRaw){
            var shortBody = String(bodyRaw).replace(/\s+/g,' ').trim();
            if(shortBody.length > 140) shortBody = shortBody.slice(0,140) + '…';
            bodyPreview = shortBody;
          }

          html += '<tr data-id="'+ escapeHtml(a.announcement_id || '') +'">'
            + '<td><div>'+ escapeHtml(shortId(a.announcement_id)) +'</div></td>'
            + '<td>'
            +   '<div style="font-weight:600;">'+ escapeHtml(a.title || '(no title)') +'</div>'
            +   (bodyPreview
                  ? '<div style="font-size:12px;color:var(--muted);margin-top:2px;">'
                    + escapeHtml(bodyPreview)
                    + '</div>'
                  : '')
            +   (bodyRaw
                  ? '<div style="margin-top:3px;"><button type="button" class="qa-body-toggle" data-body-id="'+bodyId+'">Toggle full body</button></div>'
                    + '<div id="'+bodyId+'" class="qa-body-text" style="display:none;">'+ escapeHtml(bodyRaw) +'</div>'
                  : '')
            + '</td>'
            + '<td>'+ pillForStatus(eff) +'<br/><span class="qa-badge-small">Raw: '+ escapeHtml(a.status || 'n/a') +'</span></td>'
            + '<td>'+ (win || '<span class="qa-badge-small">No dates</span>') +'</td>'
            + '<td>'+ (scopeHtml || '<span class="qa-badge-small">Global</span>') +'</td>'
            + '<td>'+ flags.join('<br/>') +'</td>'
            + '</tr>';
        });

        html += '</tbody></table>';
        els.tableWrap.innerHTML = html;

        Array.from(els.tableWrap.querySelectorAll('.qa-body-toggle')).forEach(function(btn){
          btn.addEventListener('click', function(ev){
            ev.stopPropagation();
            var id = btn.getAttribute('data-body-id');
            var el = document.getElementById(id);
            if(!el) return;
            var show = (el.style.display === 'none' || !el.style.display);
            el.style.display = show ? 'block' : 'none';
          });
        });

        Array.from(els.tableWrap.querySelectorAll('tbody tr')).forEach(function(row){
          row.addEventListener('click', function(){
            var id = row.getAttribute('data-id');
            if(!id) return;
            handleRowClick(id);
          });
        });

      })
      .catch(function(err){
        console.error(err);
        els.resultsLabel.textContent = 'Announcements';
        els.resultsMeta.textContent  = 'Failed to load.';
        els.tableWrap.innerHTML = '<div class="qa-empty">An error occurred while loading announcements.</div>';
      });
  }

  function clearFilters(){
    els.status.value   = '';
    els.program.value  = '';
    els.course.value   = '';
    els.cohort.value   = '';
    els.subkind.value  = '';
    els.product.value  = '';
    els.audience.value = '';
    els.search.value   = '';
  }

  function handleRowClick(id){
    var item = (announcements || []).find(function(a){ return a.announcement_id === id; });
    if(!item) return;
    enterFormMode(item);
  }

  /* ==========================
     ✅ FORM SIDE
     ========================== */

  function toLocalDtValue(iso){
    if(!iso) return '';
    try{
      var d = new Date(iso);
      if(isNaN(d.getTime())) return '';
      var pad = function(n){ return n < 10 ? '0'+n : ''+n; };
      return d.getFullYear() + '-' + pad(d.getMonth()+1) + '-' + pad(d.getDate()) + 'T' + pad(d.getHours()) + ':' + pad(d.getMinutes());
    }catch(e){
      return '';
    }
  }

  function resetScopeSelection(){
    scopeSelected.programs = [];
    scopeSelected.courses  = [];
    scopeSelected.levels   = [];
    scopeSelected.cohorts  = [];
    scopeSelected.subscriptionKinds = [];
    scopeSelected.productIds       = [];
    scopeSelected.audience         = [];
    scopeSelected.userIds          = [];
    selectedUserLabels = {};
    updateAllScopeVisuals();
    renderSelectedUsers();
  }

  function resetForm(asNew){
    els.fId.value    = '';
    els.fTitle.value = '';
    els.fBody.value  = '';
    els.fStatus.value   = 'draft';
    els.fPriority.value = '1';
    els.fStartAt.value  = '';
    els.fEndAt.value    = '';
    els.fPinned.checked = false;
    els.fDismiss.checked = false;

    if(els.uSearch) els.uSearch.value = '';
    if(els.uResults) els.uResults.textContent = '';

    currentAnnouncement = null;
    resetScopeSelection();

    els.formTitle.textContent = 'New announcement';
    els.formSubtitle.textContent = 'Fill in the fields and click “Save announcement”.';
    setFormStatus('', false);

    if(els.bodyPreview) els.bodyPreview.innerHTML = '<span style="color:var(--muted);">Preview will appear here…</span>';

    if(asNew){
      try{ els.fTitle.focus(); }catch(e){}
    }
  }

  function fillFormFromAnnouncement(item){
    els.fId.value    = item.announcement_id || '';
    els.fTitle.value = item.title || '';

    var rawForEdit = item.body_html || item.body || item.body_text || '';
    els.fBody.value = qaDecodeHtmlEntities(rawForEdit);

    if(item.status) els.fStatus.value = String(item.status).toLowerCase() || 'draft';
    else els.fStatus.value = 'draft';

    if(item.priority !== undefined && item.priority !== null && item.priority !== ''){
      els.fPriority.value = String(item.priority);
    }else{
      els.fPriority.value = '1';
    }

    els.fStartAt.value = toLocalDtValue(item.start_at || '');
    els.fEndAt.value   = toLocalDtValue(item.end_at   || '');

    els.fPinned.checked  = !!item.pinned;
    els.fDismiss.checked = !!item.dismissible;

    scopeSelected.programs = parseCsvToArray(item.scope_programs || '');
    scopeSelected.courses  = parseCsvToArray(item.scope_courses  || '');
    scopeSelected.levels   = parseCsvToArray(item.scope_level    || '');
    scopeSelected.cohorts  = parseCsvToArray(item.scope_cohort   || '');
    scopeSelected.subscriptionKinds = parseCsvToArray(item.scope_subscription_kind || '');
    scopeSelected.productIds       = parseCsvToArray(item.scope_product_ids       || '');
    scopeSelected.audience         = parseCsvToArray(item.scope_audience          || '');
    scopeSelected.userIds          = parseCsvToArray(item.scope_user_ids          || '');

    selectedUserLabels = {};
    updateAllScopeVisuals();
    renderSelectedUsers();

    if(els.uSearch) els.uSearch.value = '';
    if(els.uResults) els.uResults.textContent = '';

    els.formTitle.textContent = 'Edit announcement';
    els.formSubtitle.textContent = 'Editing ' + (item.announcement_id || '') + '.';
    setFormStatus('', false);

    if(els.bodyPreview){
      var normalized = qaNormalizeNewlinesToParagraphs(els.fBody.value || '');
      var safe = qaSanitizeToHtml(normalized);
      els.bodyPreview.innerHTML = safe || '<span style="color:var(--muted);">Preview will appear here…</span>';
    }
  }

  function collectPayload(){
    var id      = (els.fId.value || '').trim();
    var title   = (els.fTitle.value || '').trim();
    var bodyRaw = (els.fBody.value  || '').trim();
    var status  = els.fStatus.value || 'draft';
    var priority = els.fPriority.value;
    var startAt  = els.fStartAt.value;
    var endAt    = els.fEndAt.value;

    var normalized = qaNormalizeNewlinesToParagraphs(bodyRaw);

    var safeHtml = qaSanitizeToHtml(normalized);
    var safeText = qaExtractTextFromHtml(safeHtml);

    var payload = {
      title: title,
      body_html: safeHtml,
      body_text: safeText,
      status: status,
      start_at: startAt || '',
      end_at: endAt || '',
      pinned: !!els.fPinned.checked,
      dismissible: !!els.fDismiss.checked,
      priority: (priority === '' || priority == null) ? '1' : String(priority),
      scope_programs:          (scopeSelected.programs || []).join(','),
      scope_courses:           (scopeSelected.courses || []).join(','),
      scope_level:             (scopeSelected.levels || []).join(','),
      scope_cohort:            (scopeSelected.cohorts || []).join(','),
      scope_subscription_kind: (scopeSelected.subscriptionKinds || []).join(','),
      scope_product_ids:       (scopeSelected.productIds || []).join(','),
      scope_audience:          (scopeSelected.audience || []).join(','),
      scope_user_ids:          (scopeSelected.userIds || []).join(',')
    };

    if(id) payload.announcement_id = id;
    return payload;
  }

  function saveAnnouncement(){
    setFormStatus('', false);
    var title = (els.fTitle.value || '').trim();
    if(!title){
      setFormStatus('Title is required.', true);
      els.fTitle.focus();
      return;
    }

    els.btnSave.disabled = true;
    setFormStatus('Saving…', false);

    var payload = collectPayload();
    apiPost('announcements.save', payload)
      .then(function(res){
        if(!res || !res.ok) throw new Error((res && res.error) ? res.error : 'Unknown error');

        var id = res.announcement_id;
        els.fId.value = id;
        currentAnnouncement = currentAnnouncement || {};
        currentAnnouncement.announcement_id = id;

        els.formTitle.textContent = 'Edit announcement';
        els.formSubtitle.textContent = 'Saved as ' + id + '.';

        setFormStatus(res.created ? 'Announcement created.' : 'Announcement updated.', false);

        loadAnnouncements();
      })
      .catch(function(err){
        console.error(err);
        setFormStatus('Save failed: ' + err.message, true);
      })
      .finally(function(){
        els.btnSave.disabled = false;
      });
  }

  function enterFormMode(itemOrNull){
    if(itemOrNull){
      currentAnnouncement = itemOrNull;
      fillFormFromAnnouncement(itemOrNull);
    }else{
      resetForm(true);
    }
    setViewMode('form');
  }

  function enterListMode(){ setViewMode('list'); }

  /* ==========================
     ✅ EVENTS + EDITOR TOOLS
     ========================== */

  function attachEvents(){
    els.btnRefresh.addEventListener('click', function(){ loadAnnouncements(); });
    els.btnClear.addEventListener('click', function(){ clearFilters(); loadAnnouncements(); });
    els.search.addEventListener('keydown', function(ev){
      if(ev.key === 'Enter'){ ev.preventDefault(); loadAnnouncements(); }
    });

    els.btnNew.addEventListener('click', function(){ enterFormMode(null); });
    els.btnBackToList.addEventListener('click', function(){ enterListMode(); });

    els.btnReset.addEventListener('click', function(){ resetForm(true); });
    els.btnSave.addEventListener('click', function(){ saveAnnouncement(); });

    if(els.btnUserSearch){
      els.btnUserSearch.addEventListener('click', function(){ performUserSearch(); });
    }
    if(els.uSearch){
      els.uSearch.addEventListener('keydown', function(ev){
        if(ev.key === 'Enter'){ ev.preventDefault(); performUserSearch(); }
      });
    }

    function refreshPreview(){
      if(!els.fBody || !els.bodyPreview) return;
      var raw = els.fBody.value || '';
      var normalized = qaNormalizeNewlinesToParagraphs(raw);
      var safe = qaSanitizeToHtml(normalized);
      els.bodyPreview.innerHTML = safe || '<span style="color:var(--muted);">Preview will appear here…</span>';
    }

    if(els.fBody){
      els.fBody.addEventListener('input', refreshPreview);
    }

    Array.from(document.querySelectorAll('.qa-ebtn[data-cmd]')).forEach(function(btn){
      btn.addEventListener('click', function(){
        if(!els.fBody) return;
        var cmd = btn.getAttribute('data-cmd');
        if(cmd === 'strong') wrapSelection(els.fBody, '<strong>', '</strong>');
        else if(cmd === 'em') wrapSelection(els.fBody, '<em>', '</em>');
        else if(cmd === 'code') wrapSelection(els.fBody, '<code>', '</code>');
        else if(cmd === 'ul') selectionToList(els.fBody, 'ul');
        else if(cmd === 'ol') selectionToList(els.fBody, 'ol');
        refreshPreview();
      });
    });

    var btnInsLink = document.getElementById('btnInsLink');
    if(btnInsLink){
      btnInsLink.addEventListener('click', function(){
        if(!els.fBody) return;
        var url = prompt('Link URL (https://, mailto:, tel:, or /relative):', 'https://');
        if(url == null) return;
        url = url.trim();
        if(!qaIsSafeHref(url)){ alert('That link is not allowed (unsafe protocol).'); return; }

        var text = prompt('Link text (leave blank to use selected text):', '');
        var val = els.fBody.value || '';
        var s = els.fBody.selectionStart || 0;
        var e = els.fBody.selectionEnd || 0;
        var sel = val.slice(s,e);
        var label = (text && text.trim()) ? text.trim() : (sel || url);
        var linkHtml = '<a href="'+ url +'">'+ escapeHtml(label) +'</a>';
        els.fBody.value = val.slice(0,s) + linkHtml + val.slice(e);
        els.fBody.focus();
        refreshPreview();
      });
    }

    var btnInsBtn = document.getElementById('btnInsBtn');
    if(btnInsBtn){
      btnInsBtn.addEventListener('click', function(){
        if(!els.fBody) return;
        var url = prompt('Button link URL:', 'https://');
        if(url == null) return;
        url = url.trim();
        if(!qaIsSafeHref(url)){ alert('That link is not allowed (unsafe protocol).'); return; }

        var text = prompt('Button text:', 'Open');
        if(text == null) return;
        text = (text || 'Open').trim();
        var html = '<a href="'+ url +'" data-qa="btn">'+ escapeHtml(text) +'</a>';

        els.fBody.value = (els.fBody.value || '') + (els.fBody.value ? '\n' : '') + html;
        refreshPreview();
      });
    }

    var btnInsImg = document.getElementById('btnInsImg');
    if(btnInsImg){
      btnInsImg.addEventListener('click', function(){
        if(!els.fBody) return;
        var src = prompt('Image URL (https://...)', 'https://');
        if(src == null) return;
        src = src.trim();
        if(!qaIsSafeSrc(src)){ alert('That image URL is not allowed.'); return; }

        var alt = prompt('Alt text (short description):', 'Announcement image');
        if(alt == null) return;
        alt = alt.trim() || 'Announcement image';

        var wrap = confirm('Make image clickable (wrap in link)?');
        var html = '<img src="'+ src +'" alt="'+ escapeHtml(alt) +'">';
        if(wrap){
          var href = prompt('Link URL for the image:', 'https://');
          if(href && qaIsSafeHref(href.trim())){
            html = '<a href="'+ href.trim() +'">' + html + '</a>';
          }
        }

        els.fBody.value = (els.fBody.value || '') + (els.fBody.value ? '\n' : '') + html;
        refreshPreview();
      });
    }

    // ✅ NEW: Insert fixed quiz tool
    var btnInsFixedQuiz = document.getElementById('btnInsFixedQuiz');
    if(btnInsFixedQuiz){
      btnInsFixedQuiz.addEventListener('click', function(){
        if(!els.fBody) return;

        var pre = prompt('Pre-text (optional, e.g. “New Mock Exam is live!”):', 'New Mock Exam is live!');
        if(pre === null) return;

        var quizId = prompt('Fixed Quiz ID (e.g. GP-T1 or GP-I1):', '');
        if(quizId == null) return;
        quizId = (quizId || '').trim();

        if(!/^[A-Za-z0-9_-]+$/.test(quizId)){
          alert('Invalid quiz ID. Use only letters, numbers, underscore, dash.');
          return;
        }

        var mode = prompt('Mode (instant or timed):', 'timed');
        if(mode == null) return;
        mode = String(mode || '').trim().toLowerCase();
        if(mode !== 'instant' && mode !== 'timed'){
          alert('Mode must be “instant” or “timed”.');
          return;
        }

        var defaultBtnText = (mode === 'timed') ? 'Start Mock Exam (Timed)' : 'Start Mock Exam (Instant)';
        var btnText = prompt('Button text:', defaultBtnText);
        if(btnText == null) return;
        btnText = (btnText || defaultBtnText).trim();

        var html = '';
        if(String(pre || '').trim()){
          html += '<p><strong>' + escapeHtml(String(pre).trim()) + '</strong></p>\n';
        }
        html += '<a href="#" data-qa-fixed-quiz="' + quizId.toUpperCase() + '" data-qa-mode="' + mode + '" data-qa="btn">'
             + escapeHtml(btnText)
             + '</a>';

        els.fBody.value = (els.fBody.value || '') + (els.fBody.value ? '\n\n' : '') + html;
        refreshPreview();
      });
    }

    refreshPreview();
  }

  // ========= INIT =========
  function init(){
    if(!ensureTokenOrRedirect()) return;
    initRefs();
    attachEvents();
    resetForm(false);
    setViewMode('list');

    loadMeta().then(function(){
      loadAnnouncements();
    });
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', init);
  }else{
    init();
  }

})();
</script>

</body>
</html>
