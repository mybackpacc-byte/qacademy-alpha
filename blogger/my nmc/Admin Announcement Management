<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>QAcademy — Admin: Announcements Manager</title>
<style>
  :root{
    --brand:#0b7a75;
    --brand-soft:#e0f2f1;
    --ink:#0f172a;
    --muted:#6b7280;
    --bg:#f9fafb;
    --card:#ffffff;
    --line:#e5e7eb;
    --danger:#b91c1c;
    --danger-soft:#fef2f2;
    --ok:#15803d;
    --ok-soft:#ecfdf3;
  }
  *{box-sizing:border-box}
  body{
    margin:0;
    padding:0 12px 24px;
    font-family:system-ui,-apple-system,Segoe UI,Roboto,sans-serif;
    background:var(--bg);
    color:var(--ink);
  }
  .qa-shell{
    max-width:980px;
    margin:22px auto;
  }
  .qa-header{
    margin-bottom:14px;
  }
  .qa-kicker{
    font-size:12px;
    text-transform:uppercase;
    letter-spacing:.08em;
    color:var(--muted);
    margin-bottom:2px;
  }
  .qa-title{
    font-size:20px;
    font-weight:600;
    display:flex;
    align-items:center;
    gap:8px;
  }
  .qa-chip{
    display:inline-flex;
    align-items:center;
    padding:2px 8px;
    border-radius:999px;
    font-size:11px;
    background:var(--brand-soft);
    color:var(--brand);
    font-weight:500;
  }
  .qa-sub{
    font-size:13px;
    color:var(--muted);
    margin-top:4px;
  }

  .qa-card{
    background:var(--card);
    border-radius:14px;
    border:1px solid var(--line);
    box-shadow:0 8px 18px rgba(15,23,42,0.06);
    padding:12px 14px 10px;
    margin-bottom:14px;
  }

  /* Filters card */
  .qa-filters-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:8px;
  }
  .qa-filters-title{
    font-size:13px;
    font-weight:500;
  }
  .qa-filters-sub{
    font-size:11px;
    color:var(--muted);
  }

  .qa-filters-grid{
    display:grid;
    grid-template-columns:repeat(4,minmax(0,1fr));
    gap:10px;
  }
  @media(max-width:800px){
    .qa-filters-grid{ grid-template-columns:repeat(2,minmax(0,1fr)); }
  }
  @media(max-width:520px){
    .qa-filters-grid{ grid-template-columns:1fr; }
  }
  .qa-field{
    display:flex;
    flex-direction:column;
    gap:3px;
    font-size:12px;
  }
  .qa-label{
    font-weight:500;
    color:var(--muted);
  }
  .qa-input,
  .qa-select{
    border-radius:9px;
    border:1px solid var(--line);
    padding:6px 9px;
    font-size:13px;
    font-family:inherit;
    background:#ffffff;
  }
  .qa-input:focus,
  .qa-select:focus,
  textarea.qa-input:focus{
    outline:none;
    border-color:var(--brand);
    box-shadow:0 0 0 1px rgba(11,122,117,0.15);
  }

  .qa-actions{
    display:flex;
    flex-wrap:wrap;
    gap:8px;
    margin-top:8px;
    justify-content:flex-end;
  }
  .qa-btn{
    border-radius:999px;
    border:none;
    padding:6px 12px;
    font-size:13px;
    font-weight:500;
    cursor:pointer;
    display:inline-flex;
    align-items:center;
    gap:6px;
  }
  .qa-btn-primary{ background:var(--brand); color:#ffffff; }
  .qa-btn-ghost{
    background:transparent;
    color:var(--muted);
    border:1px solid var(--line);
  }
  .qa-btn-subtle{
    background:transparent;
    color:var(--brand);
    border:1px dashed var(--brand-soft);
    font-size:12px;
    padding:4px 10px;
  }
  .qa-btn[disabled]{ opacity:.5; cursor:default; }

  .qa-meta-row{
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:10px;
    font-size:12px;
    color:var(--muted);
    margin:4px 0 6px;
  }

  .qa-status-text{ font-size:11px; color:var(--muted); }
  .qa-status-text.err{ color:var(--danger); }

  /* List card */
  .qa-table-wrap{ overflow-x:auto; }
  table.qa-table{
    width:100%;
    border-collapse:collapse;
    font-size:13px;
  }
  table.qa-table thead{ background:#f3f4f6; }
  table.qa-table th,
  table.qa-table td{
    padding:6px 8px;
    border-bottom:1px solid #e5e7eb;
    vertical-align:top;
  }
  table.qa-table th{
    text-align:left;
    font-weight:600;
    font-size:12px;
    color:var(--muted);
  }
  table.qa-table tbody tr{ cursor:pointer; }
  table.qa-table tbody tr:hover{ background:#f9fafb; }

  .qa-pill{
    display:inline-flex;
    align-items:center;
    padding:2px 7px;
    border-radius:999px;
    font-size:11px;
    font-weight:500;
  }
  .qa-pill-status-active{ background:#dcfce7; color:#166534; }
  .qa-pill-status-scheduled{ background:#fef9c3; color:#854d0e; }
  .qa-pill-status-expired{ background:#fee2e2; color:#b91c1c; }
  .qa-pill-status-draft{ background:#e5e7eb; color:#4b5563; }
  .qa-pill-status-archived{ background:#e5e7eb; color:#6b7280; }
  .qa-pill-pinned{ background:#e0f2fe; color:#1d4ed8; }

  .qa-scope-badge{
    display:inline-flex;
    border-radius:999px;
    border:1px solid #e5e7eb;
    padding:1px 6px;
    font-size:11px;
    margin:1px 2px 1px 0;
    white-space:nowrap;
  }

  .qa-body-toggle{
    border:none;
    background:none;
    color:var(--brand);
    cursor:pointer;
    font-size:11px;
    padding:0;
  }
  .qa-body-text{
    margin-top:4px;
    font-size:12px;
    color:#111827;
    max-height:120px;
    overflow-y:auto;
    border-radius:6px;
    background:#f9fafb;
    padding:4px 6px;
    white-space:pre-wrap;
  }

  .qa-badge-small{ font-size:10px; color:var(--muted); }
  .qa-empty{ padding:10px 4px; font-size:13px; color:var(--muted); }
  .qa-badge-danger{ color:var(--danger); }

  /* Form page */
  .qa-form-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:8px;
    margin-bottom:6px;
  }
  .qa-form-title{ font-size:14px; font-weight:600; }
  .qa-form-sub{ font-size:12px; color:var(--muted); }

  .qa-status-inline{ font-size:11px; margin-top:4px; }
  .qa-status-inline.ok{ color:var(--ok); }
  .qa-status-inline.err{ color:var(--danger); }

  .qa-form-section-title{
    font-size:11px;
    text-transform:uppercase;
    letter-spacing:.08em;
    color:var(--muted);
    margin:8px 0 4px;
  }

  .qa-row{
    display:flex;
    flex-wrap:wrap;
    gap:8px;
    margin-bottom:6px;
  }
  .qa-row .qa-field{
    flex:1 1 120px;
    min-width:0;
  }
  textarea.qa-input{ min-height:110px; resize:vertical; }

  .qa-chip-row{
    display:flex;
    flex-wrap:wrap;
    gap:6px;
    margin-top:4px;
  }
  .qa-chip-toggle{
    border-radius:999px;
    border:1px solid var(--line);
    padding:3px 9px;
    font-size:11px;
    background:#ffffff;
    color:#374151;
    cursor:pointer;
    display:inline-flex;
    align-items:center;
    gap:4px;
  }
  .qa-chip-toggle span{ pointer-events:none; }
  .qa-chip-toggle.qa-chip-active{
    background:var(--brand-soft);
    border-color:var(--brand);
    color:var(--brand);
    font-weight:500;
  }

  .qa-chip-hint{
    font-size:11px;
    color:var(--muted);
    margin-top:2px;
  }

  .qa-footer-links{
    margin-top:10px;
    font-size:11px;
    color:var(--muted);
    display:flex;
    flex-wrap:wrap;
    gap:10px;
  }
  .qa-footer-links a{
    color:var(--brand);
    text-decoration:none;
  }
  .qa-footer-links a:hover{ text-decoration:underline; }

  /* Two-page behaviour */
  .qa-view{ display:none; }
  .qa-view.active{ display:block; }

  .qa-step-indicator{
    font-size:11px;
    color:var(--muted);
    margin-bottom:4px;
  }
  .qa-step-indicator strong{ color:var(--brand); }

  /* User-level scope block */
  .qa-user-scope-block{
    margin-top:8px;
    padding-top:8px;
    border-top:1px dashed var(--line);
  }
  .qa-user-search-row{
    display:flex;
    flex-wrap:wrap;
    gap:6px;
    align-items:center;
    margin-top:4px;
  }
  .qa-user-search-input{
    flex:1 1 160px;
    min-width:0;
  }
  .qa-user-results{ margin-top:4px; font-size:12px; }
  .qa-user-result-item{
    padding:4px 6px;
    border-radius:8px;
    border:1px solid var(--line);
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:6px;
    margin-top:3px;
    background:#f9fafb;
  }
  .qa-user-result-main{
    display:flex;
    flex-direction:column;
    gap:2px;
  }
  .qa-user-result-name{ font-weight:500; }
  .qa-user-result-meta{ font-size:11px; color:var(--muted); }
  .qa-user-selected-chips{
    margin-top:4px;
    display:flex;
    flex-wrap:wrap;
    gap:4px;
  }
  .qa-user-chip{
    display:inline-flex;
    align-items:center;
    gap:4px;
    padding:3px 8px;
    border-radius:999px;
    font-size:11px;
    background:var(--brand-soft);
    color:var(--brand);
  }
  .qa-user-chip button{
    border:none;
    background:none;
    padding:0;
    cursor:pointer;
    font-size:11px;
    color:inherit;
  }
  .qa-user-hint{
    font-size:11px;
    color:var(--muted);
    margin-top:2px;
  }

  /* ✅ SAFE EDITOR */
  .qa-editor-bar{
    display:flex;
    flex-wrap:wrap;
    gap:6px;
    margin-top:6px;
  }
  .qa-ebtn{
    border:1px solid var(--line);
    background:#fff;
    color:var(--ink);
    border-radius:10px;
    padding:6px 10px;
    font-size:12px;
    font-weight:650;
    cursor:pointer;
  }
  .qa-ebtn:hover{ border-color:rgba(11,122,117,.35); }
  .qa-ebtn-sep{ width:1px; background:var(--line); margin:0 2px; }

  .qa-body-preview{
    margin-top:6px;
    border:1px solid var(--line);
    border-radius:12px;
    padding:10px 12px;
    background:#ffffff;
    font-size:13px;
    color:#111827;
  }
  .qa-body-preview a{ color:var(--brand); text-decoration:underline; }
  .qa-body-preview img{
    max-width:100%;
    height:auto;
    border-radius:10px;
    display:block;
    margin-top:8px;
  }
  .qa-body-preview a[data-qa="btn"]{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding:8px 12px;
    border-radius:999px;
    background:var(--brand);
    color:#fff;
    text-decoration:none;
    font-weight:700;
    margin-top:6px;
  }
  .qa-body-preview p{ margin:0 0 10px 0; }
  .qa-body-preview p:last-child{ margin-bottom:0; }
</style>
</head>

<body>
<div class="qa-shell">
  <header class="qa-header">
    <div class="qa-kicker">QAcademy · Admin</div>
    <div class="qa-title">
      Announcements
      <span class="qa-chip">Manager</span>
    </div>
    <p class="qa-sub">
      Page 1: browse and filter announcements. Page 2: create or edit a specific announcement.
    </p>
  </header>

  <!-- VIEW A: LIST PAGE -->
  <div id="qa-view-list" class="qa-view active">
    <div class="qa-step-indicator">
      <strong>Step 1:</strong> Browse &amp; filter · Step 2: Edit / create
    </div>

    <section class="qa-card">
      <div class="qa-filters-header">
        <div>
          <div class="qa-filters-title">Filters</div>
          <div class="qa-filters-sub">Refine the table below by status, program, course or audience.</div>
        </div>
        <div id="qa-meta-status" class="qa-status-text">Loading filter options…</div>
      </div>

      <div class="qa-filters-grid">
        <div class="qa-field">
          <label class="qa-label" for="f-status">Status</label>
          <select id="f-status" class="qa-select">
            <option value="">All</option>
          </select>
        </div>

        <div class="qa-field">
          <label class="qa-label" for="f-program">Program</label>
          <select id="f-program" class="qa-select">
            <option value="">All</option>
          </select>
        </div>

        <div class="qa-field">
          <label class="qa-label" for="f-course">Course</label>
          <select id="f-course" class="qa-select">
            <option value="">All</option>
          </select>
        </div>

        <div class="qa-field">
          <label class="qa-label" for="f-cohort">Cohort</label>
          <select id="f-cohort" class="qa-select">
            <option value="">All</option>
          </select>
        </div>

        <div class="qa-field">
          <label class="qa-label" for="f-subkind">Sub. kind</label>
          <select id="f-subkind" class="qa-select">
            <option value="">All</option>
          </select>
        </div>

        <div class="qa-field">
          <label class="qa-label" for="f-product">Product</label>
          <select id="f-product" class="qa-select">
            <option value="">All</option>
          </select>
        </div>

        <div class="qa-field">
          <label class="qa-label" for="f-audience">Audience</label>
          <select id="f-audience" class="qa-select">
            <option value="">All</option>
          </select>
        </div>

        <div class="qa-field">
          <label class="qa-label" for="f-search">Search</label>
          <input id="f-search" class="qa-input" type="text" placeholder="Title / body / scope…" />
        </div>
      </div>

      <div class="qa-actions">
        <button type="button" class="qa-btn qa-btn-ghost" id="btn-clear">Clear filters</button>
        <button type="button" class="qa-btn qa-btn-subtle" id="btn-new-announcement">New announcement</button>
        <button type="button" class="qa-btn qa-btn-primary" id="btn-refresh">Refresh list</button>
      </div>
    </section>

    <section class="qa-card">
      <div class="qa-meta-row">
        <div id="qa-results-label">Announcements</div>
        <div id="qa-results-meta"></div>
      </div>
      <div class="qa-table-wrap" id="qa-table-wrap">
        <div class="qa-empty">No data yet.</div>
      </div>
    </section>
  </div>

  <!-- VIEW B: FORM PAGE -->
  <div id="qa-view-form" class="qa-view">
    <div class="qa-step-indicator">
      Step 1: Browse &amp; filter · <strong>Step 2: Edit / create</strong>
    </div>

    <section class="qa-card">
      <div class="qa-form-header">
        <div>
          <div class="qa-form-title" id="formTitle">New announcement</div>
          <div class="qa-form-sub" id="formSubtitle">
            Fill in the fields and click “Save announcement”.
          </div>
        </div>
        <button type="button" class="qa-btn qa-btn-ghost" id="btnBackToList" style="font-size:11px;">← Back to list</button>
      </div>

      <form id="annForm" onsubmit="return false;">
        <input type="hidden" id="fId" />

        <div class="qa-field">
          <label class="qa-label" for="fTitle">Title</label>
          <input id="fTitle" class="qa-input" type="text" placeholder="e.g. Licensure mock schedule for RN 2026" />
        </div>

        <div class="qa-field" style="margin-top:6px;">
          <label class="qa-label" for="fBody">Body (safe HTML)</label>

          <div class="qa-editor-bar" role="toolbar" aria-label="Announcement editor toolbar">
            <button type="button" class="qa-ebtn" data-cmd="strong"><b>B</b></button>
            <button type="button" class="qa-ebtn" data-cmd="em"><i>I</i></button>
            <button type="button" class="qa-ebtn" data-cmd="ul">• List</button>
            <button type="button" class="qa-ebtn" data-cmd="ol">1. List</button>
            <button type="button" class="qa-ebtn" data-cmd="code">Code</button>
            <span class="qa-ebtn-sep"></span>
            <button type="button" class="qa-ebtn" id="btnInsLink">Insert link</button>
            <button type="button" class="qa-ebtn" id="btnInsBtn">Insert button</button>
            <button type="button" class="qa-ebtn" id="btnInsImg">Insert image</button>

            <!-- ✅ NEW TOOL -->
            <span class="qa-ebtn-sep"></span>
            <button type="button" class="qa-ebtn" id="btnInsFixedQuiz">Insert fixed quiz</button>
          </div>

          <textarea id="fBody" class="qa-input" placeholder="Use toolbar for bold/italic/lists/links/images."></textarea>

          <div class="qa-chip-hint">
            Stored as <code>body_html</code>. Unsupported formatting will be stripped in the preview (same rules as students see).
            <br/>✅ Single Enter becomes a new paragraph. Use <code>&lt;br&gt;</code> for a line break inside a paragraph.
          </div>

          <div class="qa-editor-preview-wrap">
            <div class="qa-form-section-title" style="margin-top:10px;">Preview (sanitized)</div>
            <div id="qaBodyPreview" class="qa-body-preview"></div>
          </div>
        </div>

        <div class="qa-row" style="margin-top:8px;">
          <div class="qa-field">
            <label class="qa-label" for="fStatus">Status</label>
            <select id="fStatus" class="qa-select">
              <option value="draft">Draft</option>
              <option value="active">Active</option>
              <option value="archived">Archived</option>
            </select>
          </div>
          <div class="qa-field">
            <label class="qa-label" for="fPriority">Priority</label>
            <select id="fPriority" class="qa-select">
              <option value="1">1 – normal</option>
              <option value="0">0 – low</option>
              <option value="2">2 – high</option>
              <option value="3">3 – urgent</option>
            </select>
          </div>
        </div>

        <div class="qa-row">
          <div class="qa-field">
            <label class="qa-label" for="fStartAt">Start at</label>
            <input id="fStartAt" class="qa-input" type="datetime-local" />
          </div>
          <div class="qa-field">
            <label class="qa-label" for="fEndAt">End at</label>
            <input id="fEndAt" class="qa-input" type="datetime-local" />
          </div>
        </div>

        <div class="qa-row" style="margin-top:4px;">
          <div class="qa-field" style="flex:1 1 100%;">
            <label class="qa-label">Flags</label>
            <div class="qa-row" style="margin-bottom:0;">
              <label style="font-size:11px;display:flex;align-items:center;gap:4px;">
                <input type="checkbox" id="fPinned" /> Pinned
              </label>
              <label style="font-size:11px;display:flex;align-items:center;gap:4px;">
                <input type="checkbox" id="fDismissible" /> Dismissible
              </label>
            </div>
          </div>
        </div>

        <div class="qa-form-section-title">Scope / Targeting</div>

        <div class="qa-field">
          <div class="qa-label">Programs</div>
          <div id="scope-programs-chips" class="qa-chip-row"></div>
        </div>

        <div class="qa-field" style="margin-top:4px;">
          <div class="qa-label">Courses</div>
          <div id="scope-courses-chips" class="qa-chip-row"></div>
        </div>

        <div class="qa-row" style="margin-top:4px;">
          <div class="qa-field">
            <div class="qa-label">Levels</div>
            <div id="scope-levels-chips" class="qa-chip-row"></div>
          </div>
          <div class="qa-field">
            <div class="qa-label">Cohorts</div>
            <div id="scope-cohorts-chips" class="qa-chip-row"></div>
          </div>
        </div>

        <div class="qa-row" style="margin-top:4px;">
          <div class="qa-field">
            <div class="qa-label">Subscription kinds</div>
            <div id="scope-subkinds-chips" class="qa-chip-row"></div>
          </div>
          <div class="qa-field">
            <div class="qa-label">Products</div>
            <div id="scope-products-chips" class="qa-chip-row"></div>
          </div>
        </div>

        <div class="qa-field" style="margin-top:4px;">
          <div class="qa-label">Audience</div>
          <div id="scope-audience-chips" class="qa-chip-row"></div>
          <div class="qa-chip-hint">
            Leave all scope fields empty for a truly global announcement.
          </div>
        </div>

        <div class="qa-field qa-user-scope-block">
          <div class="qa-label">Target specific users (optional)</div>
          <div class="qa-user-search-row">
            <input id="u-search" class="qa-input qa-user-search-input" type="text"
              placeholder="Search by name, email or user ID…" />
            <button type="button" class="qa-btn qa-btn-subtle" id="btnUserSearch">Search users</button>
          </div>
          <div id="u-results" class="qa-user-results"></div>
          <div id="u-selected" class="qa-user-selected-chips"></div>
          <div class="qa-user-hint">
            If you select one or more users here, this announcement will only appear for those user IDs,
            combined with any other scopes above.
          </div>
        </div>

        <div class="qa-row" style="margin-top:10px;justify-content:space-between;align-items:center;">
          <div>
            <button type="button" class="qa-btn qa-btn-primary" id="btnSave">Save announcement</button>
            <button type="button" class="qa-btn qa-btn-ghost" id="btnReset" style="font-size:12px;">Reset form</button>
          </div>
          <div id="formStatus" class="qa-status-inline"></div>
        </div>
      </form>
    </section>
  </div>

  <div class="qa-footer-links">
    <span class="qa-status-text">Shortcuts:</span>
    <a href="/p/dashboard_23.html">Dashboard</a>
    <a href="/p/courses-hub.html">Courses hub</a>
  </div>
</div>

<script>
(function(){
  'use strict';

  // ========= CONFIG =========
  var TOKEN_KEY = 'qa_token';

