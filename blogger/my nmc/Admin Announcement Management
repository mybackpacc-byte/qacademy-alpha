  // ========= HELPERS =========
  function go(path){ location.href = path; }

  function getToken(){
    try{ return localStorage.getItem(TOKEN_KEY) || ''; }catch(e){ return ''; }
  }

  function ensureTokenOrRedirect(){
    var t = getToken();
    if(!t){ go('/p/' + LOGIN_SLUG + '.html'); return false; }
    return true;
  }

  function apiGet(params){
    var token = getToken();
    if(!token){ go('/p/' + LOGIN_SLUG + '.html'); return Promise.reject(new Error('Missing token')); }
    params = params || {};
    params.token = token;

    var usp = new URLSearchParams();
    Object.keys(params).forEach(function(k){
      var v = params[k];
      if(v !== undefined && v !== null && v !== '') usp.set(k, v);
    });

    var url = BUILDER_API_URL + '?' + usp.toString();
    return fetch(url, { method:'GET', headers:{ 'Accept':'application/json' } })
      .then(function(res){ if(!res.ok) throw new Error('HTTP ' + res.status); return res.json(); });
  }

  function apiPost(action, payload){
    var token = getToken();
    if(!token){ go('/p/' + LOGIN_SLUG + '.html'); return Promise.reject(new Error('Missing token')); }
    var body = new URLSearchParams();
    body.set('action', action);
    body.set('token', token);
    body.set('payload', JSON.stringify(payload || {}));

    return fetch(BUILDER_API_URL, {
      method:'POST',
      headers:{ 'Content-Type':'application/x-www-form-urlencoded' },
      body: body.toString()
    }).then(function(res){
      if(!res.ok) throw new Error('HTTP ' + res.status);
      return res.json();
    });
  }

  function shortId(id){
    if(!id) return '';
    if(id.length <= 10) return id;
    return id.slice(0,6) + '…' + id.slice(-4);
  }

  function formatDateISO(iso){
    if(!iso) return '';
    try{
      var d = new Date(iso);
      if(isNaN(d.getTime())) return iso;
      return d.toLocaleString();
    }catch(e){
      return iso;
    }
  }

  function pillForStatus(eff){
    var cls = 'qa-pill ';
    var label = eff || 'unknown';
    var key = (eff || '').toLowerCase();
    if(key === 'active')         cls += 'qa-pill-status-active';
    else if(key === 'scheduled') cls += 'qa-pill-status-scheduled';
    else if(key === 'expired')   cls += 'qa-pill-status-expired';
    else if(key === 'draft')     cls += 'qa-pill-status-draft';
    else if(key === 'archived')  cls += 'qa-pill-status-archived';
    else                         cls += 'qa-pill-status-draft';
    return '<span class="'+cls+'">'+ label +'</span>';
  }

  function scopeBadges(label, csv){
    var raw = (csv || '').trim();
    if(!raw) return '';
    var tokens = raw.split(',').map(function(s){ return s.trim(); }).filter(Boolean);
    if(!tokens.length) return '';
    return tokens.map(function(t){
      return '<span class="qa-scope-badge">'+ (label ? label+': ' : '') + t +'</span>';
    }).join('');
  }

  function populateSelect(selectEl, items, opts){
    opts = opts || {};
    var keepFirst = !!opts.keepFirst;
    var valueKey  = opts.valueKey || 'id';
    var labelKey  = opts.labelKey || 'label';

    var current = selectEl.value;
    var html = '';

    if(keepFirst){
      var first = selectEl.querySelector('option');
      html += first ? first.outerHTML : '<option value="">All</option>';
    }else{
      html += '<option value="">All</option>';
    }

    (items || []).forEach(function(item){
      var v = item[valueKey];
      var lbl = item[labelKey];
      html += '<option value="'+ String(v) +'">'+ String(lbl) +'</option>';
    });

    selectEl.innerHTML = html;

    if(current){
      var opt = Array.from(selectEl.options).find(function(o){ return o.value === current; });
      if(opt) selectEl.value = current;
    }
  }

