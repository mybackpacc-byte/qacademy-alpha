<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>QAcademy — Learning History</title>
<style>
  :root{
    --brand:#0b7a75;
    --muted:#859998;
    --ink:#1f2a28;
    --bg:#f6f8f7;
    --card:#ffffff;
    --soft:rgba(0,0,0,.06);
    --warn:#8f2727;
    --ok:#0a6c67;
  }
  *{box-sizing:border-box}
  body{
    margin:0;
    background:var(--bg);
    color:var(--ink);
    font-family:system-ui,Segoe UI,Roboto,sans-serif;
  }
  .wrap{
    max-width:980px;
    margin:24px auto;
    padding:0 14px 40px;
  }
  .card{
    background:var(--card);
    border:1px solid var(--soft);
    border-radius:16px;
    box-shadow:0 8px 22px rgba(0,0,0,.06);
    padding:14px 16px;
    margin-bottom:14px;
  }
  h1{
    margin:0 0 4px;
    font-size:22px;
    color:var(--brand);
    font-weight:800;
    letter-spacing:.15px;
  }
  .sub{
    font-size:13px;
    color:#5a6b68;
    margin:0;
  }

  /* Filters bar */
  .filters{
    display:flex;
    flex-wrap:wrap;
    gap:10px;
    margin-top:10px;
    align-items:flex-end;
  }
  .field{
    display:flex;
    flex-direction:column;
    gap:4px;
    min-width:120px;
    flex:1 1 140px;
  }
  .field label{
    font-size:11px;
    text-transform:uppercase;
    letter-spacing:.04em;
    color:#6b7b78;
  }
  select, input[type="search"]{
    padding:7px 8px;
    border-radius:10px;
    border:1px solid #d5e0dd;
    font-size:13px;
    background:#f9fcfb;
  }
  select:focus, input[type="search"]:focus{
    outline:none;
    border-color:var(--brand);
    box-shadow:0 0 0 1px rgba(11,122,117,.18);
    background:#ffffff;
  }

  .summary-strip{
    display:flex;
    flex-wrap:wrap;
    gap:8px;
    margin-top:10px;
    font-size:12px;
  }
  .pill{
    padding:4px 10px;
    border-radius:999px;
    border:1px solid #dbe4e2;
    background:#eef3f2;
    color:#25413d;
    display:inline-flex;
    align-items:center;
    gap:6px;
  }
  .pill strong{font-weight:700;}

  /* Attempts list */
  #attemptList{
    display:flex;
    flex-direction:column;
    gap:10px;
  }
  .attempt-row{
    border-radius:14px;
    border:1px solid #dde7e4;
    padding:10px 12px;
    background:#ffffff;
    display:grid;
    grid-template-columns: minmax(0,1.8fr) minmax(0,1.2fr);
    grid-template-rows:auto auto;
    column-gap:12px;
    row-gap:4px;
  }
  .attempt-main{
    display:flex;
    flex-direction:column;
    gap:2px;
  }
  .attempt-top{
    display:flex;
    gap:6px;
    align-items:center;
    flex-wrap:wrap;
    font-size:12px;
    color:#4b5a58;
  }
  .date{
    font-weight:600;
  }
  .course-label{
    font-weight:600;
    color:#1f2a28;
  }
  .attempt-title{
    font-size:13px;
    font-weight:600;
    color:#223230;
    margin-top:2px;
  }
  .chips-row{
    display:flex;
    flex-wrap:wrap;
    gap:6px;
    margin-top:4px;
  }
  .chip{
    padding:3px 7px;
    border-radius:999px;
    border:1px solid #dde7e4;
    font-size:11px;
    line-height:1.3;
    color:#374744;
    background:#f5f9f8;
  }
  .chip.mode-instant{
    border-color:#c7f0e7;
    background:#e8fdf8;
    color:var(--ok);
  }
  .chip.mode-timed{
    border-color:#fde2c5;
    background:#fff7ed;
    color:#92400e;
  }
  .chip.status-completed{
    border-color:#c7f0e7;
    background:#e8fdf8;
    color:#166534;
  }
  .chip.status-in-progress{
    border-color:#e5e7eb;
    background:#f9fafb;
    color:#374151;
  }
  .chip.source-fixed{
    border-color:#c4d4ff;
    background:#eef2ff;
    color:#1d3e8a;
  }
  .chip.source-builder{
    border-color:#dde7e4;
    background:#f3f5f5;
  }

  .attempt-side{
    display:flex;
    flex-direction:column;
    justify-content:space-between;
    align-items:flex-end;
    gap:6px;
  }
  .score-line{
    font-size:13px;
    text-align:right;
  }
  .score-main{
    font-weight:800;
    color:var(--brand);
  }
  .score-sub{
    font-size:11px;
    color:#6b7b78;
  }
  .time-line{
    font-size:11px;
    color:#6b7b78;
  }

  .actions{
    display:flex;
    flex-wrap:wrap;
    gap:6px;
  }
  .btn{
    border:none;
    border-radius:999px;
    padding:6px 10px;
    font-size:11px;
    font-weight:600;
    cursor:pointer;
    display:inline-flex;
    align-items:center;
    gap:4px;
  }
  .btn-primary{
    background:var(--brand);
    color:#fff;
  }
  .btn-ghost{
    background:#eef3f2;
    color:#25413d;
  }
  .btn-soft{
    background:#f9fafb;
    color:#374151;
    border:1px solid #e5e7eb;
  }
  .btn:disabled{
    opacity:.55;
    cursor:not-allowed;
  }

  #loadMoreBtn{
    margin-top:10px;
    display:none;
  }

  .status-box{
    font-family:ui-monospace,Consolas,monospace;
    font-size:12px;
    padding:10px 11px;
    border-radius:10px;
    background:#0a302e;
    color:#d7fff6;
    white-space:pre-wrap;
  }

  .empty{
    font-size:13px;
    color:#6b7b78;
    padding:6px 2px;
  }

  @media (max-width:720px){
    .attempt-row{
      grid-template-columns:1fr;
      grid-template-rows:auto auto;
    }
    .attempt-side{
      align-items:flex-start;
    }
    .score-line{
      text-align:left;
    }
  }
</style>
</head>
<body>
<div class="wrap">

  <!-- Header / Filters -->
  <div class="card">
    <h1>Learning history</h1>
    <p class="sub">All your quiz attempts across courses • Instant & Timed • Builder & Fixed quizzes.</p>

    <div class="filters">
      <div class="field">
        <label for="filterCourse">Course</label>
        <select id="filterCourse">
          <option value="">All courses</option>
        </select>
      </div>
      <div class="field">
        <label for="filterMode">Mode</label>
        <select id="filterMode">
          <option value="">All modes</option>
          <option value="instant">Instant</option>
          <option value="timed">Timed</option>
        </select>
      </div>
      <div class="field">
        <label for="filterStatus">Status</label>
        <select id="filterStatus">
          <option value="">All statuses</option>
          <option value="completed">Completed</option>
          <option value="in_progress">In progress</option>
        </select>
      </div>
      <div class="field">
        <label for="filterSource">Source</label>
        <select id="filterSource">
          <option value="">All sources</option>
          <option value="builder">Builder</option>
          <option value="fixed">Fixed quiz</option>
        </select>
      </div>
      <div class="field">
        <label for="filterSearch">Search</label>
        <input id="filterSearch" type="search" placeholder="Search label or course..." />
      </div>
      <div class="field">
        <label for="filterSort">Sort</label>
        <select id="filterSort">
          <option value="newest">Newest → oldest</option>
          <option value="oldest">Oldest → newest</option>
        </select>
      </div>
    </div>

    <div class="summary-strip">
      <div class="pill" id="scopePill">Scope: All courses</div>
      <div class="pill" id="sumCount">Attempts: —</div>
      <div class="pill" id="sumAvg">Avg score: —</div>
      <div class="pill" id="sumModes">Instant — / Timed —</div>
    </div>
  </div>

  <!-- Attempts list -->
  <div class="card">
    <div id="attemptList"></div>
    <button id="loadMoreBtn" class="btn btn-soft">Load more</button>
  </div>

  <!-- Status / log -->
  <div class="card">
    <div id="log" class="status-box">Checking access...</div>
  </div>

</div>

<script>
(function(){
  // ===== CONFIG (Guard v3 style) =====

  // 1) Defaults (can be overridden by window.QA_CONFIG)
  const DEFAULT_AUTH_URL       = "https://script.google.com/macros/s/AKfycbxaChsaqn6Or1G-SHqsXla1DdgYdWXzXLfs9GVs_7xrxDeYwjT0OhvWlYUsJtpMU8so/exec";
  const DEFAULT_LOGIN_SLUG     = "login_23";
  const DEFAULT_DASHBOARD_SLUG = "dashboard_23";

  // 2) Optional global config object
  const cfg = (window.QA_CONFIG && typeof window.QA_CONFIG === "object") ? window.QA_CONFIG : {};

  // 3) Final config used on this page
  const AUTH_WEB_APP_URL    = cfg.AUTH_URL        || DEFAULT_AUTH_URL;
  const LOGIN_SLUG          = cfg.LOGIN_SLUG      || DEFAULT_LOGIN_SLUG;
  const DASHBOARD_SLUG      = cfg.DASHBOARD_SLUG  || DEFAULT_DASHBOARD_SLUG;

  const TOKEN_KEY           = cfg.TOKEN_KEY       || "qa_token";
  const USER_ID_KEY         = cfg.USER_ID_KEY     || "qa_user_id";

  // Builder / Attempts API URL (from your Builder Web App)
  const BUILDER_WEB_APP_URL = "https://script.google.com/macros/s/AKfycbx_CDJU5juEDxybplqBlYjJP0tAS52-HIOWE6is19Ub7NqhaV_16MnFmstJpWcdorHT/exec";

  const PAGE_SIZE      = 20;

  const COURSE_LABELS = {
    "GP":"General Paper",
    "RN_MED":"Medicine & Medical Nursing (RN)",
    "RN_SURG":"Surgery & Surgical Nursing (RN)",
    "RM_PED_OBS_HRN":"Paediatric, Obstetric Anatomy & HRN (RM)",
    "RM_MID":"Midwifery (RM)",
    "RPHN_PPHN":"Principles of Public Health Nursing (RPHN)",
    "RPHN_DISEASE_CTRL":"Principles of Disease Management & Control (RPHN)",
    "RMHN_PSYCH_NURS":"Principles & Practice of Psychiatric Nursing (RMHN)",
    "RMHN_PSYCH_PPHARM":"Psychiatry, Psychopathology & Psychopharmacology (RMHN)",
    "NAC_BASIC_CLIN":"Basic Clinical Nursing (NAC/NAP)",
    "NAC_BASIC_PREV":"Basic Preventive Nursing (NAC/NAP)"
  };

  const INSTANT_RUNNER_URL = "/p/instant-ruuner-for-quiz-builder.html";
  const TIMED_RUNNER_URL   = "/p/timed-ruuner-for-quiz-builder.html";

  // Small helper to read querystring
  function qs(k){
    return new URLSearchParams(window.location.search).get(k) || "";
  }

  // Optional per-course scope (when opened from a course page)
  const COURSE_SCOPE_ID = (function(){
    const v = qs("course_id") || "";
    return v.trim();
  })();

  // ===== STATE =====
  let AUTH    = null;
  let USER_ID = "";
  let allAttempts   = [];
  let filtered      = [];
  let currentLimit  = PAGE_SIZE;
  let summary       = {count:0,avg_pct:0,instant_count:0,timed_count:0};

  // ===== EL =====
  const el = {
    filterCourse:  document.getElementById("filterCourse"),
    filterMode:    document.getElementById("filterMode"),
    filterStatus:  document.getElementById("filterStatus"),
    filterSource:  document.getElementById("filterSource"),
    filterSearch:  document.getElementById("filterSearch"),
    filterSort:    document.getElementById("filterSort"),
    attemptList:   document.getElementById("attemptList"),
    loadMoreBtn:   document.getElementById("loadMoreBtn"),
    sumCount:      document.getElementById("sumCount"),
    sumAvg:        document.getElementById("sumAvg"),
    sumModes:      document.getElementById("sumModes"),
    scopePill:     document.getElementById("scopePill"),
    log:           document.getElementById("log")
  };

  // ===== UTIL =====
  function log(msg){
    el.log.textContent = (typeof msg === "string")
      ? msg
      : JSON.stringify(msg, null, 2);
  }
  function norm(s){ return String(s||"").trim().toLowerCase(); }
  function go(path){ location.replace(path); }
  function formatDateTime(ts){
    if(!ts) return "Unknown date";
    const d = new Date(ts);
    if(isNaN(d.getTime())) return String(ts);
    const dateStr = d.toLocaleDateString("en-GB", {day:"2-digit",month:"short",year:"numeric"});
    const timeStr = d.toLocaleTimeString("en-GB", {hour:"2-digit",minute:"2-digit"});
    return {date:dateStr,time:timeStr};
  }
  function formatScore(att){
    const status = norm(att.status);
    const total  = Number(att.score_total || 0);
    const raw    = Number(att.score_raw   || 0);
    const pct    = Number(att.score_pct   || 0);
    if(status !== "completed" || !total){
      return { main:"—", sub:"Not completed yet" };
    }
    return {
      main: `${raw}/${total} (${pct}%)`,
      sub:  "Completed"
    };
  }
  function formatDuration(att){
    const t = Number(att.time_taken_s || 0);
    if(!t) return "";
    const mins = Math.floor(t / 60);
    const secs = t % 60;
    if(mins && secs) return `${mins} min ${secs}s`;
    if(mins) return `${mins} min`;
    return `${secs}s`;
  }
  function extractUserId(payload){
    if (!payload || typeof payload !== "object") return "";
    const rawUser = payload.user || payload.account || payload.profile || null;
    const candidates = [
      payload.user_id,
      payload.username,
      payload.email,
      payload.id,
      rawUser && rawUser.user_id,
      rawUser && rawUser.id,
      rawUser && rawUser.username,
      rawUser && rawUser.email
    ];
    for (let i = 0; i < candidates.length; i++){
      const v = candidates[i];
      if (v !== undefined && v !== null){
        const s = String(v).trim();
        if (s) return s;
      }
    }
    return "";
  }
  function getLocalUserId(){
    try{
      return localStorage.getItem(USER_ID_KEY) || "";
    }catch(_){
      return "";
    }
  }
  function courseLabelById(cid){
    return COURSE_LABELS[cid] || cid || "Unknown course";
  }

  function updateScopeUI(){
    if (!el.scopePill) return;
    if (COURSE_SCOPE_ID){
      const label = courseLabelById(COURSE_SCOPE_ID);
      el.scopePill.textContent = `Scope: ${label} only`;
    } else {
      el.scopePill.textContent = "Scope: All courses";
    }
  }

  async function verifyToken(){
    const token = localStorage.getItem(TOKEN_KEY);
    if(!token){
      go("/p/" + LOGIN_SLUG + ".html");
      return null;
    }
    try{
      const body = new URLSearchParams({ action:"verify", token });
      const res  = await fetch(AUTH_WEB_APP_URL, {
        method:"POST",
        headers:{ "Content-Type":"application/x-www-form-urlencoded" },
        body
      });
      if(!res.ok) throw new Error("Verify HTTP " + res.status);
      const payload = await res.json();

      // Must be ok and not blocked
      if(!payload || !payload.ok){
        localStorage.removeItem(TOKEN_KEY);
        go("/p/" + LOGIN_SLUG + ".html");
        return null;
      }

      if (payload.blocked){
        // Soft messaging, then redirect to dashboard (where you may show a richer message)
        log("Your access is currently blocked. Redirecting to dashboard...");
        setTimeout(()=> go("/p/" + DASHBOARD_SLUG + ".html"), 1200);
        return null;
      }

      return payload;
    }catch(err){
      console.error("History verify failed:", err);
      localStorage.removeItem(TOKEN_KEY);
      go("/p/" + LOGIN_SLUG + ".html");
      return null;
    }
  }

  // ===== LOAD DATA =====
  async function loadAttempts(){
    // 1) Prefer verified user_id from AUTH payload
    const uidAuth  = extractUserId(AUTH).trim();
    const uidLocal = getLocalUserId().trim();

    USER_ID = uidAuth || uidLocal;

    if (!USER_ID) {
      log("Could not determine your user ID. Please login again.");
      setTimeout(()=> go("/p/" + LOGIN_SLUG + ".html"), 1200);
      return;
    }

    // 2) Keep local qa_user_id in sync with verified user
    try{
      if (uidAuth && uidAuth !== uidLocal) {
        localStorage.setItem(USER_ID_KEY, uidAuth);
      }
    }catch(_){}

    // 3) Read token to send to Builder API (server will map token → user_ids)
    const token = localStorage.getItem(TOKEN_KEY) || "";
    if (!token) {
      log("Missing token. Please login again.");
      setTimeout(()=> go("/p/" + LOGIN_SLUG + ".html"), 1200);
      return;
    }

    log("Loading attempts...");

    try{
      // IMPORTANT: use token, not user_id
      const url = `${BUILDER_WEB_APP_URL}?action=attempts.list&token=${encodeURIComponent(token)}`;

      const res = await fetch(url);
      if(!res.ok) throw new Error("HTTP " + res.status);
      const data = await res.json();

      allAttempts = Array.isArray(data.attempts) ? data.attempts : [];
      summary = data.summary || summary;

      if(!allAttempts.length){
        el.attemptList.innerHTML =
          '<div class="empty">No attempts found yet. Start a quiz from your course page and they will appear here.</div>';
        el.loadMoreBtn.style.display = "none";
      }else{
        initFiltersFromData(allAttempts);
        applyFilters(true);
      }
      updateSummaryUI();
      log("Loaded " + allAttempts.length + " attempts.");
    }catch(err){
      console.error(err);
      log("Failed to load attempts: " + (err.message || String(err)));
    }
  }

  // ===== FILTER / SORT / PAGING =====
  function initFiltersFromData(list){
    // Populate course dropdown with actual courses seen
    const seen = new Set();
    list.forEach(a => {
      const cid = String(a.course_id || "").trim();
      if(cid) seen.add(cid);
    });

    // Ensure scoped course appears even if user has no attempts for it yet
    if (COURSE_SCOPE_ID && !seen.has(COURSE_SCOPE_ID)){
      seen.add(COURSE_SCOPE_ID);
    }

    const options = Array.from(seen).sort();
    options.forEach(cid => {
      const opt = document.createElement("option");
      opt.value = cid;
      opt.textContent = courseLabelById(cid);
      el.filterCourse.appendChild(opt);
    });

    // If we are in per-course scope, lock the dropdown to that course
    if (COURSE_SCOPE_ID){
      el.filterCourse.value = COURSE_SCOPE_ID;
      el.filterCourse.disabled = true;
    } else {
      el.filterCourse.disabled = false;
    }
  }

  function applyFilters(resetLimit){
    if(resetLimit) currentLimit = PAGE_SIZE;

    const fc = norm(el.filterCourse.value);
    const fm = norm(el.filterMode.value);
    const fs = norm(el.filterStatus.value);
    const fo = norm(el.filterSource.value);
    const q  = norm(el.filterSearch.value);
    const sort = el.filterSort.value || "newest";

    filtered = allAttempts.filter(att => {
      const courseId = norm(att.course_id);
      const mode     = norm(att.mode);
      const status   = norm(att.status);
      const source   = norm(att.source);
      const label    = norm(att.display_label);
      const cidRaw   = norm(att.course_id);

      if(fc && courseId !== fc) return false;
      if(fm && mode !== fm) return false;
      if(fs && status !== fs) return false;
      if(fo && source !== fo) return false;

      if(q){
        const hay = label + " " + cidRaw;
        if(hay.indexOf(q) === -1) return false;
      }
      return true;
    });

    // Sort
    filtered.sort((a,b)=>{
      const da = new Date(a.ts_iso || 0).getTime() || 0;
      const db = new Date(b.ts_iso || 0).getTime() || 0;
      if(sort === "oldest") return da - db;
      return db - da; // newest default
    });

    renderAttempts();
  }

  function renderAttempts(){
    el.attemptList.innerHTML = "";

    if(!filtered.length){
      // If this page is course-scoped and there are no attempts for that course,
      // keep the message simple but slightly more targeted.
      if (COURSE_SCOPE_ID){
        const label = courseLabelById(COURSE_SCOPE_ID);
        el.attemptList.innerHTML =
          `<div class="empty">No attempts found yet for ${label}. Start a quiz in this course and your attempts will appear here.</div>`;
      } else {
        el.attemptList.innerHTML =
          '<div class="empty">No attempts match your filters.</div>';
      }
      el.loadMoreBtn.style.display = "none";
      return;
    }

    const slice = filtered.slice(0, currentLimit);
    slice.forEach(att => {
      el.attemptList.appendChild(renderAttempt(att));
    });

    if(filtered.length > currentLimit){
      el.loadMoreBtn.style.display = "inline-flex";
    }else{
      el.loadMoreBtn.style.display = "none";
    }
  }

  function renderAttempt(att){
    const div = document.createElement("div");
    div.className = "attempt-row";

    const dt = formatDateTime(att.ts_iso || "");
    const scoreInfo = formatScore(att);
    const durationStr = formatDuration(att);

    const courseId = String(att.course_id || "");
    const courseLabel = courseLabelById(courseId);

    const mode  = norm(att.mode);
    const src   = norm(att.source);
    const stat  = norm(att.status);
    const quizId = String(att.quiz_id || "");
    
    const title = att.display_label || (quizId ? "Fixed quiz" : "Custom quiz");

    // MAIN SIDE
    const main = document.createElement("div");
    main.className = "attempt-main";

    const top = document.createElement("div");
    top.className = "attempt-top";
    top.innerHTML = `
      <span class="date">${dt.date}</span>
      <span>•</span>
      <span>${dt.time}</span>
      <span>•</span>
      <span class="course-label">${courseLabel}</span>
    `;

    const titleEl = document.createElement("div");
    titleEl.className = "attempt-title";
    titleEl.textContent = title;

    const chipsRow = document.createElement("div");
    chipsRow.className = "chips-row";

    // Mode chip
    if(mode){
      const c = document.createElement("span");
      c.className = "chip " + (mode === "timed" ? "mode-timed" : "mode-instant");
      c.textContent = (mode === "timed" ? "Timed mode" : "Instant mode");
      chipsRow.appendChild(c);
    }

    // Status chip
    if(stat){
      const c = document.createElement("span");
      c.className = "chip status-" + stat.replace(/\s+/g,"-");
      c.textContent = (stat === "in_progress" ? "In progress" : "Completed");
      chipsRow.appendChild(c);
    }

    // Source chip
    if(src){
      const c = document.createElement("span");
      if(src === "fixed"){
        c.className = "chip source-fixed";
        c.textContent = "Fixed quiz";
      }else{
        c.className = "chip source-builder";
        c.textContent = "Builder";
      }
      chipsRow.appendChild(c);
    }

    main.appendChild(top);
    main.appendChild(titleEl);
    main.appendChild(chipsRow);

    // SIDE (score + actions)
    const side = document.createElement("div");
    side.className = "attempt-side";

    const scoreLine = document.createElement("div");
    scoreLine.className = "score-line";
    scoreLine.innerHTML = `
      <div class="score-main">${scoreInfo.main}</div>
      <div class="score-sub">${scoreInfo.sub}</div>
    `;
    side.appendChild(scoreLine);

    const timeLine = document.createElement("div");
    timeLine.className = "time-line";
    timeLine.textContent = durationStr ? `Time taken: ${durationStr}` : "";
    side.appendChild(timeLine);

    const actions = document.createElement("div");
    actions.className = "actions";

    const attemptId = String(att.attempt_id || "");

    const isCompleted  = (norm(att.status) === "completed");
    const isInProgress = (norm(att.status) === "in_progress");

    // Determine runner URL
    const runnerUrl = (mode === "timed") ? TIMED_RUNNER_URL : INSTANT_RUNNER_URL;

    // Resume (in_progress only)
    const btnResume = document.createElement("button");
    btnResume.type = "button";
    btnResume.className = "btn btn-primary";
    btnResume.textContent = "Resume";
    btnResume.disabled = !isInProgress;
    btnResume.addEventListener("click", ()=>{
      if(!attemptId) return;
      // Same attempt_id, same runner
      location.href = `${runnerUrl}?attempt_id=${encodeURIComponent(attemptId)}`;
    });
    actions.appendChild(btnResume);

    // Review (completed)
    const btnReview = document.createElement("button");
    btnReview.type = "button";
    btnReview.className = "btn btn-ghost";
    btnReview.textContent = "Review";
    btnReview.disabled = !isCompleted;
    btnReview.addEventListener("click", ()=>{
      if(!attemptId) return;
      // For now this opens the same runner; a future upgrade can use &review=1 to force read-only review mode.
      location.href = `${runnerUrl}?attempt_id=${encodeURIComponent(attemptId)}&review=1`;
    });
    actions.appendChild(btnReview);

    // Retake (completed → new attempt with same questions via attempt.retake)
    const btnRetake = document.createElement("button");
    btnRetake.type = "button";
    btnRetake.className = "btn btn-soft";
    btnRetake.textContent = "Retake same set";
    btnRetake.disabled = !isCompleted;

btnRetake.addEventListener("click", async ()=>{
  if (!isCompleted || !attemptId) return;

  const originalText = btnRetake.textContent;
  btnRetake.disabled = true;
  btnRetake.textContent = "Starting retake...";

  try {
    const token = localStorage.getItem(TOKEN_KEY) || "";
    if (!token) {
      alert("Your session expired. Please log in again.");
      go("/p/" + LOGIN_SLUG + ".html");
      return;
    }

    const payload = JSON.stringify({ attempt_id: attemptId });

    const body = new URLSearchParams({
      action:  "attempt.retake",
      token:   token,     // ✅ server maps token → user_id
      payload: payload
    });

    const res = await fetch(BUILDER_WEB_APP_URL, {
      method: "POST",
      headers: { "Content-Type": "application/x-www-form-urlencoded" },
      body
    });

    if (!res.ok) throw new Error("HTTP " + res.status);
    const data = await res.json();

    if (!data || !data.ok) {
      throw new Error(data && data.error ? data.error : "Unknown error");
    }

    const newAttemptId = data.attempt_id;
    const newMode      = (data.mode || mode || "").toLowerCase();

    if (!newAttemptId) throw new Error("Missing attempt_id in response");

    const finalMode = newMode || mode;
    const targetRunnerUrl = (finalMode === "timed") ? TIMED_RUNNER_URL : INSTANT_RUNNER_URL;

    location.href = `${targetRunnerUrl}?attempt_id=${encodeURIComponent(newAttemptId)}`;
  } catch (err) {
    console.error("Retake failed:", err);
    alert("Could not start retake: " + (err.message || String(err)));
    btnRetake.disabled = false;
    btnRetake.textContent = originalText;
  }
});

    actions.appendChild(btnRetake);

    side.appendChild(actions);

    div.appendChild(main);
    div.appendChild(side);

    return div;
  }

  function updateSummaryUI(){
    el.sumCount.textContent = `Attempts: ${summary.count || allAttempts.length || 0}`;
    const avg = summary.avg_pct || 0;
    el.sumAvg.textContent = `Avg score: ${avg ? avg + "%" : "—"}`;
    el.sumModes.textContent = `Instant ${summary.instant_count || 0} | Timed ${summary.timed_count || 0}`;
  }

  // ===== EVENTS =====
  el.filterCourse.addEventListener("change", ()=> applyFilters(true));
  el.filterMode.addEventListener("change",   ()=> applyFilters(true));
  el.filterStatus.addEventListener("change", ()=> applyFilters(true));
  el.filterSource.addEventListener("change", ()=> applyFilters(true));
  el.filterSort.addEventListener("change",   ()=> applyFilters(false));
  el.filterSearch.addEventListener("input",  ()=>{
    // small debounce-ish behaviour
    clearTimeout(el._searchT);
    el._searchT = setTimeout(()=> applyFilters(true), 200);
  });

  el.loadMoreBtn.addEventListener("click", ()=>{
    currentLimit += PAGE_SIZE;
    renderAttempts();
  });

  // ===== INIT =====
  (async function init(){
    updateScopeUI();
    log("Checking access...");
    AUTH = await verifyToken();
    if(!AUTH) return;
    log("Access OK. Loading history...");
    await loadAttempts();
  })();

})();
</script>
</body>
</html>
