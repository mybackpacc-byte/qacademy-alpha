</script>

<!-- 1) GUARD v3 (same as your GP course page guard; reuse exactly the same script here) -->
<script>
(function () {
  'use strict';

  var DEFAULT_AUTH_URL       = 'https://script.google.com/macros/s/AKfycbxaChsaqn6Or1G-SHqsXla1DdgYdWXzXLfs9GVs_7xrxDeYwjT0OhvWlYUsJtpMU8so/exec';
  var DEFAULT_LOGIN_SLUG     = 'login_23';
  var DEFAULT_DASHBOARD_SLUG = 'dashboard_23';

  var cfg = (window.QA_CONFIG && typeof window.QA_CONFIG === 'object') ? window.QA_CONFIG : {};

  var AUTH_URL       = cfg.AUTH_URL       || DEFAULT_AUTH_URL;
  var LOGIN_SLUG     = cfg.LOGIN_SLUG     || DEFAULT_LOGIN_SLUG;
  var DASHBOARD_SLUG = cfg.DASHBOARD_SLUG || DEFAULT_DASHBOARD_SLUG;

  var PAGE_KIND     = window.QA_PAGE_KIND || 'announcements';
  var COURSE_ID     = window.QA_COURSE_ID || null;
  var REQUIRE_ADMIN = (typeof window.QA_REQUIRE_ADMIN === 'boolean')
    ? window.QA_REQUIRE_ADMIN
    : (String(PAGE_KIND).toLowerCase() === 'admin');

  window.QA_GUARD_STATE      = 'pending';
  window.QA_GUARD_BLOCK_TYPE = null;

  var guardResolve, guardReject;
  window.qaGuardReady = new Promise(function (resolve, reject) {
    guardResolve = resolve;
    guardReject  = reject;
  });

  function persistGuardState(state, blockType) {
    window.QA_GUARD_STATE      = state;
    window.QA_GUARD_BLOCK_TYPE = blockType || null;
  }

  function buildPageUrl(slug) {
    slug = String(slug || '').replace(/^\s+|\s+$/g, '');
    if (!slug) return '/';
    return '/p/' + slug + '.html';
  }

  function go(url) { window.location.replace(url); }

  function qaGoToLogin(reason) {
    var url = buildPageUrl(LOGIN_SLUG);
    if (reason) {
      var sep = url.indexOf('?') === -1 ? '?' : '&';
      url += sep + 'reason=' + encodeURIComponent(reason);
    }
    go(url);
  }

  function qaGoToDashboard() { go(buildPageUrl(DASHBOARD_SLUG)); }

  function qaLogout() {
    try { localStorage.removeItem('qa_token'); localStorage.removeItem('qa_user_id'); } catch (e) {}
    qaGoToLogin('logout');
  }

  window.qaGoToLogin     = qaGoToLogin;
  window.qaGoToDashboard = qaGoToDashboard;
  window.qaLogout        = qaLogout;

  var overlayId = 'qa-guard-overlay';
  function ensureOverlay() {
    var el = document.getElementById(overlayId);
    if (el) return el;

    el = document.createElement('div');
    el.id = overlayId;
    el.style.position   = 'fixed';
    el.style.inset      = '0';
    el.style.zIndex     = '99999';
    el.style.background = 'rgba(15,23,42,0.86)';
    el.style.display    = 'flex';
    el.style.alignItems = 'center';
    el.style.justifyContent = 'center';
    el.style.fontFamily = 'system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif';
    el.style.padding    = '16px';
    el.style.boxSizing  = 'border-box';

    el.innerHTML =
      '<div id="qa-guard-overlay-inner" style="max-width:420px;width:100%;background:#ffffff;border-radius:16px;padding:18px 20px;box-shadow:0 18px 45px rgba(15,23,42,0.45);text-align:center;">' +
        '<div id="qa-guard-overlay-title" style="font-size:18px;font-weight:600;margin-bottom:6px;color:#0b7a75;">Checking your access...</div>' +
        '<div id="qa-guard-overlay-body" style="font-size:14px;color:#475569;margin-bottom:14px;">Please wait a moment.</div>' +
        '<div id="qa-guard-overlay-actions" style="font-size:13px;color:#94a3b8;"></div>' +
      '</div>';

    document.body.appendChild(el);
    return el;
  }

  function showOverlay(title, body, actionsHtml) {
    var el = ensureOverlay();
    var t  = el.querySelector('#qa-guard-overlay-title');
    var b  = el.querySelector('#qa-guard-overlay-body');
    var a  = el.querySelector('#qa-guard-overlay-actions');

    if (t && typeof title === 'string') t.textContent = title;
    if (b && typeof body === 'string')  b.textContent = body;
    if (a) a.innerHTML = actionsHtml || '';

    el.style.display = 'flex';
  }

  function hideOverlay() {
    var el = document.getElementById(overlayId);
    if (el) el.style.display = 'none';
  }

  function buildBlockedActions(type) {
    var btnStyle = 'display:inline-flex;align-items:center;justify-content:center;padding:8px 14px;border-radius:999px;border:none;background:#0b7a75;color:#ffffff;font-size:14px;font-weight:600;cursor:pointer;text-decoration:none;';
    if (type === 'no_course_access' || type === 'admin_required' || type === 'account_issue') {
      return '<button type="button" onclick="qaGoToDashboard()" style="' + btnStyle + '">Go to Dashboard</button>';
    }
    if (type === 'session_expired') {
      return '<button type="button" onclick="qaGoToLogin(\'session_expired\')" style="' + btnStyle + '">Go to Login</button>';
    }
    return '';
  }

  function handleBlocked(type, title, body) {
    persistGuardState('blocked', type);
    var actionsHtml = buildBlockedActions(type);
    showOverlay(title, body, actionsHtml);
    guardResolve({ ok: false, blocked: true, type: type });
  }

  function runGuard() {
    showOverlay('Checking your access...', 'Please wait while we verify your session.', '');

    var token = null;
    try { token = localStorage.getItem('qa_token'); } catch (e) { token = null; }

    if (!token) {
      handleBlocked('session_expired', 'Sign in required', 'Your session has ended. Please sign in again.');
      qaGoToLogin('no_token');
      return;
    }

    if (!AUTH_URL) {
      hideOverlay();
      persistGuardState('error', 'missing_auth_url');
      var err = new Error('Guard misconfigured: AUTH_URL is missing.');
      guardReject(err);
      console.error(err);
      return;
    }

    fetch(AUTH_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({ action: 'verify', token: token })
    })
      .then(function (res) { return res.json(); })
      .then(function (data) {
        if (!data || data.ok !== true) {
          var errCode = (data && data.error) || 'unknown_error';

          if (errCode === 'missing_token' || errCode === 'not_found' || errCode === 'expired') {
            try { localStorage.removeItem('qa_token'); localStorage.removeItem('qa_user_id'); } catch (e) {}
            handleBlocked('session_expired', 'Sign in required', 'Your session has ended. Please sign in again.');
            qaGoToLogin('session_expired');
            return;
          }

          if (errCode === 'user_missing' || errCode === 'user_inactive' || errCode === 'user_expired') {
            handleBlocked('account_issue', 'Account issue', 'There is a problem with your account. Please contact QAcademy support.');
            return;
          }

          persistGuardState('error', errCode);
          hideOverlay();
          var err2 = new Error('Guard verify failed: ' + errCode);
          guardReject(err2);
          console.error(err2);
          return;
        }

        var u         = data.user   || {};
        var flags     = data.flags  || {};
        var access    = (data.access && typeof data.access === 'object') ? data.access : {};
        var courseIds = Array.isArray(access.courses) ? access.courses.slice() : [];
        var upperIds  = courseIds.map(function (c) { return String(c || '').trim().toUpperCase(); }).filter(Boolean);
        var coursesMeta = Array.isArray(data.courses) ? data.courses : [];

        var QA_USER = {
          id:                 u.user_id || '',
          user_id:            u.user_id || '',
          username:           u.username || '',
          email:              u.email || '',
          name:               u.name || '',
          forename:           u.forename || '',
          surname:            u.surname || '',
          phone_number:       u.phone_number || '',
          program_id:         u.program_id || '',
          cohort:             u.cohort || '',
          avatar_url:         u.avatar_url || '',
          role:               u.role || '',
          is_admin:           !!(flags && flags.is_admin),
          must_change_password: !!u.must_change_password,
          user_expires_utc:   u.expires_utc || ''
        };

        var QA_ACCESS = {
          courseIds:          upperIds,
          access_expires_utc: access.expires_utc || '',
          coursesMeta:        coursesMeta,
          hasCourse: function (courseId) {
            var cid = String(courseId || '').trim().toUpperCase();
            if (!cid) return false;
            return this.courseIds.indexOf(cid) !== -1;
          }
        };

        window.QA_USER   = QA_USER;
        window.QA_ACCESS = QA_ACCESS;

        try { if (QA_USER.user_id) localStorage.setItem('qa_user_id', QA_USER.user_id); } catch (e) {}

        var kind = String(PAGE_KIND || '').toLowerCase();
        var cid  = COURSE_ID ? String(COURSE_ID).trim().toUpperCase() : '';

        if (kind === 'dashboard') {
          persistGuardState('ready', null);
          hideOverlay();
          guardResolve({ ok: true, blocked: false, kind: kind });
          return;
        }

        if (kind === 'admin' || REQUIRE_ADMIN) {
          if (!QA_USER.is_admin) {
            handleBlocked('admin_required', 'Admin access required', 'This page is only available to QAcademy admins.');
            return;
          }
          persistGuardState('ready', null);
          hideOverlay();
          guardResolve({ ok: true, blocked: false, kind: kind });
          return;
        }

        if (kind === 'course' || kind === 'builder' || kind === 'runner_instant' || kind === 'runner_timed' || kind === 'history_course') {
          if (!cid) {
            persistGuardState('error', 'missing_course_id');
            hideOverlay();
            var err3 = new Error('Guard misconfigured: QA_COURSE_ID is missing for course-tied page.');
            guardReject(err3);
            console.error(err3);
            return;
          }

          if (!QA_ACCESS.hasCourse(cid)) {
            handleBlocked('no_course_access', 'No access to this course',
              'Your current subscription does not include this course. Please go back to your dashboard to see the courses you have access to.'
            );
            return;
          }

          persistGuardState('ready', null);
          hideOverlay();
          guardResolve({ ok: true, blocked: false, kind: kind, course_id: cid });
          return;
        }

        if (kind === 'history') {
          persistGuardState('ready', null);
          hideOverlay();
          guardResolve({ ok: true, blocked: false, kind: kind });
          return;
        }

        persistGuardState('ready', null);
        hideOverlay();
        guardResolve({ ok: true, blocked: false, kind: kind });
      })
      .catch(function (err) {
        persistGuardState('error', 'network');
        console.error('Guard network/error', err);
        showOverlay('Network problem',
          'We could not verify your access due to a network error. Please check your connection and reload this page.',
          ''
        );
        guardReject(err);
      });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', runGuard);
  else runGuard();
})();
</script>

