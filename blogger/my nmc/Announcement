<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>QAcademy — Announcements</title>
<style>
  :root{
    --brand:#0b7a75;
    --brand-soft:#e0f2f1;
    --ink:#0f172a;
    --muted:#6b7280;
    --bg:#f3f4f6;
    --card:#ffffff;
    --line:#e5e7eb;
    --danger:#b91c1c;
    --danger-soft:#fef2f2;
    --ok:#15803d;
    --ok-soft:#ecfdf3;
  }
  *{box-sizing:border-box}
  body{
    margin:0;
    padding:0 12px 24px;
    font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
    background:var(--bg);
  }
  .qa-shell{
    max-width:980px;
    margin:20px auto 32px;
  }
  .qa-top-actions{
    display:flex;
    justify-content:flex-end;
    gap:8px;
    flex-wrap:wrap;
    margin-bottom:10px;
  }
  .qa-top-btn{
    display:inline-block;
    padding:8px 12px;
    border-radius:10px;
    border:1px solid var(--brand);
    color:var(--brand);
    background:#f3faf9;
    font-weight:600;
    font-size:13px;
    text-decoration:none;
  }
  .qa-top-btn.logout{
    background:#ffffff;
  }

  .qa-card{
    background:var(--card);
    border-radius:14px;
    border:1px solid rgba(15,23,42,0.06);
    box-shadow:0 4px 14px rgba(15,23,42,0.06);
    padding:14px 16px;
    margin-bottom:14px;
  }
  .qa-header-main{
    display:flex;
    align-items:flex-start;
    justify-content:space-between;
    gap:10px;
    flex-wrap:wrap;
  }
  .qa-title{
    font-size:18px;
    font-weight:750;
    color:var(--ink);
    margin-bottom:4px;
  }
  .qa-subtitle{
    font-size:13px;
    color:var(--muted);
    margin:0;
  }
  .qa-chip{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding:2px 8px;
    border-radius:999px;
    font-size:11px;
    font-weight:600;
    border:1px solid rgba(15,23,42,0.1);
    color:var(--muted);
    white-space:nowrap;
  }
  .qa-chip-course{
    background:#eef2ff;
    border-color:#c7d2fe;
    color:#3730a3;
  }

  .qa-filters{
    display:flex;
    flex-wrap:wrap;
    gap:8px;
    margin:10px 0 4px;
  }
  .qa-search{
    flex:1;
    min-width:220px;
    padding:9px 11px;
    border-radius:10px;
    border:1px solid var(--line);
    font-size:14px;
  }
  .qa-toggle-group{
    display:inline-flex;
    align-items:center;
    gap:6px;
    font-size:13px;
    color:var(--muted);
  }
  .qa-toggle-group input{
    accent-color:var(--brand);
  }

  .qa-stats{
    margin-top:6px;
    font-size:12px;
    color:#9ca3af;
  }

  .qa-ann-list{
    list-style:none;
    margin:0;
    padding:0;
  }
  .qa-ann-item{
    border-radius:12px;
    border:1px solid rgba(148,163,184,0.35);
    padding:10px 12px;
    margin-bottom:8px;
    background:#ffffff;
    display:flex;
    flex-direction:column;
    gap:2px;
  }
  .qa-ann-topline{
    display:flex;
    justify-content:space-between;
    gap:8px;
    flex-wrap:wrap;
    align-items:flex-start;
  }
  .qa-ann-title{
    font-size:14px;
    font-weight:650;
    color:var(--ink);
  }
  .qa-ann-body{
    font-size:13px;
    color:#4b5563;
  }
  .qa-ann-meta{
    font-size:12px;
    color:#9ca3af;
    display:flex;
    flex-wrap:wrap;
    gap:8px;
  }
  .qa-ann-item-old{
    background:#f9fafb;
  }

  .qa-ann-divider{
    margin:10px 0 6px;
    padding-top:6px;
    font-size:11px;
    font-weight:600;
    color:#6b7280;
    text-transform:uppercase;
    letter-spacing:0.06em;
    border-top:1px solid var(--line);
  }

  /* ✅ Urgent card styling */
  .qa-ann-item-urgent{
    border-color:#fecaca;
    background:#fff7f7;
    box-shadow:0 6px 16px rgba(185,28,28,0.08);
  }
  /* ✅ Announcement rich content helpers (buttons + images) */
.qa-ann-body a[data-qa="btn"],
.qa-ann-body a.qa-btnlink{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding:8px 12px;
  border-radius:10px;
  border:1px solid rgba(11,122,117,.35);
  background:var(--brand-soft);
  color:var(--brand);
  text-decoration:none;
  font-weight:700;
  font-size:12px;
  margin-top:6px;
}

/* ✅ Tighten spacing inside announcement bodies */
.qa-ann-body p{
  margin: 0 0 6px 0;   /* was browser default ~16px */
}
.qa-ann-body p:last-child{
  margin-bottom: 0;
}
.qa-ann-body ul,
.qa-ann-body ol{
  margin: 4px 0 6px 18px;
}
.qa-ann-body li{
  margin: 2px 0;
}
.qa-ann-body br{
  line-height: 1.2;
}
  
.qa-ann-body img{
  max-width:100%;
  height:auto;
  display:block;
  margin:8px 0 4px;
  border-radius:12px;
  border:1px solid rgba(15,23,42,0.08);
}


  .qa-pill{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding:1px 7px;
    border-radius:999px;
    font-size:10px;
    font-weight:600;
    border:1px solid transparent;
    white-space:nowrap;
  }
  .qa-pill-pinned{
    background:#e0f2f1;
    border-color:#b2dfdb;
    color:#0b7a75;
  }
  .qa-pill-urgent{
    background:#fef2f2;
    border-color:#fecaca;
    color:#b91c1c;
  }
  .qa-pill-upcoming{
    background:#fef9c3;
    border-color:#fde68a;
    color:#a16207;
  }
  .qa-pill-live{
    background:#ecfdf3;
    border-color:#bbf7d0;
    color:#166534;
  }
  .qa-pill-ended{
    background:#f3f4f6;
    border-color:#e5e7eb;
    color:#6b7280;
  }

  /* ✅ Actions (Mark as read / Dismiss / Restore) */
  .qa-ann-actions{
    display:flex;
    gap:8px;
    flex-wrap:wrap;
    margin-top:6px;
  }
  .qa-btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding:6px 10px;
    border-radius:10px;
    border:1px solid var(--line);
    background:#fff;
    color:var(--ink);
    font-size:12px;
    font-weight:650;
    cursor:pointer;
  }
  .qa-btn:disabled{
    opacity:.55;
    cursor:not-allowed;
  }
  .qa-btn-primary{
    border-color:rgba(11,122,117,.35);
    background:var(--brand-soft);
    color:var(--brand);
  }
  .qa-btn-danger{
    border-color:rgba(185,28,28,.25);
    background:var(--danger-soft);
    color:var(--danger);
  }
  .qa-pill-new{
    background:#eef2ff;
    border-color:#c7d2fe;
    color:#3730a3;
  }
  .qa-pill-seen{
    background:#f3f4f6;
    border-color:#e5e7eb;
    color:#6b7280;
  }
  .qa-pill-dismissed{
    background:#fff7ed;
    border-color:#fed7aa;
    color:#9a3412;
  }

  .qa-empty{
    font-size:13px;
    color:var(--muted);
  }
  .qa-error{
    font-size:13px;
    color:var(--danger);
    background:var(--danger-soft);
    border-radius:10px;
    padding:8px 10px;
    margin-top:6px;
  }

  .qa-footer-hint{
    margin-top:8px;
    font-size:12px;
    color:#9ca3af;
  }

  @media (max-width:600px){
    .qa-shell{ margin-top:12px; }
    .qa-card{ padding:12px 12px; }
  }
</style>
</head>
