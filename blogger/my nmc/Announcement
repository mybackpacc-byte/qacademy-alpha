   ✅ SAFE HTML RENDERING (body_html)
   - Allow a small whitelist of tags
   - Strip event handlers + unsafe attrs
   - Allow only safe href protocols
   ========================== */
function qaIsSafeHref(href){
  if (!href) return false;
  href = String(href).trim();

  // allow relative links
  if (href[0] === '/' || href[0] === '?' || href[0] === '#') return true;

  // block javascript:, data:, vbscript: even with whitespace/casing tricks
  var lower = href.replace(/\s+/g,'').toLowerCase();
  if (lower.startsWith('javascript:') || lower.startsWith('data:') || lower.startsWith('vbscript:')) return false;

  try{
    var u = new URL(href, window.location.origin);
    return (u.protocol === 'http:' || u.protocol === 'https:' || u.protocol === 'mailto:' || u.protocol === 'tel:');
  }catch(e){
    return false;
  }
}
function qaIsSafeSrc(src){
  if (!src) return false;
  src = String(src).trim();

  // allow relative
  if (src[0] === '/' || src[0] === '?') return true;

  // block javascript:, data:, vbscript: even with whitespace/casing tricks
  var lower = src.replace(/\s+/g,'').toLowerCase();
  if (lower.startsWith('javascript:') || lower.startsWith('data:') || lower.startsWith('vbscript:')) return false;

  try{
    var u = new URL(src, window.location.origin);
    return (u.protocol === 'http:' || u.protocol === 'https:');
  }catch(e){
    return false;
  }
}

    
function qaSanitizeHtmlToFragment(html){
  html = qaDecodeHtmlEntities(html);   // ✅ keep for now
  html = String(html || '');
  var tpl = document.createElement('template');
  tpl.innerHTML = html;

  var ALLOWED = {
    A:1, P:1, BR:1, STRONG:1, EM:1, B:1, I:1,
    UL:1, OL:1, LI:1,
    CODE:1, PRE:1,
    SPAN:1, DIV:1,
    IMG:1
  };

  // Walk all elements and sanitize
  var walker = document.createTreeWalker(tpl.content, NodeFilter.SHOW_ELEMENT, null, false);
  var nodes = [];
  while (walker.nextNode()) nodes.push(walker.currentNode);

  nodes.forEach(function(node){
    var tag = node.tagName;

    // Drop disallowed tags but keep their text content
    if (!ALLOWED[tag]){
      var parent = node.parentNode;
      if (parent){
        while (node.firstChild) parent.insertBefore(node.firstChild, node);
        parent.removeChild(node);
      }
      return;
    }

    // Strip all attributes except safe ones
    var attrs = Array.prototype.slice.call(node.attributes || []);
    attrs.forEach(function(attr){
      var name = String(attr.name || '').toLowerCase();

      // kill event handlers + style always
      if (name.startsWith('on') || name === 'style'){
        node.removeAttribute(attr.name);
        return;
      }

      if (tag === 'A'){
if (
  name !== 'href' &&
  name !== 'title' &&
  name !== 'class' &&
  name !== 'data-qa' &&
  name !== 'data-qa-fixed-quiz' &&   // ✅ allow quiz launcher marker
  name !== 'data-qa-mode'            // ✅ optional (instant/timed)
){
  node.removeAttribute(attr.name);
  return;
}

        if (name === 'href'){
          var href = node.getAttribute('href') || '';
          if (!qaIsSafeHref(href)){
            node.removeAttribute('href');
          } else {
            node.setAttribute('target','_blank');
            node.setAttribute('rel','noopener noreferrer nofollow');
          }
        }
      }
      else if (tag === 'IMG'){
        // allow src + alt + title only
        if (name !== 'src' && name !== 'alt' && name !== 'title'){
          node.removeAttribute(attr.name);
          return;
        }
        if (name === 'src'){
          var src = node.getAttribute('src') || '';
          if (!qaIsSafeSrc(src)){
            node.removeAttribute('src');
          }
        }
      }
      else {
        // non-A, non-IMG tags: remove all attributes
        node.removeAttribute(attr.name);
      }
    });
  });

  return tpl.content;
}


function qaRenderAnnouncementBody(bodyEl, a){
  if (!bodyEl || !a) return;

  // Prefer body_html (sanitized)
  if (a.body_html && String(a.body_html).trim()){
    bodyEl.innerHTML = ''; // clear
    try{
      var frag = qaSanitizeHtmlToFragment(a.body_html);
      bodyEl.appendChild(frag);

      // ✅ If sanitizer results in empty output, fallback to text
      if (!bodyEl.textContent.trim() && !bodyEl.querySelector('a,img,br,strong,em,ul,ol,li,code,pre,span,div,p')){
        bodyEl.textContent = (a.body_text || a.body || '').trim();
      }
      return;
    }catch(e){
      // fallback below
    }
  }

  // Fallback: body_text (then body), always as plain text
  if (a.body_text && String(a.body_text).trim()){
    bodyEl.textContent = String(a.body_text).trim();
  } else if (a.body && String(a.body).trim()){
    bodyEl.textContent = String(a.body).trim();
  } else {
    bodyEl.textContent = '';
  }
}


function qaDecodeHtmlEntities(str){
  str = String(str || '');
  // fast skip
  if (str.indexOf('&lt;') === -1 && str.indexOf('&gt;') === -1 && str.indexOf('&amp;') === -1) return str;

  var ta = document.createElement('textarea');
  ta.innerHTML = str;
  return ta.value;
}

