<!-- 3) ANNOUNCEMENTS JS -->
<script>
function qaInitAnnouncementsPage(){
  (function(){
    var cfg = (window.QA_CONFIG && typeof window.QA_CONFIG === 'object') ? window.QA_CONFIG : {};
    var BUILDER_API_URL   = cfg.BUILDER_API_URL ||
      'https://script.google.com/macros/s/AKfycbx_CDJU5juEDxybplqBlYjJP0tAS52-HIOWE6is19Ub7NqhaV_16MnFmstJpWcdorHT/exec';
    var ANNOUNCEMENTS_URL = cfg.ANNOUNCEMENTS_URL || BUILDER_API_URL || '';

    var DAYS_RECENT = 30;

    var paramsUrl = new URLSearchParams(window.location.search);
    var COURSE_ID = (paramsUrl.get('course_id') || '').trim().toUpperCase() || '';

    var elTitle          = document.getElementById('qa-ann-title');
    var elSubTitle       = document.getElementById('qa-ann-subtitle');
    var elCourseChipWrap = document.getElementById('qa-ann-course-chip');
    var elCourseLabel    = document.getElementById('qa-ann-course-label');

