    function populateCourses(){
      if (!elCourseSelect || !window.QA_ACCESS) return;
      var courses = window.QA_ACCESS.courseIds || [];
      elCourseSelect.innerHTML = '<option value="">Select course...</option>';
      courses.forEach(function(cid){
        var opt = document.createElement('option');
        opt.value = cid;
        opt.textContent = cid;
        elCourseSelect.appendChild(opt);
      });
    }

    function load(){
      clearError();
      if (elSubTitle) elSubTitle.textContent = 'Loading announcements...';

      var token = null;
      try{ token = localStorage.getItem('qa_token'); }catch(e){ token = null; }

      if (!token){
        if (elSubTitle) elSubTitle.textContent = 'Unable to verify your session. Please sign in again.';
        showError('Missing session token.');
        return;
      }

      setHeaderForScope();

      var params = new URLSearchParams();
      params.set('action','announcements.list');
      params.set('token', token);
      params.set('mode','archive');
      params.set('limit','200');

      if (currentScope === 'COURSE' && selectedCourse){
        params.set('course_id', selectedCourse);
      }

      var url = ANNOUNCEMENTS_URL + '?' + params.toString();

      fetch(url)
        .then(function(res){ return res.json(); })
        .then(function(data){
          if (data && data.ok === false){
            showError('Announcements error: ' + (data.error || 'unknown'));
            if (elSubTitle) elSubTitle.textContent = 'Could not load announcements.';
            return;
          }

          var items = Array.isArray(data && data.items) ? data.items : [];

          // ✅ pull states map from backend (recommended: data.states = { ANN001:{state:'seen'}, ... })
          statesById = (data && data.states && typeof data.states === 'object') ? data.states : {};

          allItems = items.map(function(a){
            var copy = Object.assign({}, a);
            copy._state = classifyState(copy);
            copy._id = (copy.announcement_id || copy.id || copy.ann_id || '').trim();
            return copy;
          });

          if (!allItems.length){
            if (elSubTitle) elSubTitle.textContent = 'No announcements found.';
          }

          render();
        })
        .catch(function(err){
          console.error('Announcements archive error', err);
          showError('Failed to load announcements: ' + err.message);
          if (elSubTitle) elSubTitle.textContent = 'Could not load announcements.';
        });
    }

    function onScopeChange(){
      var checked = document.querySelector('input[name="qa-ann-scope"]:checked');
      currentScope = checked ? checked.value : 'ALL';

      if (currentScope === 'COURSE'){
        if (elCourseSelect) elCourseSelect.style.display = 'block';

        if (!selectedCourse && COURSE_ID && elCourseSelect){
          selectedCourse = COURSE_ID;
          elCourseSelect.value = COURSE_ID;
        }
      } else {
        if (elCourseSelect) elCourseSelect.style.display = 'none';
        selectedCourse = '';
        if (elCourseSelect) elCourseSelect.value = '';
      }

      load();
    }

    if (elScopeRadios && elScopeRadios.length){
      elScopeRadios.forEach(function(r){ r.addEventListener('change', onScopeChange); });
    }
    if (elCourseSelect){
      elCourseSelect.addEventListener('change', function(){
        selectedCourse = this.value || '';
        if (currentScope === 'COURSE') load();
      });
    }

    if (elSearch)     elSearch.addEventListener('input', render);
    if (elUrgent)     elUrgent.addEventListener('change', render);
    if (elIncludeOld) elIncludeOld.addEventListener('change', render);
    if (elIncludeDismissed) elIncludeDismissed.addEventListener('change', render);

    populateCourses();

    if (COURSE_ID){
      var courseRadio = document.querySelector('input[name="qa-ann-scope"][value="COURSE"]');
      if (courseRadio){
        courseRadio.checked = true;
        selectedCourse = COURSE_ID;
        if (elCourseSelect){
          elCourseSelect.style.display = 'block';
          elCourseSelect.value = COURSE_ID;
        }
        currentScope = 'COURSE';
      }
    }

    setHeaderForScope();
    load();
  })();
}
</script>

