function qaOpenFixedQuizFromAnnouncementSmart(quizId, preferredMode){
  quizId = String(quizId || '').trim();
  if(!quizId) return;

  clearError();

  var token = getToken();
  if(!token){
    showError('Missing session token. Please sign in again.');
    return;
  }

  if (elSubTitle) elSubTitle.textContent = 'Opening quiz...';

  // IMPORTANT: do NOT restrict by source here, or you may miss an existing in-progress attempt
  var urlList = BUILDER_API_URL +
    '?action=attempts.list' +
    '&token=' + encodeURIComponent(token);


  fetch(urlList)
    .then(function(r){ return r.json(); })
    .then(function(res){
      var attempts = Array.isArray(res && res.attempts) ? res.attempts : [];

      // Only this quiz
      var mine = attempts.filter(function(a){
        return String(a.quiz_id || '').trim() === quizId;
      });

      // Sort newest first
      mine.sort(function(a,b){
        var da = new Date(a.ts_iso || a.timestamp || 0).getTime();
        var db = new Date(b.ts_iso || b.timestamp || 0).getTime();
        return (db||0) - (da||0);
      });

      var inProg = mine.find(function(a){
        return String(a.status || '').toLowerCase() === 'in_progress';
      });

      if(inProg && inProg.attempt_id){
        // ✅ Resume
        goToAttemptId(inProg.attempt_id, inProg.mode || preferredMode);
        return { done:true };
      }

      // If there is no in-progress attempt, we start a fresh attempt.
      // (We do NOT auto-open completed attempts from announcements.)


      // 3) Otherwise spawn new (token-authoritative)
      var payload = {
        quiz_id: quizId,
        source: 'fixed'
        // Do NOT send user_id. Backend should derive it from token.
      };

      var spawnBody = new URLSearchParams();
      spawnBody.set('action', 'fixed.spawn');
      spawnBody.set('token', token);
      spawnBody.set('payload', JSON.stringify(payload));

      return fetch(BUILDER_API_URL, {
        method:'POST',
        headers:{ 'Content-Type':'application/x-www-form-urlencoded' },
        body: spawnBody
      })
      .then(function(r){ return r.json(); })
      .then(function(data){
        if(!data || data.ok === false) throw new Error((data && data.error) || 'spawn_failed');
        if(!data.attempt_id) throw new Error('Missing attempt_id');
        goToAttemptId(data.attempt_id, (data.mode || preferredMode));
        return { done:true };
      });

    })
    .catch(function(err){
      console.error(err);
      showError('Could not open quiz: ' + err.message);
      if (elSubTitle) setHeaderForScope();
    });

  function goToAttemptId(attemptId, mode){
    var m = String(mode || preferredMode || '').toLowerCase();
    var base = (m === 'timed') ? TIMED_RUNNER_URL : INSTANT_RUNNER_URL;
    var sep = base.indexOf('?') === -1 ? '?' : '&';
    window.location.href = base + sep + 'quiz_id=' + encodeURIComponent(attemptId);
  }
}

