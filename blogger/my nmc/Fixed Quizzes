<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>QAcademy — Fixed Quizzes</title>

<style>
  :root{
    --brand:#0b7a75;
    --muted:#859998;
    --ink:#0f172a;
    --bg:#f6f8f7;
    --card:#ffffff;
    --soft:rgba(0,0,0,.06);
    --danger:#b42318;
    --danger-soft:#fff5f5;
  }

  *{box-sizing:border-box}

  body{
    margin:0;
    font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
    background:var(--bg);
    color:var(--ink);
  }

  .fq-wrap{
    max-width:980px;
    margin:24px auto;
    padding:0 14px 32px;
  }

  .fq-header{
    display:flex;
    flex-direction:column;
    gap:4px;
    margin-bottom:14px;
  }

  .fq-header-title{
    font-size:20px;
    font-weight:700;
    color:var(--brand);
  }

  .fq-header-sub{
    font-size:13px;
    color:#4b5b59;
  }

  .fq-top-actions{
    display:flex;
    flex-wrap:wrap;
    justify-content:flex-end;
    gap:8px;
    margin-bottom:10px;
  }

  .fq-top-actions a{
    display:inline-block;
    padding:7px 11px;
    border-radius:999px;
    border:1px solid var(--brand);
    font-size:12px;
    font-weight:600;
    text-decoration:none;
    color:var(--brand);
    background:#f3faf9;
    white-space:nowrap;
  }

  .fq-top-actions a.fq-logout{
    background:#ffffff;
  }

  .fq-filters-card{
    background:var(--card);
    border-radius:14px;
    border:1px solid var(--soft);
    padding:10px 12px;
    box-shadow:0 6px 16px rgba(0,0,0,.05);
    margin-bottom:12px;
  }

  .fq-filters-grid{
    display:grid;
    grid-template-columns:1fr;
    gap:8px;
  }

  .fq-filter-group{
    display:flex;
    flex-direction:column;
    gap:4px;
    font-size:12px;
  }

  .fq-filter-label{
    font-weight:600;
    color:#475569;
  }

  .fq-filter-group select,
  .fq-filter-group input[type="search"]{
    padding:7px 9px;
    border-radius:10px;
    border:1px solid #e2e8f0;
    font-size:13px;
  }

  .fq-filters-row-bottom{
    display:flex;
    flex-wrap:wrap;
    gap:8px;
    margin-top:6px;
    align-items:center;
    justify-content:space-between;
  }

  .fq-summary-chip{
    font-size:12px;
    padding:4px 8px;
    border-radius:999px;
    background:#edf7f5;
    color:#334155;
    border:1px solid #cbd5e1;
    white-space:nowrap;
  }

  .fq-reset-btn{
    border:none;
    background:none;
    font-size:12px;
    color:#0b7a75;
    cursor:pointer;
    text-decoration:underline;
    padding:0;
  }

  .fq-main{
    margin-top:12px;
  }

  .fq-message{
    display:none;
    margin-bottom:10px;
    padding:9px 11px;
    border-radius:10px;
    border:1px solid var(--soft);
    background:#ffffff;
    font-size:13px;
    color:#475569;
  }

  .fq-message--error{
    border-color:#fecaca;
    background:var(--danger-soft);
    color:var(--danger);
  }

  .fq-course-block{
    margin-bottom:18px;
    padding-bottom:4px;
  }

  /* Clear visual separator between course sections */
  .fq-course-block + .fq-course-block{
    border-top:1px solid rgba(0,0,0,.06);
    padding-top:14px;
    margin-top:4px;
  }

  .fq-course-header{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:8px;
    margin-bottom:8px;
    cursor:pointer;
    user-select:none;
  }

  .fq-course-header:focus{
    outline:2px solid var(--brand);
    outline-offset:2px;
    border-radius:8px;
  }

  .fq-course-title{
    font-size:15px;
    font-weight:700;
    color:#0f172a;
  }

  .fq-course-sub{
    font-size:12px;
    color:#6b7280;
  }

  .fq-course-header-right{
    display:flex;
    align-items:center;
    gap:6px;
  }

  .fq-course-toggle-icon{
    font-size:12px;
    display:inline-block;
    transition:transform .18s ease, opacity .18s ease;
    opacity:.8;
  }

  .fq-course-block--collapsed .fq-course-toggle-icon{
    transform:rotate(-90deg);
    opacity:.7;
  }

  .fq-course-grid{
    display:grid;
    grid-template-columns:1fr;
    gap:10px;
  }

  /* Hide grid when collapsed */
  .fq-course-block--collapsed .fq-course-grid{
    display:none;
  }

  .fq-card{
    position:relative;
    overflow:hidden;
    background:var(--card);
    border-radius:14px;
    border:1px solid rgba(0,0,0,.08);
    padding:10px 11px;
    box-shadow:0 4px 12px rgba(0,0,0,.04);
  }

  /* Left colour bar base */
  .fq-card::before{
    content:"";
    position:absolute;
    left:0;
    top:0;
    bottom:0;
    width:4px;
    background:var(--muted);
    opacity:0.6;
  }

  /* Instant mode tint + bar */
  .fq-card--instant{
    background:linear-gradient(90deg, rgba(11,122,117,0.06), #ffffff);
  }
  .fq-card--instant::before{
    background:#0b7a75;
    opacity:0.9;
  }

  /* Timed mode tint + bar */
  .fq-card--timed{
    background:linear-gradient(90deg, rgba(245,158,11,0.07), #ffffff);
  }
  .fq-card--timed::before{
    background:#f59e0b;
    opacity:0.9;
  }

  .fq-card-header-top{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:4px;
  }

  .fq-pill-mode{
    display:inline-block;
    padding:2px 8px;
    border-radius:999px;
    font-size:10px;
    font-weight:700;
    letter-spacing:.03em;
    text-transform:uppercase;
  }

  .fq-pill-mode--instant{
    background:#e4f6f3;
    color:#0b7a75;
  }

  .fq-pill-mode--timed{
    background:#fff4d6;
    color:#8a5a0a;
  }

  .fq-status-chip{
    display:inline-block;
    padding:1px 7px;
    border-radius:999px;
    font-size:10px;
    font-weight:600;
    margin-left:6px;
    border:1px solid transparent;
  }

  .fq-status--active{
    background:#ecfbf8;
    border-color:#c7ebe1;
    color:#0a6c67;
  }

  .fq-status--upcoming{
    background:#fff9ea;
    border-color:#f2ddaa;
    color:#6a4a0a;
  }

  .fq-status--closed{
    background:#f4f5f7;
    border-color:#d4d7de;
    color:#4b5563;
  }

  .fq-card-title{
    font-size:14px;
    font-weight:700;
    margin-bottom:2px;
    color:#0b3d3b;
  }

  .fq-card-meta{
    font-size:12px;
    color:#6b7280;
    margin-bottom:6px;
  }

  .fq-card-stats{
    font-size:12px;
    color:#4b5563;
    margin-bottom:8px;
  }

  .fq-card-actions{
    display:flex;
    flex-wrap:wrap;
    gap:8px;
    align-items:center;
    justify-content:flex-start;
  }

  .fq-main-btn{
    padding:7px 11px;
    font-size:12px;
    font-weight:600;
    border-radius:999px;
    border:1px solid #0b7a75;
    background:#0b7a75;
    color:#ffffff;
    cursor:pointer;
  }

  .fq-main-btn[disabled]{
    opacity:.6;
    cursor:default;
  }

  .fq-secondary-link{
    font-size:11px;
    color:#0b7a75;
    text-decoration:underline;
    background:none;
    border:none;
    cursor:pointer;
    padding:0;
  }

  .fq-empty-text{
    font-size:13px;
    color:#6b7280;
    margin-top:4px;
  }

  @media (min-width:720px){
    .fq-filters-grid{
      grid-template-columns:repeat(3,minmax(0,1fr));
    }
    .fq-course-grid{
      grid-template-columns:repeat(2,minmax(0,1fr));
    }
  }

  @media (min-width:960px){
    .fq-course-grid{
      grid-template-columns:repeat(3,minmax(0,1fr));
    }
  }
    /* === Fixed Quizzes Loader Overlay === */
   .fq-loader-overlay{
    position:fixed;
    inset:0;
    z-index:9999;
    display:none;
    align-items:center;
    justify-content:center;
    background:rgba(246,248,247,0.40);
    backdrop-filter:blur(1px);
  }


  .fq-loader-card{
    min-width:220px;
    max-width:320px;
    padding:14px 16px;
    border-radius:16px;
    background:var(--card);
    border:1px solid var(--soft);
    box-shadow:0 18px 45px rgba(15,23,42,0.16);
    text-align:center;
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:8px;
  }

  .fq-loader-spinner{
    width:26px;
    height:26px;
    border-radius:999px;
    border:3px solid rgba(11,122,117,0.15);
    border-top-color:var(--brand);
    animation:fq-spin 0.75s linear infinite;
  }

  .fq-loader-text{
    font-size:13px;
    color:#475569;
  }

  @keyframes fq-spin{
    from{transform:rotate(0deg);}
    to{transform:rotate(360deg);}
  }

</style>
</head>
<body>

<!-- 0) PAGE FLAGS FOR Guard v3 -->
<script>
  // Standalone page: only needs auth, not a single course
  window.QA_PAGE_KIND = 'history';   // treated similar to learning history
</script>

<!-- Guard v3 integrated -->
<script>
(function(){
  'use strict';

  /* ============== CONFIG (PER SITE + PER PAGE) ============== */

  // 1) Default config (can be overridden by window.QA_CONFIG)
  var DEFAULT_AUTH_URL       = 'https://script.google.com/macros/s/AKfycbxaChsaqn6Or1G-SHqsXla1DdgYdWXzXLfs9GVs_7xrxDeYwjT0OhvWlYUsJtpMU8so/exec';
  var DEFAULT_LOGIN_SLUG     = 'login_23';
  var DEFAULT_DASHBOARD_SLUG = 'dashboard_23';

  // 2) Optional global config object
  var cfg = (window.QA_CONFIG && typeof window.QA_CONFIG === 'object') ? window.QA_CONFIG : {};

  var AUTH_URL       = cfg.AUTH_URL       || DEFAULT_AUTH_URL;
  var LOGIN_SLUG     = cfg.LOGIN_SLUG     || DEFAULT_LOGIN_SLUG;
  var DASHBOARD_SLUG = cfg.DASHBOARD_SLUG || DEFAULT_DASHBOARD_SLUG;

  // 3) Per-page flags (set these BEFORE including this snippet if you want to override)
  var PAGE_KIND     = window.QA_PAGE_KIND || 'course';
  var COURSE_ID     = window.QA_COURSE_ID || null;
  var REQUIRE_ADMIN = (typeof window.QA_REQUIRE_ADMIN === 'boolean')
    ? window.QA_REQUIRE_ADMIN
    : (String(PAGE_KIND).toLowerCase() === 'admin');

  /* ============== EXPORTED STATE ============== */

  window.QA_GUARD_STATE      = 'pending'; // 'pending' | 'ready' | 'blocked' | 'error'
  window.QA_GUARD_BLOCK_TYPE = null;      // 'session_expired' | 'account_issue' | 'no_course_access' | 'admin_required' | ...

  var guardResolve, guardReject;
  window.qaGuardReady = new Promise(function(resolve, reject){
    guardResolve = resolve;
    guardReject  = reject;
  });

  function persistGuardState(state, blockType){
    window.QA_GUARD_STATE      = state;
    window.QA_GUARD_BLOCK_TYPE = blockType || null;
  }

  /* ============== NAVIGATION HELPERS ============== */

  function buildPageUrl(slug){
    slug = String(slug || '').replace(/^\s+|\s+$/g, '');
    if(!slug) return '/';
    // Blogger pages pattern: /p/slug.html
    return '/p/' + slug + '.html';
  }

  function go(url){
    window.location.replace(url);
  }

  function qaGoToLogin(reason){
    var url = buildPageUrl(LOGIN_SLUG);
    if(reason){
      var sep = url.indexOf('?') === -1 ? '?' : '&';
      url += sep + 'reason=' + encodeURIComponent(reason);
    }
    go(url);
  }

  function qaGoToDashboard(){
    go(buildPageUrl(DASHBOARD_SLUG));
  }

  function qaLogout(){
    try{
      localStorage.removeItem('qa_token');
      localStorage.removeItem('qa_user_id');
    }catch(e){}
    qaGoToLogin('logout');
  }

  window.qaGoToLogin    = qaGoToLogin;
  window.qaGoToDashboard = qaGoToDashboard;
  window.qaLogout       = qaLogout;

  /* ============== OVERLAY (LOADER + BLOCKED UI) ============== */

  var overlayId = 'qa-guard-overlay';

  function ensureOverlay(){
    var el = document.getElementById(overlayId);
    if(el) return el;

    el = document.createElement('div');
    el.id = overlayId;
    el.style.position = 'fixed';
    el.style.inset = '0';
    el.style.zIndex = '99999';
    el.style.background = 'rgba(15,23,42,0.86)';
    el.style.display = 'flex';
    el.style.alignItems = 'center';
    el.style.justifyContent = 'center';
    el.style.fontFamily = 'system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif';
    el.style.padding = '16px';
    el.style.boxSizing = 'border-box';

    el.innerHTML =
      '<div id="qa-guard-overlay-inner" style="max-width:420px;width:100%;background:#ffffff;border-radius:16px;padding:18px 20px;box-shadow:0 18px 45px rgba(15,23,42,0.45);text-align:center;">' +
        '<div id="qa-guard-overlay-title" style="font-size:18px;font-weight:600;margin-bottom:6px;color:#0b7a75;">Checking your access...</div>' +
        '<div id="qa-guard-overlay-body" style="font-size:14px;color:#475569;margin-bottom:14px;">Please wait a moment.</div>' +
        '<div id="qa-guard-overlay-actions" style="font-size:13px;color:#94a3b8;"></div>' +
      '</div>';

    document.body.appendChild(el);
    return el;
  }

  function showOverlay(title, body, actionsHtml){
    var el = ensureOverlay();
    var t = el.querySelector('#qa-guard-overlay-title');
    var b = el.querySelector('#qa-guard-overlay-body');
    var a = el.querySelector('#qa-guard-overlay-actions');

    if(t && typeof title === 'string') t.textContent = title;
    if(b && typeof body === 'string')  b.textContent = body;
    if(a) a.innerHTML = actionsHtml || '';

    el.style.display = 'flex';
  }

  function hideOverlay(){
    var el = document.getElementById(overlayId);
    if(el) el.style.display = 'none';
  }

  function buildBlockedActions(type){
    var btnStyle = 'display:inline-flex;align-items:center;justify-content:center;padding:8px 14px;border-radius:999px;border:none;background:#0b7a75;color:#ffffff;font-size:14px;font-weight:600;cursor:pointer;text-decoration:none;';
    if(type === 'no_course_access' || type === 'admin_required' || type === 'account_issue'){
      return '<button type="button" onclick="qaGoToDashboard()" style="' + btnStyle + '">Go to Dashboard</button>';
    }
    if(type === 'session_expired'){
      return '<button type="button" onclick="qaGoToLogin(\'session_expired\')" style="' + btnStyle + '">Go to Login</button>';
    }
    return '';
  }

  function handleBlocked(type, title, body){
    persistGuardState('blocked', type);
    var actionsHtml = buildBlockedActions(type);
    showOverlay(title, body, actionsHtml);
    guardResolve({ ok:false, blocked:true, type:type });
  }

  /* ============== MAIN GUARD LOGIC ============== */

  function runGuard(){
    // Initial loader
    showOverlay('Checking your access...', 'Please wait while we verify your session.', '');

    var token = null;
    try{
      token = localStorage.getItem('qa_token');
    }catch(e){
      token = null;
    }

    if(!token){
      handleBlocked('session_expired', 'Sign in required', 'Your session has ended. Please sign in again.');
      qaGoToLogin('no_token');
      return;
    }

    if(!AUTH_URL){
      hideOverlay();
      persistGuardState('error', 'missing_auth_url');
      var err = new Error('Guard misconfigured: AUTH_URL is missing.');
      guardReject(err);
      console.error(err);
      return;
    }

    // Call apiVerify via POST
    fetch(AUTH_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({ action: 'verify', token: token })
    })
    .then(function(res){ return res.json(); })
    .then(function(data){
      if(!data || data.ok !== true){
        var errCode = (data && data.error) || 'unknown_error';

        if(errCode === 'missing_token' || errCode === 'not_found' || errCode === 'expired'){
          try{
            localStorage.removeItem('qa_token');
            localStorage.removeItem('qa_user_id');
          }catch(e){}
          handleBlocked('session_expired', 'Sign in required', 'Your session has ended. Please sign in again.');
          qaGoToLogin('session_expired');
          return;
        }

        if(errCode === 'user_missing' || errCode === 'user_inactive' || errCode === 'user_expired'){
          handleBlocked('account_issue', 'Account issue', 'There is a problem with your account. Please contact QAcademy support.');
          return;
        }

        persistGuardState('error', errCode);
        hideOverlay();
        var err = new Error('Guard verify failed: ' + errCode);
        guardReject(err);
        console.error(err);
        return;
      }

      // Success: build QA_USER + QA_ACCESS
      var u      = data.user   || {};
      var flags  = data.flags  || {};
      var access = (data.access && typeof data.access === 'object') ? data.access : {};
      var courseIds = Array.isArray(access.courses) ? access.courses.slice() : [];
      var upperIds  = courseIds.map(function(c){
        return String(c || '').trim().toUpperCase();
      }).filter(Boolean);
      var coursesMeta = Array.isArray(data.courses) ? data.courses : [];

      var QA_USER = {
        id:        u.user_id || '',
        user_id:   u.user_id || '',
        username:  u.username || '',
        email:     u.email || '',
        name:      u.name || '',
        forename:  u.forename || '',
        surname:   u.surname || '',
        phone_number: u.phone_number || '',
        program_id:   u.program_id || '',
        cohort:       u.cohort || '',
        avatar_url:   u.avatar_url || '',
        role:         u.role || '',
        is_admin:     !!(flags && flags.is_admin),
        must_change_password: !!u.must_change_password,
        user_expires_utc: u.expires_utc || ''
      };

      var QA_ACCESS = {
        courseIds: upperIds,
        access_expires_utc: access.expires_utc || '',
        coursesMeta: coursesMeta,
        hasCourse: function(courseId){
          var cid = String(courseId || '').trim().toUpperCase();
          if(!cid) return false;
          return this.courseIds.indexOf(cid) !== -1;
        }
      };

      window.QA_USER   = QA_USER;
      window.QA_ACCESS = QA_ACCESS;

      try{
        if(QA_USER.user_id){
          localStorage.setItem('qa_user_id', QA_USER.user_id);
        }
      }catch(e){}

      // Page-level rules
      var kind = String(PAGE_KIND || '').toLowerCase();
      var cid  = COURSE_ID ? String(COURSE_ID).trim().toUpperCase() : '';

      // Dashboard: any verified user OK (even if no courses yet)
      if(kind === 'dashboard'){
        persistGuardState('ready', null);
        hideOverlay();
        guardResolve({ ok:true, blocked:false, kind:kind });
        return;
      }

      // Admin pages
      if(kind === 'admin' || REQUIRE_ADMIN){
        if(!QA_USER.is_admin){
          handleBlocked('admin_required', 'Admin access required', 'This page is only available to QAcademy admins.');
          return;
        }
        persistGuardState('ready', null);
        hideOverlay();
        guardResolve({ ok:true, blocked:false, kind:kind });
        return;
      }

      // Course-tied pages
      if(
        kind === 'course' ||
        kind === 'runner_instant' ||
        kind === 'runner_timed' ||
        kind === 'history_course'
      ){

       if(!cid){
          persistGuardState('error', 'missing_course_id');
          hideOverlay();
          var err2 = new Error('Guard misconfigured: QA_COURSE_ID is missing for course-tied page.');
          guardReject(err2);
          console.error(err2);
          return;
        }

        if(!QA_ACCESS.hasCourse(cid)){
          handleBlocked(
            'no_course_access',
            'No access to this course',
            'Your current subscription does not include this course. Please go back to your dashboard to see the courses you have access to.'
          );
          return;
        }

        persistGuardState('ready', null);
        hideOverlay();
        guardResolve({ ok:true, blocked:false, kind:kind, course_id:cid });
        return;
      }

      // General history page (user-level, not course-tied)
      if(kind === 'history'){
        persistGuardState('ready', null);
        hideOverlay();
        guardResolve({ ok:true, blocked:false, kind:kind });
        return;
      }

      // Default: any verified user allowed
      persistGuardState('ready', null);
      hideOverlay();
      guardResolve({ ok:true, blocked:false, kind:kind });
    })
    .catch(function(err){
      persistGuardState('error', 'network');
      console.error('Guard network/error', err);
      showOverlay(
        'Network problem',
        'We could not verify your access due to a network error. Please check your connection and reload this page.',
        ''
      );
      guardReject(err);
    });
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', runGuard);
  } else {
    runGuard();
  }

})();
</script>

<div id="qa-fixed-app" style="display:none;">
  <div class="fq-wrap">

    <!-- Top navigation actions -->
    <div class="fq-top-actions">
      <a href="/p/dashboard_23.html" id="fq-back-dashboard">Dashboard</a>
      <!-- Optional: course back-link injected later if ?course_id= given -->
      <a href="#" class="fq-logout" onclick="qaLogout();return false;">Logout</a>
    </div>

    <!-- Header -->
    <header class="fq-header">
      <div class="fq-header-title">Fixed Quizzes</div>
      <div class="fq-header-sub" id="fq-header-sub">
        View all official QAcademy fixed quizzes across your courses. Start new quizzes, resume where you left off, or retake previous ones.
      </div>
    </header>

    <!-- Filters card -->
    <section class="fq-filters-card" aria-label="Filters">
      <div class="fq-filters-grid">
        <!-- Course filter -->
        <div class="fq-filter-group">
          <label for="fq-filter-course" class="fq-filter-label">Course</label>
