        }else if(headerSubEl){
          // Preselect without lock (fallback)
          headerSubEl.textContent =
            'Showing fixed quizzes for ' + courseLabelForId(preselectCourseId) +
            ' (' + preselectCourseId + '). You can change the course using the filters above.';
        }
      }else{
        // course_id in URL but not in access list → fall back to all
        preselectCourseId = '';
        lockedToCourseId  = '';
      }
    }else if(headerSubEl){
      // Default generic header when not locked to a specific course
      headerSubEl.textContent =
        'View all official QAcademy fixed quizzes across your courses. Start new quizzes, resume where you left off, or retake previous ones.';
    }
  }


function attachFilterListeners(){
  if(selCourse)    selCourse.addEventListener('change', applyFiltersAndRender);
