  // ===== Data loading =====
  function fetchJson(url){
    return fetch(url).then(function(res){
      if(!res.ok) throw new Error('HTTP ' + res.status);
      return res.json();
    });
  }

  function fetchText(url, options){
    return fetch(url, options || {}).then(function(res){
      if(!res.ok) throw new Error('HTTP ' + res.status);
      return res.text();
    });
  }

  function loadCourseQuizzesForCourse(courseId){
    var url = BUILDER_API_URL +
      '?action=coursequizzes&course_id=' +
      encodeURIComponent(courseId);
    return fetchJson(url).then(function(data){
      if(!data || !Array.isArray(data.quizzes)) return [];
      // Add course_id explicitly to each quiz object (defensive)
      data.quizzes.forEach(function(q){
        if(!q.course_id) q.course_id = courseId;
      });
      return data.quizzes;
    });
  }

  function loadAllCourseQuizzes(){
    if(!coursesList.length) return Promise.resolve([]);
    var promises = coursesList.map(function(c){
      return loadCourseQuizzesForCourse(c.course_id)
        .catch(function(err){
          console.error('Failed to load quizzes for course', c.course_id, err);
          return [];
        });
    });
    return Promise.all(promises).then(function(results){
      var merged = [];
      results.forEach(function(list){
        if(Array.isArray(list)) merged = merged.concat(list);
      });
      return merged;
    });
  }

  function loadAttemptsForUser(){
    var token = getToken();
    if(!token){
      // We can still show quizzes, but no per-user stats
      return Promise.resolve({ attempts: [], summary:{ count:0, avg_pct:0 } });
    }
    var url = BUILDER_API_URL +
      '?action=attempts.list' +
      '&token=' + encodeURIComponent(token) +
      '&source=' + encodeURIComponent('fixed');
    return fetchJson(url).catch(function(err){
      console.error('Failed to load attempts.list:', err);
      return { attempts: [], summary:{ count:0, avg_pct:0 } };
    });
  }

  // ===== Date helpers =====
  function asDate(val){
    if(!val && val !== 0) return null;
    if(val instanceof Date){
      if(isNaN(val.getTime())) return null;
      return val;
    }
    var d = new Date(val);
    if(isNaN(d.getTime())) return null;
    return d;
  }

  function fmtShort(d){
    if(!d) return '';
    return d.toLocaleDateString(undefined, { day:'2-digit', month:'short', year:'numeric' });
  }

  function formatDateInfo(q){
    var status = String(q.status || '').toUpperCase();
    var pub  = asDate(q.publish_at);
    var unp  = asDate(q.unpublish_at);

    if(status === 'UPCOMING'){
      if(pub) return 'Opens: ' + fmtShort(pub);
      return 'Opens soon';
    }
    if(status === 'ACTIVE'){
      if(pub && unp) return 'Open: ' + fmtShort(pub) + ' – ' + fmtShort(unp);
      if(pub) return 'Open since: ' + fmtShort(pub);
      if(unp) return 'Closes: ' + fmtShort(unp);
      return 'Currently open';
    }
    if(status === 'CLOSED'){
      if(unp) return 'Closed: ' + fmtShort(unp);
      return 'Closed';
    }
    return '';
  }

  // ===== Stats computation =====
  function computeQuizStats(){
    quizStats = {};
    if(!Array.isArray(allQuizzes) || !Array.isArray(allAttempts)) return;

    // Group attempts by quiz_id
    var byQuiz = {};
    allAttempts.forEach(function(a){
      var qid = String(a.quiz_id || '').trim();
      if(!qid) return;
      if(!byQuiz[qid]) byQuiz[qid] = [];
      byQuiz[qid].push(a);
    });

    Object.keys(byQuiz).forEach(function(qid){
      var list = byQuiz[qid];
      // sort by ts_iso ascending
      list.sort(function(a,b){
        var da = asDate(a.ts_iso);
        var db = asDate(b.ts_iso);
        if(da && db) return da - db;
        if(da && !db) return -1;
        if(!da && db) return 1;
        return 0;
      });
    });

    allQuizzes.forEach(function(q){
      var qid = String(q.quiz_id || '').trim();
      if(!qid) return;
      var atts = byQuiz[qid] || [];
      var attemptsCount = atts.length;

      var inProgressList = atts.filter(function(a){
        return safeNorm(a.status) === 'in_progress';
      });
      var completedList = atts.filter(function(a){
        return safeNorm(a.status) === 'completed';
      });

      var lastAny = atts.length ? atts[atts.length - 1] : null;
      var lastCompleted = completedList.length ? completedList[completedList.length - 1] : null;

      var bestScore = 0;
      completedList.forEach(function(a){
        var pct = Number(a.score_pct || 0);
        if(pct > bestScore) bestScore = pct;
      });

      var lastScore = 0;
      if(lastCompleted){
        lastScore = Number(lastCompleted.score_pct || 0);
      }else if(lastAny){
        lastScore = Number(lastAny.score_pct || 0);
      }

      var lastDateStr = lastAny ? lastAny.ts_iso : '';
      var lastDate = asDate(lastDateStr);

      var state = 'not_started';
      if(attemptsCount === 0){
        state = 'not_started';
      }else if(inProgressList.length){
        state = 'in_progress';
      }else if(completedList.length){
        state = 'completed';
      }

      quizStats[qid] = {
        attemptsCount: attemptsCount,
        inProgress: inProgressList.length ? inProgressList[inProgressList.length - 1] : null,
        lastCompleted: lastCompleted,
        lastAny: lastAny,
        bestScore: bestScore,
        lastScore: lastScore,
        lastDate: lastDate,
        state: state
      };
    });
  }

  // ===== Sorting & filtering =====
  function sortQuizzes(quizzes){
    var STATUS_ORDER = { 'ACTIVE':0, 'UPCOMING':1, 'CLOSED':2 };
    return quizzes.slice().sort(function(a,b){
      var sa = String(a.status || '').toUpperCase();
      var sb = String(b.status || '').toUpperCase();
      var ra = (sa in STATUS_ORDER) ? STATUS_ORDER[sa] : 99;
      var rb = (sb in STATUS_ORDER) ? STATUS_ORDER[sb] : 99;
      if(ra !== rb) return ra - rb;

      var da = asDate(a.publish_at);
      var db = asDate(b.publish_at);
      if(da && db) return db - da;
      if(da && !db) return -1;
      if(!da && db) return 1;
      return 0;
    });
  }

  function filterByQuestionsBand(q, band){
    if(!band) return true;
    var n = Number(q.n || 0);
    if(!n) return false; // unknown -> only show when "All sizes"
    if(band === '1-20')   return n >= 1  && n <= 20;
    if(band === '21-40')  return n >= 21 && n <= 40;
    if(band === '41-60')  return n >= 41 && n <= 60;
    if(band === '61plus') return n >= 61;
    return true;
  }

  function filterByAttemptState(qid, wantedState){
    if(!wantedState) return true;
    var s = quizStats[qid];
    if(!s) return (wantedState === 'not_started'); // no stats => not started
    return s.state === wantedState;
  }

