  function parseQuery(){
    var params = {};
    try{
      var qs = window.location.search || '';
      if(qs.indexOf('?') === 0) qs = qs.slice(1);
      qs.split('&').forEach(function(part){
        if(!part) return;
        var kv = part.split('=');
        var k = decodeURIComponent(kv[0] || '').trim();
        var v = decodeURIComponent(kv[1] || '').trim();
        if(k) params[k] = v;
      });
    }catch(e){}
    return params;
  }

  function getToken(){
    try{
      return localStorage.getItem('qa_token') || '';
    }catch(e){
      return '';
    }
  }

  function getUserId(){
    try{
      return localStorage.getItem('qa_user_id') || '';
    }catch(e){
      return '';
    }
  }

  function safeNorm(s){
    return String(s || '').trim().toLowerCase();
  }

  // ===== Courses from QA_ACCESS =====
  function buildCoursesFromAccess(){
    var access = window.QA_ACCESS || {};
    var ids = Array.isArray(access.courseIds) ? access.courseIds.slice() : [];
    coursesMeta = Array.isArray(access.coursesMeta) ? access.coursesMeta.slice() : [];

    var metaMap = {};
    coursesMeta.forEach(function(c){
      var id = String(c.course_id || c.id || '').trim().toUpperCase();
      if(!id) return;
      metaMap[id] = c;
    });

    coursesList = ids.map(function(cid){
      var upper = String(cid || '').trim().toUpperCase();
      var meta = metaMap[upper] || {};
      var label =
        meta.display_label ||
        meta.label ||
        meta.title ||
        meta.name ||
        upper;
      return { course_id: upper, label: label };
    });
  }

  function courseLabelForId(cid){
    var upper = String(cid || '').trim().toUpperCase();
    for(var i=0;i<coursesList.length;i++){
      if(coursesList[i].course_id === upper) return coursesList[i].label;
    }
    return upper || 'Unknown course';
  }

  // ===== Filters =====
  function fillCourseFilter(){
