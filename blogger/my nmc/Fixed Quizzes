        var tUpper = String(q.type || '').toUpperCase();
        btn.textContent = (tUpper === 'TIMED') ? 'Retake timed quiz' : 'Retake instant quiz';
      }
    });

  }

  function toggleCourseSection(sectionEl, iconEl){
    if(!sectionEl) return;
    var collapsed = sectionEl.classList.toggle('fq-course-block--collapsed');
    if(iconEl){
      // Using rotation via CSS; text stays as "▾"
iconEl.innerHTML = `<svg width="12" height="12" viewBox="0 0 20 20" fill="currentColor" style="display:block">
  <path d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.21 8.29a.75.75 0 01.02-1.08z"/>
</svg>`;
    }
    var headerEl = sectionEl.querySelector('.fq-course-header');
    if(headerEl){
      headerEl.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
    }
  }

  function buildCard(q){
    var qid = String(q.quiz_id || '').trim();
    var stats = quizStats[qid] || {
      attemptsCount: 0,
      state: 'not_started'
    };

    var statusUpper = String(q.status || '').toUpperCase();
    var typeUpper   = String(q.type   || '').toUpperCase();
    var modeLower   = (typeUpper === 'TIMED') ? 'timed' : 'instant';

    var card = document.createElement('article');
    card.className = 'fq-card';
    card.setAttribute('data-quiz-id', qid);
    card.setAttribute('data-course-id', q.course_id || '');

    // Add mode-based visual class
    if(modeLower === 'timed'){
      card.classList.add('fq-card--timed');
    }else{
      card.classList.add('fq-card--instant');
    }

    // Header row: mode pill + status chip
    var headerTop = document.createElement('div');
    headerTop.className = 'fq-card-header-top';

    var modePill = document.createElement('span');
    modePill.className = 'fq-pill-mode';
    if(modeLower === 'timed'){
      modePill.classList.add('fq-pill-mode--timed');
      modePill.textContent = '🕒 Timed';
    }else{
      modePill.classList.add('fq-pill-mode--instant');
      modePill.textContent = '🔥 Instant';
    }

    var statusChip = buildStatusChip(statusUpper);

    headerTop.appendChild(modePill);
    headerTop.appendChild(statusChip);

    // Title
    var titleEl = document.createElement('div');
    titleEl.className = 'fq-card-title';
    titleEl.textContent = q.title || q.quiz_id || 'Untitled quiz';

    // Meta line
    var metaEl = document.createElement('div');
    metaEl.className = 'fq-card-meta';

    var typeLabel = (modeLower === 'timed') ? 'Timed exam' : 'Instant review';
    var parts = [];
    parts.push(typeLabel);
    if(q.n){
      parts.push(q.n + ' questions');
    }
    var dateInfo = formatDateInfo(q);
    if(dateInfo) parts.push(dateInfo);

    metaEl.textContent = parts.join(' | ');

    // Stats line
    var statsEl = document.createElement('div');
    statsEl.className = 'fq-card-stats';

    if(stats.attemptsCount === 0){
      statsEl.textContent = 'Not started yet';
    }else{
      var bits = [];
      if(stats.lastScore > 0){
        bits.push('Last: ' + stats.lastScore + '%');
      }
      if(stats.bestScore > 0){
        bits.push('Best: ' + stats.bestScore + '%');
      }
      bits.push('Attempts: ' + stats.attemptsCount);
      if(stats.lastDate){
        bits.push('Last attempt: ' + fmtShort(stats.lastDate));
      }
      statsEl.textContent = bits.join(' | ');
    }

    // Actions
    var actionsEl = document.createElement('div');
    actionsEl.className = 'fq-card-actions';

    var mainBtn = document.createElement('button');
    mainBtn.type = 'button';
    mainBtn.className = 'fq-main-btn';

    var canClick = (statusUpper === 'ACTIVE');

    if(!canClick){
      if(statusUpper === 'UPCOMING'){
        mainBtn.textContent = 'Not yet open';
      }else if(statusUpper === 'CLOSED'){
        mainBtn.textContent = 'Closed';
      }else{
        mainBtn.textContent = 'Unavailable';
      }
      mainBtn.disabled = true;
    }else{
      // Decide label based on attempt state
      if(stats.state === 'in_progress' && stats.inProgress){
        mainBtn.textContent = 'Resume quiz';
        mainBtn.addEventListener('click', function(){
          goToRunnerExistingAttempt(stats.inProgress);
        });
      }else if(stats.state === 'completed'){
        mainBtn.textContent = 'Retake quiz';
        mainBtn.addEventListener('click', function(){
          retakeQuizFromLatestCompleted(q, mainBtn);
        });
      }else{
        var tUpper = String(q.type || '').toUpperCase();
        mainBtn.textContent = (tUpper === 'TIMED') ? 'Start timed quiz' : 'Start instant quiz';
        mainBtn.addEventListener('click', function(){
          startFixedQuiz(q, mainBtn);
        });
      }
    }

    actionsEl.appendChild(mainBtn);

    // "View attempts" link
    var statsInfo = quizStats[qid];
    if(statsInfo && statsInfo.attemptsCount > 0){
      var link = document.createElement('button');
      link.type = 'button';
      link.className = 'fq-secondary-link';
      link.textContent = 'View attempts';
      link.addEventListener('click', function(){
        qaShowLoader('Opening attempts...');
        // Go to Learning History, filtered by course + quiz
        var slug = LEARNING_HISTORY_SLUG;
        var url = '/p/' + slug + '.html';
        var sep = url.indexOf('?') === -1 ? '?' : '&';
        var params = new URLSearchParams();
        if(q.course_id){
          params.set('course_id', q.course_id);
        }
        if(q.quiz_id){
          params.set('quiz_id', q.quiz_id);
        }
        window.location.href = url + sep + params.toString();
      });
      actionsEl.appendChild(link);
    }

    card.appendChild(headerTop);
    card.appendChild(titleEl);
    card.appendChild(metaEl);
    card.appendChild(statsEl);
    card.appendChild(actionsEl);

    return card;
  }

  function renderCoursesAndCards(filteredQuizzes){
    clearMain();
    if(!mainEl) return;

    if(!filteredQuizzes.length){
      var empty = document.createElement('div');
      empty.className = 'fq-empty-text';
      empty.textContent = 'No quizzes match your filters yet.';
      mainEl.appendChild(empty);
      return;
    }

    // Group by course_id
    var byCourse = {};
    filteredQuizzes.forEach(function(q){
      var cid = String(q.course_id || '').trim().toUpperCase();
      if(!cid) cid = 'UNKNOWN';
      if(!byCourse[cid]) byCourse[cid] = [];
      byCourse[cid].push(q);
    });

    Object.keys(byCourse).sort().forEach(function(cid){
      var quizzes = sortQuizzes(byCourse[cid]);

      var sec = document.createElement('section');
      sec.className = 'fq-course-block';
      sec.setAttribute('data-course-id', cid);

      var header = document.createElement('div');
      header.className = 'fq-course-header';
      header.setAttribute('tabindex','0');
      header.setAttribute('role','button');
      header.setAttribute('aria-expanded','true');

      var left = document.createElement('div');
      var title = document.createElement('div');
      title.className = 'fq-course-title';
      title.textContent = courseLabelForId(cid);

      var sub = document.createElement('div');
      sub.className = 'fq-course-sub';
      sub.textContent = 'Course ID: ' + cid;

      left.appendChild(title);
      left.appendChild(sub);

      var right = document.createElement('div');
      right.className = 'fq-course-sub fq-course-header-right';

      var countSpan = document.createElement('span');
      countSpan.textContent = quizzes.length + (quizzes.length === 1 ? ' quiz' : ' quizzes');

      var icon = document.createElement('span');
      icon.className = 'fq-course-toggle-icon';
      icon.innerHTML = `<svg width="12" height="12" viewBox="0 0 20 20" fill="currentColor" style="display:block">
  <path d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.21 8.29a.75.75 0 01.02-1.08z"/>
</svg>`;


      right.appendChild(countSpan);
      right.appendChild(icon);

      header.appendChild(left);
      header.appendChild(right);

      var grid = document.createElement('div');
      grid.className = 'fq-course-grid';

      quizzes.forEach(function(q){
        grid.appendChild(buildCard(q));
      });

      sec.appendChild(header);
      sec.appendChild(grid);

      // Accordion behaviour
      header.addEventListener('click', function(){
        toggleCourseSection(sec, icon);
      });
      header.addEventListener('keydown', function(ev){
        if(ev.key === 'Enter' || ev.key === ' '){
          ev.preventDefault();
          toggleCourseSection(sec, icon);
        }
      });

      mainEl.appendChild(sec);
    });
  }

  // ===== Apply filters & render =====
  function applyFiltersAndRender(){
    if(!Array.isArray(allQuizzes)){
      renderCoursesAndCards([]);
      setSummary('No quizzes available.');
      return;
    }

    var f = getFilterState();

    var filtered = allQuizzes.filter(function(q){
      var qid = String(q.quiz_id || '').trim();
      var statusUpper = String(q.status || '').toUpperCase();
      var typeUpper   = String(q.type   || '').toUpperCase();
      var modeLower   = (typeUpper === 'TIMED') ? 'timed' : 'instant';

      // Course
      if(f.course && String(q.course_id || '').trim().toUpperCase() !== f.course){
        return false;
      }

      // Mode
      if(f.mode && modeLower !== f.mode){
        return false;
      }

      // Status
      if(f.status && statusUpper !== f.status){
        return false;
      }

      // Questions band
      if(!filterByQuestionsBand(q, f.questions)){
        return false;
      }

      // Attempt state
      if(!filterByAttemptState(qid, f.attempt)){
        return false;
      }

      // Search by title
      if(f.search){
        var title = String(q.title || q.quiz_id || '').toLowerCase();
        if(title.indexOf(f.search) === -1){
          return false;
        }
      }

      return true;
    });

    renderCoursesAndCards(filtered);

    // Summary chip
    var total = allQuizzes.length;
    var shown = filtered.length;

    // Compute average pct across all completed attempts globally
    var completed = allAttempts.filter(function(a){
      return safeNorm(a.status) === 'completed' && Number(a.score_pct || 0) > 0;
    });
    var avg = 0;
    if(completed.length){
      var sum = 0;
      completed.forEach(function(a){ sum += Number(a.score_pct || 0); });
      avg = Math.round(sum / completed.length);
    }

    var summaryParts = [];
    summaryParts.push('Showing ' + shown + ' of ' + total + ' quizzes');
    if(allAttempts.length){
      summaryParts.push(allAttempts.length + ' attempts');
    }
    if(avg > 0){
      summaryParts.push('Avg score ' + avg + '%');
    }
    setSummary(summaryParts.join(' | '));
  }

  // ===== Init =====
  function initFixedQuizzesPage(){
    if(!appEl) return;
    qaShowLoader('Loading fixed quizzes...');


  // Parse query for preselect course
  var q = parseQuery();
  if(q.course_id){
    preselectCourseId = String(q.course_id || '').trim().toUpperCase();
    lockedToCourseId  = preselectCourseId;  // NEW: start in "locked" mode
  }

    // Build courses list from QA_ACCESS
    buildCoursesFromAccess();
    fillCourseFilter();
    attachFilterListeners();

    setMessage('', false);
    setSummary('Loading quizzes...');

    // Load data
       loadAllCourseQuizzes().then(function(quizzes){
      allQuizzes = Array.isArray(quizzes) ? quizzes : [];
      return loadAttemptsForUser();
    }).then(function(res){
      allAttempts = Array.isArray(res.attempts) ? res.attempts : [];
      computeQuizStats();
      applyFiltersAndRender();
      if(!allQuizzes.length){
        setMessage('No fixed quizzes are published for your courses yet.', false);
      }else{
        setMessage('', false);
      }
      qaHideLoader();
    }).catch(function(err){
      console.error('Fixed Quizzes init error:', err);
      setMessage('Failed to load fixed quizzes: ' + err.message, true);
      setSummary('Failed to load quizzes');
      renderCoursesAndCards([]);
      qaHideLoader();
    });

  }

  // Hook into Guard v3 lifecycle
  if(window.qaGuardReady){
    window.qaGuardReady.then(function(state){
      if(!state || state.blocked || state.ok === false){
        return;
      }
      showApp();
      initFixedQuizzesPage();
    }).catch(function(err){
      console.error('Guard / Fixed Quizzes page error:', err);
    });
  }else{
    // Fallback: dev mode without guard
    showApp();
    initFixedQuizzesPage();
  }

})();
</script>

