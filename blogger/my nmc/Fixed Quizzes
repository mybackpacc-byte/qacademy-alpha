      opt.value = c.course_id;
      opt.textContent = c.label + ' (' + c.course_id + ')';
      selCourse.appendChild(opt);
    });

    if(preselectCourseId){
      var found = coursesList.some(function(c){ return c.course_id === preselectCourseId; });
