<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>QAcademy — Create Your Account</title>
  <style>
    :root{
      --brand:#0b7a75;
      --brand-soft:#e0f2f1;
      --muted:#6b7b7a;
      --ink:#0f172a;
      --paper:#ffffff;
      --line:#e2e8f0;
      --danger:#b42318;
      --danger-soft:#fff5f5;
    }
    *{box-sizing:border-box;}
    body{
      margin:0;
      font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
      background:radial-gradient(circle at top,#e0f2f1,#f8fafc);
      color:var(--ink);
    }
    .qa-wrap{
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:18px;
    }
    .qa-card{
      width:100%;
      max-width:460px;
      background:var(--paper);
      border-radius:18px;
      border:1px solid rgba(15,23,42,.06);
      box-shadow:0 18px 45px rgba(15,23,42,.12);
      padding:22px 20px 20px;
    }
    .qa-title{
      font-size:1.25rem;
      font-weight:700;
      margin:0 0 4px;
      color:var(--ink);
    }
    .qa-subtitle{
      font-size:.9rem;
      margin:0 0 14px;
      color:var(--muted);
    }
    .qa-pill{
      display:inline-flex;
      align-items:center;
      gap:6px;
      padding:4px 10px;
      border-radius:999px;
      font-size:.78rem;
      background:var(--brand-soft);
      color:var(--brand);
      margin-bottom:10px;
    }
    .qa-form-group{
      margin-bottom:12px;
    }
    .qa-label{
      display:block;
      font-size:.82rem;
      font-weight:600;
      margin-bottom:4px;
      color:var(--muted);
    }
    .qa-input,
    .qa-select{
      width:100%;
      padding:8px 9px;
      border-radius:10px;
      border:1px solid var(--line);
      font-size:.9rem;
      outline:none;
      transition:border-color .15s, box-shadow .15s, background .15s;
      background:#f9fafb;
    }
    .qa-input:focus,
    .qa-select:focus{
      border-color:var(--brand);
      box-shadow:0 0 0 1px rgba(11,122,117,.12);
      background:#ffffff;
    }
    .qa-input-error{
      border-color:var(--danger) !important;
      background:#fff5f5 !important;
    }
    .qa-hint{
      font-size:.78rem;
      color:#94a3b8;
      margin-top:2px;
      line-height:1.35;
    }
    .qa-error{
      display:none;
      margin-bottom:10px;
      padding:8px 10px;
      border-radius:10px;
      background:var(--danger-soft);
      color:var(--danger);
      font-size:.8rem;
    }
    .qa-success{
      display:none;
      margin-bottom:10px;
      padding:8px 10px;
      border-radius:10px;
      background:var(--brand-soft);
      color:var(--brand);
      font-size:.8rem;
    }
    .qa-btn{
      width:100%;
      border:none;
      border-radius:999px;
      padding:9px 14px;
      font-size:.95rem;
      font-weight:600;
      background:var(--brand);
      color:#ffffff;
      cursor:pointer;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:6px;
      box-shadow:0 8px 18px rgba(11,122,117,.32);
      transition:transform .08s ease, box-shadow .08s ease, opacity .15s;
    }
    .qa-btn:hover{
      transform:translateY(-1px);
      box-shadow:0 12px 30px rgba(11,122,117,.35);
    }
    .qa-btn:active{
      transform:translateY(0);
      box-shadow:0 6px 12px rgba(11,122,117,.28);
    }
    .qa-btn[disabled]{
      opacity:.7;
      cursor:default;
      transform:none;
      box-shadow:0 6px 14px rgba(15,23,42,.18);
    }
    .qa-footer{
      margin-top:10px;
      font-size:.8rem;
      color:var(--muted);
      text-align:center;
    }
    .qa-footer a{
      color:var(--brand);
      text-decoration:none;
      font-weight:600;
    }
    .qa-footer a:hover{text-decoration:underline;}
  </style>
</head>
<body>
<div class="qa-wrap">
  <div class="qa-card">
    <div class="qa-pill">
      <span>✨</span>
      <span>Includes General Paper Free trial access</span>
    </div>

    <h1 class="qa-title">Create your QAcademy account</h1>
    <p class="qa-subtitle">
      Join with your email, choose a username and password, then log in to continue.
      You’ll get General Paper (GP) access during your free trial.
    </p>

    <div id="qa-error" class="qa-error"></div>
    <div id="qa-success" class="qa-success"></div>

    <form id="qa-self-register-form" novalidate>
      <div class="qa-form-group">
        <label class="qa-label" for="qa-forename">First name *</label>
        <input id="qa-forename" class="qa-input" type="text" autocomplete="given-name" />
      </div>

      <div class="qa-form-group">
        <label class="qa-label" for="qa-surname">Surname *</label>
        <input id="qa-surname" class="qa-input" type="text" autocomplete="family-name" />
      </div>

      <!-- Username -->
      <div class="qa-form-group">
        <label class="qa-label" for="qa-username">Username *</label>
        <input id="qa-username" class="qa-input" type="text" autocomplete="username" />
        <div class="qa-hint">
          Letters, numbers, underscore. Must start with a letter. Example: <b>kofi_01</b>
        </div>
      </div>

      <div class="qa-form-group">
        <label class="qa-label" for="qa-email">Email address *</label>
        <input id="qa-email" class="qa-input" type="email" autocomplete="email" />
        <div class="qa-hint">Use the email you’ll use to log in later.</div>
      </div>

      <div class="qa-form-group">
        <label class="qa-label" for="qa-phone">Phone (optional)</label>
        <input id="qa-phone" class="qa-input" type="tel" autocomplete="tel" />
      </div>

      <div class="qa-form-group">
        <label class="qa-label" for="qa-program">Programme (optional)</label>
        <select id="qa-program" class="qa-select">
          <option value="">Select your main programme</option>
          <option value="RN">Registered Nurse (RN)</option>
          <option value="RM">Registered Midwife (RM)</option>
          <option value="RPHN">Registered Public Health Nurse (RPHN)</option>
          <option value="RMHN">Mental Health Nurse (RMHN)</option>
          <option value="NACNAP">NAC / NAP</option>
          <option value="OTHER">Other / Not sure yet</option>
        </select>
        <div class="qa-hint">Helps us show procedures and content that match your route.</div>
      </div>

      <div class="qa-form-group">
        <label class="qa-label" for="qa-password">Password *</label>
        <input id="qa-password" class="qa-input" type="password" autocomplete="new-password" />
        <div class="qa-hint">Minimum 8 characters. Use a password you can remember.</div>
      </div>

      <div class="qa-form-group">
        <label class="qa-label" for="qa-password2">Confirm password *</label>
        <input id="qa-password2" class="qa-input" type="password" autocomplete="new-password" />
      </div>

      <button id="qa-submit" class="qa-btn" type="submit">
        <span>Create my account</span>
      </button>
    </form>

    <div class="qa-footer">
      Already have an account?
      <a href="/p/login_23.html">Log in here</a>
    </div>
  </div>
</div>

<script>
(function(){
  'use strict';

  var cfg = (window.QA_CONFIG && typeof window.QA_CONFIG === 'object') ? window.QA_CONFIG : {};
  var AUTH_URL   = cfg.AUTH_URL   || 'https://script.google.com/macros/s/AKfycbxaChsaqn6Or1G-SHqsXla1DdgYdWXzXLfs9GVs_7xrxDeYwjT0OhvWlYUsJtpMU8so/exec';
  var LOGIN_SLUG = cfg.LOGIN_SLUG || 'login_23';

  var form   = document.getElementById('qa-self-register-form');
  var btn    = document.getElementById('qa-submit');
  var errBox = document.getElementById('qa-error');
  var okBox  = document.getElementById('qa-success');

  var elForename = document.getElementById('qa-forename');
  var elUsername = document.getElementById('qa-username');

  var usernameDirty = false;

  function clearFieldErrors(){
    var ids = ['qa-forename','qa-surname','qa-username','qa-email','qa-password','qa-password2'];
    ids.forEach(function(id){
      var el = document.getElementById(id);
      if(el){ el.classList.remove('qa-input-error'); }
    });
  }

  function showError(msg, fieldId){
    if(!errBox) return;
    errBox.textContent = msg || 'Something went wrong. Please try again.';
    errBox.style.display = 'block';
    if(okBox){ okBox.style.display = 'none'; }

    clearFieldErrors();
    if(fieldId){
      var el = document.getElementById(fieldId);
      if(el){
        el.classList.add('qa-input-error');
        el.focus();
      }
    }
    window.scrollTo({top:0, behavior:'smooth'});
  }

  function showSuccess(msg){
    if(!okBox) return;
    okBox.textContent = msg || 'Account created successfully.';
    okBox.style.display = 'block';
    if(errBox){ errBox.style.display = 'none'; }
  }

  function setLoading(isLoading){
    if(!btn) return;
    if(isLoading){
      btn.disabled = true;
      btn.textContent = 'Creating your account...';
    } else {
      btn.disabled = false;
      btn.textContent = 'Create my account';
    }
  }

  // Admin-style base generator: lowercase, alnum only, must start with letter, cap
  function makeUsernameBase(fromName){
    var base = String(fromName || '').trim().toLowerCase();
    base = base.replace(/[^a-z0-9]/g, '');
    if(!base) base = 'user';
    if(!/^[a-z]/.test(base)) base = 'u' + base;
    if(base.length > 12) base = base.slice(0,12);
    return base;
  }

  function maybeSuggestUsername(){
    if(usernameDirty) return;
    var f = (elForename.value || '').trim();
    if(!f){
      elUsername.value = '';
      return;
    }
    var base = makeUsernameBase(f);
    elUsername.value = base + '01';
  }

  elForename.addEventListener('input', maybeSuggestUsername);
  elForename.addEventListener('blur', maybeSuggestUsername);

  elUsername.addEventListener('input', function(){
    usernameDirty = true;
  });
  elUsername.addEventListener('blur', function(){
    // if they left it blank, allow auto-suggest to kick back in
    var v = (elUsername.value || '').trim();
    if(!v){
      usernameDirty = false;
      maybeSuggestUsername();
    }
  });

  function looksLikeValidUsername(u){
    // Match backend rule: starts with letter; letters/numbers/underscore; max 20; min 3
    return /^[a-z][a-z0-9_]{2,19}$/.test(u);
  }

  function validateClient(){
    clearFieldErrors();
    var f  = document.getElementById('qa-forename').value.trim();
    var s  = document.getElementById('qa-surname').value.trim();
    var u  = document.getElementById('qa-username').value.trim().toLowerCase();
    var e  = document.getElementById('qa-email').value.trim();
    var p1 = document.getElementById('qa-password').value;
    var p2 = document.getElementById('qa-password2').value;

    if(!f) return {ok:false, field:'qa-forename', message:'Please enter your first name.'};
    if(!s) return {ok:false, field:'qa-surname', message:'Please enter your surname.'};

    if(!u) return {ok:false, field:'qa-username', message:'Please choose a username.'};
    if(!looksLikeValidUsername(u)){
      return {ok:false, field:'qa-username', message:'Username must start with a letter and use only letters, numbers, underscore (3–20 chars).'};
    }

    if(!e) return {ok:false, field:'qa-email', message:'Please enter your email address.'};
    if(!/^\S+@\S+\.\S+$/.test(e)){
      return {ok:false, field:'qa-email', message:'Please enter a valid email address.'};
    }

    if(!p1) return {ok:false, field:'qa-password', message:'Please choose a password.'};
    if(p1.length < 8) return {ok:false, field:'qa-password', message:'Password should be at least 8 characters.'};

    if(!p2) return {ok:false, field:'qa-password2', message:'Please confirm your password.'};
    if(p1 !== p2) return {ok:false, field:'qa-password2', message:'Passwords do not match.'};

    return {ok:true};
  }

  function mapError(code){
    code = String(code || '');
    if(code === 'missing_fields') return {msg:'Please fill in all required fields.'};
    if(code === 'email_exists') return {msg:'This email is already registered. Try logging in instead.', field:'qa-email'};
    if(code === 'invalid_username') return {msg:'Username format is not allowed. Use letters/numbers/underscore and start with a letter.', field:'qa-username'};
    if(code === 'username_exists') return {msg:'That username is already taken. Try another one (e.g., add 02).', field:'qa-username'};
    if(code === 'password_policy_failed') return {msg:'Password is too weak. Use at least 8 characters.', field:'qa-password'};
    return {msg:'Could not create your account. Please try again.'};
  }

  // Kick the suggestion once on load (empty until user types)
  maybeSuggestUsername();

  if(form){
    form.addEventListener('submit', function(ev){
      ev.preventDefault();
      if(errBox){ errBox.style.display = 'none'; }
      if(okBox){ okBox.style.display = 'none'; }

      var v = validateClient();
      if(!v.ok){
        showError(v.message, v.field);
        return;
      }

      var forename = document.getElementById('qa-forename').value.trim();
      var surname  = document.getElementById('qa-surname').value.trim();
      var username = document.getElementById('qa-username').value.trim().toLowerCase();
      var email    = document.getElementById('qa-email').value.trim();
      var phone    = document.getElementById('qa-phone').value.trim();
      var program  = document.getElementById('qa-program').value;
      var password = document.getElementById('qa-password').value;
      var ua = (navigator && navigator.userAgent) ? navigator.userAgent : '';

      var body = new URLSearchParams();
      body.append('action', 'self_register');
      body.append('forename', forename);
      body.append('surname', surname);
      body.append('username', username);
      body.append('email', email);
      body.append('password', password);
      body.append('phone_number', phone);
      body.append('program_id', program);
      body.append('cohort', '');
      body.append('avatar_url', '');
      body.append('ua', ua);
      body.append('ip', '');

      setLoading(true);

      fetch(AUTH_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: body.toString()
      })
      .then(function(res){
        if(!res.ok) throw new Error('network_or_http_error');
        return res.json();
      })
      .then(function(data){
        if(!data || !data.ok){
          var m = mapError(data && data.error);
          showError(m.msg, m.field);
          return;
        }

        var redirect = data.redirect;
        if(!redirect){
          redirect = '/p/' + (LOGIN_SLUG || 'login_23') + '.html?reg=1&u=' + encodeURIComponent(username);
        }

        showSuccess('Account created successfully. Redirecting you to login...');
        setTimeout(function(){
          window.location.href = redirect;
        }, 700);
      })
      .catch(function(err){
        console.error(err);
        showError('Something went wrong. Please check your connection and try again.');
      })
      .finally(function(){
        setLoading(false);
      });
    });
  }
})();
</script>
</body>
</html>
