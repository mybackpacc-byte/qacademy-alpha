<script>
/** =================== 3.5) RETURN_TO SUPPORT (Upgrade/Guard compatible) =================== */
(function(){
  const KEY = "qa_return_to";

  function getQS(name){
    try{ return new URLSearchParams(location.search || "").get(name) || ""; }
    catch(e){ return ""; }
  }

  function safeReturnTo(rt){
    rt = String(rt || "").trim();
    if(!rt) return "";
    // Only allow same-site relative paths
    if(rt[0] !== "/") return "";
    if(rt.startsWith("//")) return "";
    if(rt.toLowerCase().includes("javascript:")) return "";
    return rt;
  }

  // Capture on load (so even if page code changes later, it's stored)
  window.qaCaptureReturnTo = function(){
    const rt = safeReturnTo(getQS("return_to"));
    if(rt){
      try{ sessionStorage.setItem(KEY, rt); }catch(e){}
    }
    return rt;
  };

  // Consume (prefer URL param, fallback to sessionStorage)
  window.qaConsumeReturnTo = function(){
    let rt = safeReturnTo(getQS("return_to"));
    if(rt) return rt;

    try{ rt = safeReturnTo(sessionStorage.getItem(KEY) || ""); }catch(e){ rt = ""; }
    if(rt){
      try{ sessionStorage.removeItem(KEY); }catch(e){}
      return rt;
    }
    return "";
  };

  window.qaRedirectAfterLogin = function(dashboardUrl){
    const rt = window.qaConsumeReturnTo();
    if(rt){
      location.href = rt;
      return;
    }
    location.href = dashboardUrl || "/";
  };

  // run now
  window.qaCaptureReturnTo();
})();
</script>

<script>
/* 4) LOGIN FLOW — Email/Username + Password + Google Sign-In + Friendly Errors + IP capture */
(function(){
  var WEB_APP_URL    = "https://script.google.com/macros/s/AKfycbxaChsaqn6Or1G-SHqsXla1DdgYdWXzXLfs9GVs_7xrxDeYwjT0OhvWlYUsJtpMU8so/exec";
  var DASHBOARD_SLUG = "router";
  var TOKEN_KEY      = "qa_token";

  var GOOGLE_CLIENT_ID = "117220903038-1qe508lr01t59mjabeavcl640hraigs4.apps.googleusercontent.com";

  // ==== NEW: client IP cache ====
  var clientIp = "";

  async function fetchClientIpOnce(){
    if (clientIp) return clientIp;
    try{
      var res = await fetch("https://api.ipify.org?format=json");
      if(res.ok){
        var data = await res.json();
        clientIp = data && data.ip ? String(data.ip) : "";
      }
    }catch(e){
      clientIp = "";
    }
    return clientIp;
  }

  var card     = document.getElementById("qa-card");
  var form     = document.getElementById("qa-form");
  var elId     = document.getElementById("qa-id");       // email OR username
  var elP      = document.getElementById("qa-password");
  var elBtn    = document.getElementById("qa-login");
  var elMsg    = document.getElementById("qa-msg");
  var clearBtn = document.getElementById("qa-clear");
  var note     = document.getElementById("qa-note");
  var toggle   = document.getElementById("qa-toggle");
  var caps     = document.getElementById("qa-caps");
  var exitBtn  = document.getElementById("qa-exit");
  var googleBtnContainer = document.getElementById("qa-google-btn");

  // ✅ new: links + advanced container
  var forgotA = document.getElementById("qa-forgot");
  var createA = document.getElementById("qa-create");
  var advBox  = document.getElementById("qa-advanced");

  function dashboardUrl(){
    // keep your existing slug style
    return "/p/" + String(DASHBOARD_SLUG || "").trim() + ".html";
  }

  // ✅ ensure our links carry return_to back to this login page (relative path)
  (function applyAuthLinks(){
    function currentRelative(){
      try{ return (location.pathname || "/") + (location.search || "") + (location.hash || ""); }
      catch(e){ return "/"; }
    }
    var rt = encodeURIComponent(currentRelative());
    if(forgotA) forgotA.href = "/p/forgot-password.html?return_to=" + rt;
    if(createA) createA.href = "/p/subscribe-to-nmc-licensure.html?return_to=" + rt;
  })();

  // ✅ hide advanced tools unless dev flag is enabled
  (function gateAdvanced(){
    if(!advBox) return;
    var qs = null, dev = false;
    try{
      qs = new URLSearchParams(location.search || "");
      dev = (qs.get("dev") === "1") || (localStorage.getItem("qa_dev") === "1");
    }catch(e){
      dev = false;
    }
    advBox.style.display = dev ? "block" : "none";
  })();

  /* === Friendly error mapper (shared by email/username + Google) === */
  function qaMapAuthErrorToMessage(code, via){
    code = String(code || "").trim();
    var fromGoogle = (via === "google");

    switch(code){
      case "missing_credentials":
        return fromGoogle
          ? "Google sign-in could not start. Please try again."
          : "Please enter your email/username and password.";
      case "invalid_login":
        return "Incorrect email/username or password.";
      case "user_inactive":
        return "Your account is inactive. Please contact QAcademy support.";
      case "user_expired":
        return "Your access has expired. Please renew to continue.";
      case "rate_limited":
      case "too_many_attempts":
        return "Too many login attempts. For your security, please wait about 10 minutes before trying again.";
      case "too_many_attempts_24h":
        return "Too many failed login attempts. For your security, this account is locked for 24 hours. Try again later or contact QAcademy support if this wasn’t you.";
      case "google_token_invalid":
        return "Google sign-in could not be verified. Please close this window and try again.";
      case "google_token_expired":
        return "Your Google sign-in session expired. Please try again.";
      case "google_audience_mismatch":
        return "Google sign-in is misconfigured. Please contact support.";
      case "google_email_not_verified":
        return "Your Google email is not verified. Please verify it in your Google account first.";
      case "no_account_for_email":
        return "No QAcademy account is linked to this Google email. Try your email/password or contact support.";
      default:
        return fromGoogle
          ? ("Google sign-in failed. Please try again. (" + code + ")")
          : ("Login failed. Please try again. (" + code + ")");
    }
  }

  function setFieldError(el, hasErr){
    el.setAttribute("aria-invalid", hasErr ? "true" : "false");
    el.style.borderColor = hasErr ? "#f19999" : "var(--line)";
    el.style.boxShadow = hasErr ? "0 0 0 3px rgba(244,67,54,.15)" : "none";
  }

  function showMsg(text, kind){
    elMsg.textContent = text;
    elMsg.className = "mv-status " + (kind === "ok" ? "ok" : "err");
    elMsg.style.display = "block";
    if(kind !== "ok"){
      card.classList.remove("shake"); void card.offsetWidth; card.classList.add("shake");
    }
  }

  function setBusy(busy){
    elBtn.disabled = busy;
    elBtn.setAttribute("aria-busy", busy ? "true" : "false");
    if(busy){
      elBtn.dataset.prev = elBtn.textContent;
      elBtn.textContent = "Signing in...";
    } else {
      elBtn.textContent = elBtn.dataset.prev || "Login";
    }
  }

  // Show/Hide password
  toggle.addEventListener("click", function(){
    if(elP.type === "password"){ elP.type = "text"; toggle.textContent = "Hide"; }
    else{ elP.type = "password"; toggle.textContent = "Show"; }
    elP.focus();
  });

  // Caps lock indicator
  ["keydown","keyup"].forEach(function(ev){
    elP.addEventListener(ev, function(e){
      var isCaps = e.getModifierState && e.getModifierState("CapsLock");
      caps.style.display = isCaps ? "block" : "none";
    });
  });

  // Exit (prefer return_to if present)
  exitBtn.addEventListener("click", function(){
    try{
      if(window.qaConsumeReturnTo){
        var rt = window.qaConsumeReturnTo();
        if(rt){ location.href = rt; return; }
      }
    }catch(e){}
    if(history.length > 1) history.back(); else location.href = "/";
  });

  /* ===== Post-registration banner + prefill ===== */
  (function initRegistrationBanner(){
    try{
      var qs = new URLSearchParams(location.search || "");
      if(qs.get("reg") !== "1") return;

      var u = (qs.get("u") || "").trim();
      if(u){
        elId.value = u;
        setTimeout(function(){ elP.focus(); }, 50);
        showMsg("Account created ✅ Your username is " + u + ". Please log in.", "ok");
      } else {
        showMsg("Account created ✅ Please log in to continue.", "ok");
        setTimeout(function(){ elId.focus(); }, 50);
      }
    }catch(e){}
  })();

  /* ===== LOGIN: Email OR Username + Password ===== */
  async function doLogin(e){
    if(e) e.preventDefault();
    var identifier = (elId.value || "").trim();
    var password   = (elP.value || "").trim();
    setFieldError(elId,false); setFieldError(elP,false);

    if(!identifier || !password){
      showMsg("Please enter your email/username and password.", "err");
      if(!identifier) setFieldError(elId,true);
      if(!password) setFieldError(elP,true);
      return;
    }

    var isEmail = identifier.indexOf("@") !== -1;

    setBusy(true);
    try{
      var ua = navigator.userAgent || "";

      await fetchClientIpOnce();

      var payload = isEmail
        ? { action:"login_email", email:identifier, password:password, ua:ua }
        : { action:"login",       username:identifier, password:password, ua:ua };

      if (clientIp){
        payload.ip = clientIp;
      }

      var body = new URLSearchParams(payload);

      var res = await fetch(WEB_APP_URL, {
        method:"POST",
        headers:{ "Content-Type":"application/x-www-form-urlencoded" },
        body: body
      });
      if(!res.ok) throw new Error("HTTP " + res.status);
      var data = await res.json();

      if(!data || !data.ok){
        var errCode = (data && data.error) || "invalid_login";
        var msg = qaMapAuthErrorToMessage(errCode, "password");
        showMsg(msg, "err");
        setFieldError(elId,true);
        setFieldError(elP,true);
        return;
      }

      localStorage.setItem(TOKEN_KEY, data.token);
      showMsg("Login successful. Redirecting...", "ok");

      // ✅ NEW: go back to return_to if provided (e.g., Upgrade page)
      if(window.qaRedirectAfterLogin){
        window.qaRedirectAfterLogin(dashboardUrl());
      } else {
        location.href = dashboardUrl();
      }
    }catch(err){
      showMsg("Network or server error: " + err.message, "err");
    }finally{
      setBusy(false);
    }
  }

  form.addEventListener("submit", doLogin);
  [elId, elP].forEach(function(el){
    el.addEventListener("keydown", function(e){
      if(e.key === "Enter") doLogin(e);
    });
  });

  // Advanced: clear local token
  if(clearBtn){
    clearBtn.addEventListener("click", function(){
      try{
        localStorage.removeItem(TOKEN_KEY);
        note.textContent = "Cleared local token (qa_token).";
        note.style.color = "var(--brand)";
      }catch(e){
        note.textContent = "Could not clear token: " + e.message;
        note.style.color = "#b42318";
      }
    });
  }

  /* ===== GOOGLE SIGN-IN ===== */
  async function onGoogleCredential(response){
    var idToken = response && response.credential;
    if(!idToken){
      showMsg("Google sign-in failed: no credential received.", "err");
      return;
    }

    setBusy(true);
    showMsg("Signing in with Google...", "ok");
    try{
      var ua = navigator.userAgent || "";

      await fetchClientIpOnce();

      var payload = {
        action:   "login_google",
        id_token: idToken,
        ua:       ua
      };
      if (clientIp){
        payload.ip = clientIp;
      }

      var body = new URLSearchParams(payload);

      var res = await fetch(WEB_APP_URL, {
        method:"POST",
        headers:{ "Content-Type":"application/x-www-form-urlencoded" },
        body: body
      });
      if(!res.ok) throw new Error("HTTP " + res.status);
      var data = await res.json();

      if(!data || !data.ok){
        var errCode = (data && data.error) || "google_login_failed";
        var msg = qaMapAuthErrorToMessage(errCode, "google");
        showMsg(msg, "err");
        return;
      }

      localStorage.setItem(TOKEN_KEY, data.token);
      showMsg("Google login successful. Redirecting...", "ok");

      // ✅ NEW: go back to return_to if provided (e.g., Upgrade page)
      if(window.qaRedirectAfterLogin){
        window.qaRedirectAfterLogin(dashboardUrl());
      } else {
        location.href = dashboardUrl();
      }
    }catch(err){
      showMsg("Google sign-in failed: " + err.message, "err");
    }finally{
      setBusy(false);
    }
  }

  function initGoogleSignIn(attempts){
    attempts = attempts || 0;
    if(!googleBtnContainer) return;
    if(!(window.google && google.accounts && google.accounts.id)){
      if(attempts < 20){
        setTimeout(function(){ initGoogleSignIn(attempts+1); }, 250);
      }
      return;
    }

    try{
      google.accounts.id.initialize({
        client_id: GOOGLE_CLIENT_ID,
        callback: onGoogleCredential
      });

      google.accounts.id.renderButton(googleBtnContainer, {
        type: "standard",
        theme: "outline",
        size: "large",
        text: "continue_with",
        shape: "pill",
        width: "100"
      });
    }catch(e){
      console.log("Google Sign-In init error:", e);
    }
  }

  // Fire a background IP fetch early (non-blocking)
  fetchClientIpOnce();

  initGoogleSignIn();
})();
</script>
