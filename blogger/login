<!-- QAcademy — Standalone Login (Email/Username + Auth v3 + Google Sign-In + Friendly Errors) -->
<meta name="viewport" content="width=device-width, initial-scale=1" />

<style>
  /* 0) Base: full-screen stage (do NOT hide Blogger yet) */
  html, body { margin:0; padding:0; height:100%; }

  #qa-standalone-login{
    position:fixed; inset:0; z-index:2147483647;
    font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;

    /* ✅ the key fix */
    overflow-y:auto;
    -webkit-overflow-scrolling:touch;
  }

  /* 1) Theme */
  :root{
    --brand:#0b7a75; --brand-2:#859998; --gold:#f2c94c;
    --ink:#0f172a; --muted:#5b6a68; --paper:#ffffff; --line:#e6edf0;
    --ring:rgba(11,122,117,.18); --shadow:0 14px 36px rgba(15,23,42,.10);
  }

  .mv-shell{
    width:100%;
    min-height:100dvh;               /* ✅ better than 100vh on mobile */
    display:grid;
    place-items:center;
    padding:32px 12px;
    padding-bottom:calc(32px + env(safe-area-inset-bottom)); /* ✅ iPhone bottom bar */
    box-sizing:border-box;
  }

  /* On mobile, let it sit from top so scrolling feels natural */
  @media (max-width:860px){
    .mv-shell{ place-items:start center; padding-top:18px; }
  }

  .mv-card{
    width:min(920px,96vw); display:grid; grid-template-columns:1fr 1fr;
    background:rgba(255,255,255,.72); backdrop-filter:blur(10px);
    border:1px solid var(--line); border-radius:20px; box-shadow:var(--shadow); overflow:hidden;
    animation:mvIn .35s ease both;
  }
  @keyframes mvIn{from{opacity:0; transform:translateY(8px)} to{opacity:1; transform:none}}
  @media (max-width:860px){ .mv-card{grid-template-columns:1fr} }

  /* Left pane */
  .mv-left{
    position:relative; display:grid; place-items:center; padding:46px 30px; color:#fff;
    background:linear-gradient(160deg,#0d837d,#0a6a67 60%,#0b7a75);
  }
  .mv-left::after{
    content:""; position:absolute; inset:0; pointer-events:none;
    background:
      radial-gradient(600px 400px at 20% 20%, rgba(242,201,76,.22), transparent 70%),
      radial-gradient(500px 380px at 90% 90%, rgba(255,255,255,.18), transparent 70%);
  }
  .mv-logo-box{ width:86px; height:86px; border-radius:22px; overflow:hidden; display:grid; place-items:center; }
  .mv-logo-box img{ width:100%; height:100%; object-fit:contain; display:block; }
  .mv-brand{ margin-top:14px; text-align:center; }
  .mv-brand h2{ margin:6px 0 4px; font-size:26px; letter-spacing:.3px; }
  .mv-brand p{ margin:0; color:rgba(255,255,255,.85); }

  /* Right pane */
  .mv-right{ padding:26px 26px 22px; background:var(--paper); }
  .mv-head{ display:flex; align-items:center; justify-content:space-between; margin-bottom:6px; }
  .mv-title{ font-size:20px; font-weight:800; letter-spacing:.2px; }
  .mv-lock{ display:inline-grid; place-items:center; width:26px; height:26px; border-radius:8px; background:#eef7f6; border:1px solid #d6ece9; }
  label{ display:block; font-size:13px; color:#566561; margin:10px 0 6px; }
  .mv-input{
    width:100%; padding:12px; border:1px solid var(--line); border-radius:12px; font-size:14px;
    background:#fff; transition:border-color .15s, box-shadow .15s;
  }
  .mv-input:focus{ outline:none; border-color:#cfe7e4; box-shadow:0 0 0 4px var(--ring); }
  .mv-row{ display:flex; justify-content:space-between; align-items:center; margin:6px 0; }

  .mv-link{
    font-size:12px; color:var(--brand); border:none; background:none;
    cursor:pointer; padding:2px 4px; text-decoration:none;
  }
  .mv-link:hover{ text-decoration:underline; }

  .mv-actions{ display:flex; gap:10px; margin-top:16px; }
  .mv-btn{
    flex:1; padding:12px 16px; border-radius:12px; border:1px solid var(--brand);
    color:#fff; background:linear-gradient(180deg,#0b7a75,#0a6a67); font-weight:800; letter-spacing:.2px;
  }
  .mv-btn:disabled{ filter:saturate(.6); cursor:progress; }
  .mv-btn.outline{ background:#fff; color:var(--ink); border-color:#d0d7de; font-weight:600; }

  .mv-status{ display:none; margin:12px 0; padding:10px 12px; border-radius:12px; font-size:13px; }
  .ok{ border:1px solid #c6f6d5; background:#f0fff4; color:#276749; }
  .err{ border:1px solid #ffdcdc; background:#fff6f6; color:#b42318; }

  .shake{ animation:mvShake .28s ease; }
  @keyframes mvShake{0%{transform:translateX(0)}25%{transform:translateX(-4px)}50%{transform:translateX(4px)}75%{transform:translateX(-3px)}100%{transform:translateX(0)}}

  /* Google sign-in area + divider */
  .mv-google-wrap{ margin:10px 0 14px; }
  .mv-google-label{ font-size:13px; color:var(--muted); margin-bottom:6px; }
  .mv-or{
    display:flex; align-items:center; gap:8px; font-size:12px; color:var(--muted);
    text-transform:uppercase; letter-spacing:.12em; margin:10px 0 6px;
  }
  .mv-or::before, .mv-or::after{ content:""; flex:1; height:1px; background:var(--line); }

  /* Dark mode */
  @media (prefers-color-scheme: dark){
    :root{ --paper:#0b1116; --line:#1f2a33; --ink:#e6edf3; --muted:#97a6a5; --ring:rgba(11,122,117,.35) }
    .mv-shell{ background:linear-gradient(135deg,#0a0f14,#0b1216) }
    .mv-right{ background:var(--paper) } .mv-input{ background:#0b1116; color:var(--ink) }
    .mv-btn.outline{ background:#0b1116; color:var(--ink); border-color:#2a3a44 }
  }
  @media (max-width:860px){
    .mv-card{ width:min(520px,96vw); }
    .mv-right{ padding-bottom:18px; }
  }
</style>

