<script>
/* 3) SAFE HOIST: move the shell to <body>, then hide siblings */
(function(){
  function hoist(){
    var shell = document.getElementById('qa-standalone-login');
    if(!shell) return;
    try{
      document.body.appendChild(shell);
      Array.from(document.body.children).forEach(function(el){
        if(el !== shell) el.style.display = 'none';
      });
      // ✅ allow scrolling inside the login overlay
      document.documentElement.style.overflow = 'auto';
      document.body.style.overflow = 'auto';
      document.body.style.background = 'transparent';
    }catch(e){}
  }
  if(document.readyState === 'loading'){ document.addEventListener('DOMContentLoaded', hoist); }
  else { hoist(); }
})();
</script>

