    }
  });
}


/** ========== PORTAL HELPERS ========== */

// Calls PortalAuthv2 WebApp (POST form-encoded)
function _portalPost_(payload){
  const url = PORTAL_AUTH_URL;
  const resp = UrlFetchApp.fetch(url, {
    method: 'post',
    contentType: 'application/x-www-form-urlencoded',
    payload: payload,
    muteHttpExceptions: true
  });
  const txt = resp.getContentText() || '';
  try { return JSON.parse(txt); } catch(_){ return { ok:false, error:'bad_portal_json', raw:txt }; }
}

// NEW: Verify token via PortalAuthv2 doGet?action=verify&token=...
function _portalVerifyToken_(token){
  try{
    const url = PORTAL_AUTH_URL + '?action=verify&token=' + encodeURIComponent(String(token||'').trim());
    const resp = UrlFetchApp.fetch(url, { method:'get', muteHttpExceptions:true });
    const txt = resp.getContentText() || '';
    const j = JSON.parse(txt);

    // Expect j.ok true. Payload shape may vary; we return raw as-is.
    if(!j || !j.ok) return { ok:false, raw:j };
    return j;
  } catch(e){
    return { ok:false, error:'verify_fetch_failed:' + String(e) };
  }
}

// Activation bridge
function _portalActivate_(payRow){
  const product_id = String(payRow.product_id || '').trim().toUpperCase();
  const email      = String(payRow.email || '').trim().toLowerCase();
  const user_id    = String(payRow.user_id || '').trim();
  const reference  = String(payRow.reference || '').trim();

  if(ACTIVATION_MODE === 'PAYMENTS_ACTIVATE'){
    const secret = _getProp_(PROP_PORTAL_PAYMENTS_SECRET);
    if(!secret) return { ok:false, error:'missing_portal_payments_secret' };

    const res = _portalPost_({
      action: 'payments_activate',
      secret: secret,
      user_id: user_id,
      email: email,
      product_id: product_id,
      source: 'PAYSTACK',
      source_ref: reference
    });

return {
  ok: !!res.ok,
  subscription_id: res.subscription_id || '',
  user_id: res.user_id || '',   // ✅ if PortalAuth returns it
  error: res.error || '',
  raw: res
};
    
  }

  // Fallback (NOT recommended): uses admin token to call existing assign_product
  const adminToken = _getProp_(PROP_PORTAL_ADMIN_TOKEN);
  if(!adminToken) return { ok:false, error:'missing_portal_admin_token' };

  const res2 = _portalPost_({
    action: 'assign_product',
    token: adminToken,
    user_id: user_id,
    email: email,
    product_id: product_id
  });

  if(res2 && res2.ok) return { ok:true, subscription_id: res2.subscription_id || '', raw: res2 };
  if(res2 && String(res2.error||'') === 'subscription_exists'){
    return { ok:true, subscription_id:'', raw: res2 };
  }

  return { ok:false, error: res2.error || 'assign_product_failed', raw: res2 };
}

// Read product price dynamically from PortalAuthv2 products tab
function _getProductPricingFromPortal_(product_id){
  try{
    const ss = SpreadsheetApp.openById(PORTAL_DB_ID);
    const sh = ss.getSheetByName(PORTAL_TAB_PRODUCTS);
    if(!sh) return { ok:false, error:'portal_products_tab_missing' };

    const values = sh.getDataRange().getValues();
    if(values.length < 2) return { ok:false, error:'portal_products_empty' };

    const headers = values[0].map(String);
    const idx = {};
    headers.forEach((h,i)=> idx[String(h).trim()] = i);

    const pidCol = idx['product_id'];
    if(pidCol === undefined) return { ok:false, error:'portal_products_missing_product_id_col' };

    let row = null;
    for(let r=1;r<values.length;r++){
      const pid = String(values[r][pidCol] || '').trim().toUpperCase();
      if(pid === product_id){ row = values[r]; break; }
    }
    if(!row) return { ok:false, error:'product_not_found' };

    const price_minor = parseInt(row[idx['price_minor']], 10);
    const currency = String(row[idx['currency']] || 'GHS').trim().toUpperCase();
    const name = String(row[idx['name']] || '').trim();

    if(!price_minor || price_minor <= 0) return { ok:false, error:'product_price_invalid' };

    return { ok:true, product_id, price_minor, currency, name };
  } catch(e){
    return { ok:false, error:'portal_product_lookup_error: ' + String(e) };
  }
}


/** ========== PAYSTACK HELPERS ========== */

function _paystackInitialize_({ email, amount_minor, currency, metadata, callback_url }){
  const secret = _getProp_(PROP_PAYSTACK_SECRET_KEY);
  if(!secret) return { ok:false, error:'missing_paystack_secret_key' };

  const payload = {
    email: email,
    amount: amount_minor,
    currency: currency || 'GHS',
    metadata: metadata || {}
  };

  if (callback_url) payload.callback_url = callback_url;

  const resp = UrlFetchApp.fetch(PAYSTACK_INIT_URL, {
    method: 'post',
    contentType: 'application/json',
    headers: { Authorization: 'Bearer ' + secret },
    payload: JSON.stringify(payload),
    muteHttpExceptions: true
  });

  const txt = resp.getContentText() || '';
  let obj = {};
  try { obj = JSON.parse(txt); } catch(_){ obj = {}; }

  if(!obj || obj.status !== true || !obj.data){
    return { ok:false, error:(obj && obj.message) ? obj.message : 'init_failed', raw: obj };
  }

  return {
    ok:true,
    authorization_url: obj.data.authorization_url,
    access_code: obj.data.access_code,
    reference: obj.data.reference,
    raw: obj
  };
}

function _paystackVerify_(reference){
  const secret = _getProp_(PROP_PAYSTACK_SECRET_KEY);
  if(!secret) return { ok:false, error:'missing_paystack_secret_key' };

  const resp = UrlFetchApp.fetch(PAYSTACK_VERIFY_URL + encodeURIComponent(reference), {
    method: 'get',
    headers: { Authorization: 'Bearer ' + secret },
    muteHttpExceptions: true
  });

  const txt = resp.getContentText() || '';
  let obj = {};
  try { obj = JSON.parse(txt); } catch(_){ obj = {}; }

  if(!obj || obj.status !== true || !obj.data){
    return { ok:false, error:(obj && obj.message) ? obj.message : 'verify_failed', raw: obj };
  }

  const st = String(obj.data.status || '').toLowerCase();
  if(st !== 'success'){
    return { ok:false, error:'not_success_status:' + st, raw: obj };
  }

  const amount_minor_paid = parseInt(obj.data.amount, 10);
  return { ok:true, amount_minor_paid, raw: obj };
}


/** ========== PAYMENTS SHEET HELPERS ========== */

function _paymentsSheet_(){
  // Payments tab lives in PAYMENTS_DB_ID if provided, otherwise fallback to PORTAL_DB_ID
  const dbId = (PAYMENTS_DB_ID && String(PAYMENTS_DB_ID).trim()) ? String(PAYMENTS_DB_ID).trim() : PORTAL_DB_ID;
  const ss = SpreadsheetApp.openById(dbId);
  const sh = ss.getSheetByName(TAB_PAYMENTS);
  if(!sh) throw new Error('missing_tab_' + TAB_PAYMENTS + '_in_' + dbId);
  return sh;
}

function _headers_(sh){
  const vals = sh.getRange(1,1,1,sh.getLastColumn()).getValues()[0];
  return vals.map(String);
}

function _rowToObj_(headers, row){
  const o = {};
  headers.forEach((h,i)=> o[h] = row[i]);
  return o;
}

function _findRowIndexBy_(sh, colName, value){
  const headers = _headers_(sh);
  const col = headers.indexOf(colName);
  if(col < 0) return -1;

  const last = sh.getLastRow();
  if(last < 2) return -1;

  const rng = sh.getRange(2, col+1, last-1, 1).getValues();
  const target = String(value || '').trim();
  for(let i=0;i<rng.length;i++){
    if(String(rng[i][0] || '').trim() === target){
      return i + 2;
    }
  }
  return -1;
}

function _appendObj_(sh, headers, obj){
  const row = headers.map(h => (obj[h] !== undefined ? obj[h] : ''));
  sh.appendRow(row);
}

function _updateObj_(sh, headers, rowIndex, obj){
  const row = headers.map(h => (obj[h] !== undefined ? obj[h] : ''));
  sh.getRange(rowIndex, 1, 1, headers.length).setValues([row]);
}

function _paymentsGetByReference_(reference){
  const sh = _paymentsSheet_();
  const headers = _headers_(sh);
  const idx = _findRowIndexBy_(sh, 'reference', reference);
  if(idx < 0) return null;
  const row = sh.getRange(idx,1,1,headers.length).getValues()[0];
  return _rowToObj_(headers, row);
}

function _paymentsUpsertByReference_(reference, obj){
  const sh = _paymentsSheet_();
  const headers = _headers_(sh);
  const idx = _findRowIndexBy_(sh, 'reference', reference);

  if(idx < 0){
    _appendObj_(sh, headers, obj);
    return;
  }
  const row = sh.getRange(idx,1,1,headers.length).getValues()[0];
  const cur = _rowToObj_(headers, row);
  const merged = Object.assign({}, cur, obj);
  _updateObj_(sh, headers, idx, merged);
}

function _paymentsPatch_(reference, patch){
  const sh = _paymentsSheet_();
  const headers = _headers_(sh);
  const idx = _findRowIndexBy_(sh, 'reference', reference);
  if(idx < 0) return;

  const row = sh.getRange(idx,1,1,headers.length).getValues()[0];
  const cur = _rowToObj_(headers, row);
  const merged = Object.assign({}, cur, patch);
  _updateObj_(sh, headers, idx, merged);
}

function _mergeRaw_(rawStr, addObj){
  let base = {};
  try { base = rawStr ? JSON.parse(String(rawStr)) : {}; } catch(_){ base = {}; }
  const merged = Object.assign({}, base, addObj || {});
  return JSON.stringify(merged);
}


/** ========== META ========== */

function apiMeta(){
  const cache = CacheService.getScriptCache();
  const hit = cache.get('qa_meta_v1');
  if(hit){
    try { return _json(JSON.parse(hit)); } catch(_){}
  }

  const programs = _getProgramsFromPortal_();
  const products = _getPublicProductsFromPortal_();

  if(programs && programs.ok === false){
    return _json({ ok:false, error: programs.error || 'programs_meta_failed' });
  }
  if(products && products.ok === false){
    return _json({ ok:false, error: products.error || 'products_meta_failed' });
  }

  const out = {
    ok: true,
    programs: programs.programs || [],
    products: products.products || []
  };

  cache.put('qa_meta_v1', JSON.stringify(out), 300);
  return _json(out);
}

// Programs: prefer "programs" tab; fallback to distinct program_id from program_course_map
function _getProgramsFromPortal_(){
  try{
    const ss = SpreadsheetApp.openById(PORTAL_DB_ID);

    let sh = ss.getSheetByName(PORTAL_TAB_PROGRAMS);
    if(sh){
      const v = sh.getDataRange().getValues();
      if(v.length < 2) return { ok:true, programs: [] };

      const headers = v[0].map(x=>String(x).trim());
      const idx = {};
      headers.forEach((h,i)=>idx[h]=i);

      const pidCol = idx['program_id'];
      if(pidCol === undefined) return { ok:false, programs:[], error:'programs_missing_program_id' };

      const pnameCol = (idx['program_name'] !== undefined) ? idx['program_name'] : idx['name'];

      const seen = {};
      const out = [];
      for(let r=1;r<v.length;r++){
        const program_id = String(v[r][pidCol]||'').trim().toUpperCase();
        if(!program_id || seen[program_id]) continue;
        seen[program_id]=true;

        const program_name = (pnameCol!==undefined) ? String(v[r][pnameCol]||'').trim() : '';
        out.push({ program_id, program_name: program_name || program_id });
      }

      out.sort((a,b)=>a.program_name.localeCompare(b.program_name));
      return { ok:true, programs: out };
    }

    sh = ss.getSheetByName('program_course_map');
    if(!sh) return { ok:true, programs: [] };

    const v2 = sh.getDataRange().getValues();
    if(v2.length < 2) return { ok:true, programs: [] };

    const headers2 = v2[0].map(x=>String(x).trim());
    const pidCol2 = headers2.indexOf('program_id');
    if(pidCol2 < 0) return { ok:false, programs:[], error:'pcmap_missing_program_id' };

    const seen2 = {};
    const out2 = [];
    for(let r=1;r<v2.length;r++){
      const program_id = String(v2[r][pidCol2]||'').trim().toUpperCase();
      if(!program_id || seen2[program_id]) continue;
      seen2[program_id]=true;
      out2.push({ program_id, program_name: program_id });
    }
    out2.sort((a,b)=>a.program_name.localeCompare(b.program_name));
    return { ok:true, programs: out2 };
  } catch(e){
    return { ok:false, programs:[], error:'programs_lookup_error:' + String(e) };
  }
}

// Products: return ACTIVE, non-TRIAL only, with price fields (safe public subset)
function _getPublicProductsFromPortal_(){
  try{
    const ss = SpreadsheetApp.openById(PORTAL_DB_ID);
    const sh = ss.getSheetByName(PORTAL_TAB_PRODUCTS);
    if(!sh) return { ok:false, products:[], error:'portal_products_tab_missing' };

    const v = sh.getDataRange().getValues();
    if(v.length < 2) return { ok:true, products: [] };

    const headersRaw = v[0].map(x => String(x||'').trim());
    const headers = headersRaw.map(h => h.toLowerCase().replace(/\s+/g,'_'));
    const idx = {};
    headers.forEach((h,i)=> idx[h]=i);

    const pidCol    = idx['product_id'] ?? idx['id'];
    const nameCol   = idx['name'] ?? idx['product_name'] ?? idx['plan_name'];
    const priceCol  = idx['price_minor'] ?? idx['amount_minor'] ?? idx['price'];
    const curCol    = idx['currency'] ?? idx['curr'];
    const statusCol = idx['status'];
    const kindCol   = idx['kind'] ?? idx['type'];

    if(pidCol === undefined || nameCol === undefined || priceCol === undefined){
      return { ok:false, products:[], error:'products_missing_required_cols', debug_headers: headersRaw };
    }

    const out = [];
    for(let r=1;r<v.length;r++){
      const product_id = String(v[r][pidCol]||'').trim().toUpperCase();
      if(!product_id) continue;

      const status = (statusCol!==undefined) ? String(v[r][statusCol]||'').trim().toUpperCase() : 'ACTIVE';
      if(status && status !== 'ACTIVE') continue;

      const kind = (kindCol!==undefined) ? String(v[r][kindCol]||'').trim().toUpperCase() : '';
      if(kind === 'TRIAL') continue;

      const name = String(v[r][nameCol]||'').trim() || product_id;

      const rawPrice = v[r][priceCol];
      const price_minor = parseInt(String(rawPrice).replace(/,/g,'').trim(), 10);
      if(!price_minor || price_minor <= 0) continue;

      const currency = (curCol!==undefined) ? String(v[r][curCol]||'GHS').trim().toUpperCase() : 'GHS';

      out.push({ product_id, name, price_minor, currency });
    }

    out.sort((a,b)=>a.name.localeCompare(b.name));
    return { ok:true, products: out };
  } catch(e){
    return { ok:false, products:[], error:'products_lookup_error:' + String(e) };
  }
}


/** ========== UTIL ========== */

function _json(obj){
  return ContentService
    .createTextOutput(JSON.stringify(obj))
    .setMimeType(ContentService.MimeType.JSON);
}

function _iso(d){ return Utilities.formatDate(d, 'Etc/UTC', "yyyy-MM-dd'T'HH:mm:ss'Z'"); }

function _merge(a,b){
  const o = {};
  Object.keys(a||{}).forEach(k=> o[k]=a[k]);
  Object.keys(b||{}).forEach(k=> o[k]=b[k]);
  return o;
}

function _randToken_(){
  // short, URL-safe token
  var seed = Utilities.getUuid() + '|' + new Date().getTime() + '|' + Math.random();
  var bytes = Utilities.computeDigest(Utilities.DigestAlgorithm.SHA_256, seed);
  return Utilities.base64EncodeWebSafe(bytes).replace(/=+$/,'').slice(0, 32);
}

function _addQueryParam_(url, key, value){
  if(!url) return '';
  var u = String(url);
  var sep = (u.indexOf('?') === -1) ? '?' : '&';
  return u + sep + encodeURIComponent(key) + '=' + encodeURIComponent(String(value || ''));
}


function _getProp_(k){
  return PropertiesService.getScriptProperties().getProperty(k) || '';
}

function _getHeaderCI_(e, name){
  const want = String(name || '').toLowerCase();
  const h = (e && e.headers) ? e.headers : null;
  if(!h) return '';
  for (var k in h){
    if (String(k).toLowerCase() === want) return h[k];
  }
  return '';
}


function _hmacSha512Hex_(message, secret){
  const sigBytes = Utilities.computeHmacSha512Signature(message, secret);
  return sigBytes.map(b => ('0' + (b & 0xFF).toString(16)).slice(-2)).join('');
}

/**
 * Generate a strong shared secret for PORTAL_PAYMENTS_SECRET.
 * Run once, then copy the output from Logs.
 */
function qaGeneratePortalPaymentsSecret() {
  var seed = [
    Utilities.getUuid(), Utilities.getUuid(), Utilities.getUuid(),
    String(new Date().getTime()),
    String(Math.random()), String(Math.random())
  ].join('|');

  var bytes = Utilities.computeDigest(Utilities.DigestAlgorithm.SHA_256, seed);
  var secret = Utilities.base64EncodeWebSafe(bytes).replace(/=+$/,'');

  Logger.log('PORTAL_PAYMENTS_SECRET = ' + secret);
  return secret;
}
